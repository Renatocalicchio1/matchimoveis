<%- include('partials/app-shell',{active:'perfil',title:'Meu perfil',subtitle:'Dados da sua conta.',perfil:(user && user.tipo)||'corretor',user:user}) %>

<div class="card">
  <h3>Dados do usuário</h3>
  <form method="POST" action="/app/perfil" style="margin-top:14px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
      <div><label>Nome</label><input name="nome" value="<%= user.nome||'' %>"></div>
      <div><label>Celular</label><input name="celular" value="<%= user.celular||user.telefone||'' %>"></div>
      <div><label>CRECI</label><input name="creci" value="<%= user.creci||'' %>"></div>
      <div><label>CPF</label><input name="cpf" value="<%= user.cpf||'' %>"></div>
      <div><label>Tipo de conta</label><input value="<%= user.tipo||'corretor' %>" readonly style="background:#f7f7f7;color:#aaa"></div>
      <div><label>Código do usuário</label><input value="<%= user.codigoUsuario || user.codigo || '-' %>" readonly style="background:#f7f7f7;color:#111;font-weight:700"></div>
    </div>
    <button class="btn btn-primary" type="submit" style="margin-top:16px">Salvar perfil</button>
  </form>
</div>

<div class="card">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
    <div>
      <h3 style="margin-bottom:4px">📍 Minha localização</h3>
      <p style="color:#717171;font-size:13px">Usada para calcular distâncias até os imóveis e leads.</p>
    </div>
    <button class="btn btn-primary" onclick="pegarLocalizacao()" id="btn-loc">
      📡 Atualizar localização
    </button>
  </div>

  <div id="loc-status" style="margin-top:14px;padding:12px;border-radius:10px;background:#f7f7f7;font-size:13px;display:flex;align-items:center;gap:10px">
    <% if(user.lat && user.lng) { %>
      <span style="color:#1A1A1A;font-size:16px">✅</span>
      <span>Localização salva: <strong><%= user.endereco || (user.lat + ', ' + user.lng) %></strong></span>
    <% } else { %>
      <span style="color:#6B6B6B;font-size:16px">⚠️</span>
      <span>Localização não definida. Clique em <strong>Atualizar localização</strong> para habilitar o mapa de distâncias.</span>
    <% } %>
  </div>

  <div id="mapa-perfil" style="margin-top:14px;border-radius:12px;overflow:hidden;display:<%= (user.lat && user.lng) ? 'block' : 'none' %>;height:200px"></div>

  <form id="form-loc" method="POST" action="/app/perfil/localizacao" style="display:none">
    <input type="hidden" name="lat" id="inp-lat">
    <input type="hidden" name="lng" id="inp-lng">
    <input type="hidden" name="endereco" id="inp-endereco">
  </form>
</div>

<script>
function pegarLocalizacao() {
  const btn = document.getElementById('btn-loc');
  const status = document.getElementById('loc-status');
  btn.textContent = '⏳ Obtendo localização...';
  btn.disabled = true;

  if (!navigator.geolocation) {
    status.innerHTML = '<span style="color:#FF385C">❌ Geolocalização não suportada neste navegador.</span>';
    btn.disabled = false;
    return;
  }

  navigator.geolocation.getCurrentPosition(async (pos) => {
    const lat = pos.coords.latitude;
    const lng = pos.coords.longitude;

    // busca endereço via geocoding reverso
    let endereco = lat + ', ' + lng;
    try {
      const r = await fetch('https://nominatim.openstreetmap.org/reverse?format=json&lat='+lat+'&lon='+lng);
      const d = await r.json();
      endereco = d.display_name || endereco;
    } catch(e) {}

    // salva via POST
    document.getElementById('inp-lat').value = lat;
    document.getElementById('inp-lng').value = lng;
    document.getElementById('inp-endereco').value = endereco;
    document.getElementById('form-loc').submit();

  }, (err) => {
    status.innerHTML = '<span style="color:#FF385C">❌ Não foi possível obter localização. Verifique as permissões do navegador.</span>';
    btn.textContent = '📡 Atualizar localização';
    btn.disabled = false;
  }, { enableHighAccuracy: true, timeout: 10000 });
}

// mostra mapa se já tem localização
<% if(user.lat && user.lng) { %>
const mapDiv = document.getElementById('mapa-perfil');
mapDiv.style.display = 'block';
const iframe = document.createElement('iframe');
iframe.width = '100%';
iframe.height = '200';
iframe.frameBorder = '0';
iframe.style.border = '0';
iframe.src = 'https://www.openstreetmap.org/export/embed.html?bbox=<%= user.lng-0.01 %>,<%= user.lat-0.01 %>,<%= user.lng+0.01 %>,<%= user.lat+0.01 %>&layer=mapnik&marker=<%= user.lat %>,<%= user.lng %>';
mapDiv.appendChild(iframe);
<% } %>
</script>

<%- include('partials/app-end') %>

<div class="card" style="margin-top:16px">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px">
    <div>
      <h3 style="margin-bottom:4px">📱 WhatsApp</h3>
      <p style="color:#717171;font-size:13px">Conecte seu WhatsApp para receber e responder leads automaticamente.</p>
    </div>
    <div id="wa-status-badge" style="padding:6px 14px;border-radius:20px;font-size:12px;font-weight:700;background:#f3f4f6;color:#374151">
      ⏳ Verificando...
    </div>
  </div>

  <div id="wa-qr-container" style="display:none;text-align:center;margin:16px 0">
    <p style="font-size:13px;color:#555;margin-bottom:12px">Abra o WhatsApp → Dispositivos conectados → Conectar dispositivo → Escaneie:</p>
    <img id="wa-qr-img" style="width:220px;height:220px;border-radius:12px;border:2px solid #e5e7eb">
    <p style="font-size:12px;color:#aaa;margin-top:8px">QR Code expira em 60 segundos</p>
  </div>

  <div id="wa-conectado" style="display:none;background:#f0fdf4;border-radius:10px;padding:12px 16px;margin:12px 0">
    <div style="font-size:14px;font-weight:700;color:#166534">✅ WhatsApp conectado</div>
    <div id="wa-numero" style="font-size:13px;color:#15803d;margin-top:4px"></div>
  </div>

  <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:8px">
    <button id="btn-conectar-wa" onclick="conectarWhatsApp()" style="background:#25D366;color:#fff;border:none;padding:10px 18px;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer">
      📲 Conectar WhatsApp
    </button>
    <button id="btn-desconectar-wa" onclick="desconectarWhatsApp()" style="display:none;background:#f3f4f6;color:#374151;border:1px solid #e5e7eb;padding:10px 18px;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer">
      Desconectar
    </button>
  </div>
</div>

<script>
let waPolling = null;

async function verificarStatusWA() {
  try {
    const r = await fetch('/app/whatsapp/status');
    const d = await r.json();
    const badge = document.getElementById('wa-status-badge');
    const conectado = document.getElementById('wa-conectado');
    const qrContainer = document.getElementById('wa-qr-container');
    const btnConectar = document.getElementById('btn-conectar-wa');
    const btnDesconectar = document.getElementById('btn-desconectar-wa');

    if (d.status === 'open') {
      badge.style.background = '#d1fae5'; badge.style.color = '#065f46';
      badge.textContent = '✅ Conectado';
      conectado.style.display = 'block';
      qrContainer.style.display = 'none';
      btnConectar.style.display = 'none';
      btnDesconectar.style.display = 'inline-block';
      if (d.numero) document.getElementById('wa-numero').textContent = 'Número: ' + d.numero;
      if (waPolling) { clearInterval(waPolling); waPolling = null; }
    } else {
      badge.style.background = '#fee2e2'; badge.style.color = '#991b1b';
      badge.textContent = '❌ Desconectado';
      conectado.style.display = 'none';
      btnConectar.style.display = 'inline-block';
      btnDesconectar.style.display = 'none';
    }
  } catch(e) {}
}

async function conectarWhatsApp() {
  const btn = document.getElementById('btn-conectar-wa');
  btn.textContent = '⏳ Gerando QR...';
  btn.disabled = true;
  try {
    const r = await fetch('/app/whatsapp/qrcode');
    const d = await r.json();
    if (d.base64) {
      document.getElementById('wa-qr-img').src = d.base64;
      document.getElementById('wa-qr-container').style.display = 'block';
      btn.textContent = '🔄 Novo QR Code';
      btn.disabled = false;
      // Polling para verificar conexão
      waPolling = setInterval(verificarStatusWA, 3000);
    } else {
      btn.textContent = '📲 Conectar WhatsApp';
      btn.disabled = false;
      alert('Erro ao gerar QR Code: ' + (d.erro || 'tente novamente'));
    }
  } catch(e) {
    btn.textContent = '📲 Conectar WhatsApp';
    btn.disabled = false;
  }
}

async function desconectarWhatsApp() {
  if (!confirm('Desconectar WhatsApp?')) return;
  await fetch('/app/whatsapp/desconectar', { method: 'POST' });
  verificarStatusWA();
}

verificarStatusWA();
</script>
