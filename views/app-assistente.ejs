<%- include("partials/app-shell",{active:"assistente",user:user}) %>

<style>
main{padding:0!important;height:calc(100vh - 60px);display:flex;flex-direction:column;background:#f9fafb}

.chat-wrapper{display:flex;flex-direction:column;height:100%;max-width:800px;margin:0 auto;width:100%;padding:0 16px;box-sizing:border-box}

.chat-header{display:flex;align-items:center;justify-content:space-between;padding:14px 0 12px;border-bottom:0.5px solid rgba(0,0,0,.08)}
.chat-header-left{display:flex;align-items:center;gap:10px}
.chat-avatar{width:32px;height:32px;background:#6366f1;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.chat-title{font-weight:500;font-size:14px;color:#111827}
.chat-status{font-size:11px;color:#22c55e;display:flex;align-items:center;gap:4px}
.chat-status::before{content:'';width:6px;height:6px;background:#22c55e;border-radius:50%;display:inline-block}
.chat-header-actions{display:flex;gap:6px}
.header-chip{background:#fff;border:0.5px solid rgba(0,0,0,.12);border-radius:999px;padding:5px 12px;font-size:12px;font-weight:500;cursor:pointer;color:#374151;transition:all .12s;white-space:nowrap}
.header-chip:hover{background:#111827;color:#fff;border-color:#111827}

#chat-messages{flex:1;overflow-y:auto;padding:20px 0;display:flex;flex-direction:column;gap:16px;scroll-behavior:smooth}
#chat-messages::-webkit-scrollbar{width:3px}
#chat-messages::-webkit-scrollbar-thumb{background:#e5e7eb;border-radius:4px}

.msg{display:flex;align-items:flex-end;gap:8px;animation:fadeUp .2s ease}
.msg.user{flex-direction:row-reverse}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

.msg-avatar{width:26px;height:26px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;margin-bottom:2px}
.msg-avatar.bot{background:#6366f1}
.msg-avatar.user{background:#111827}

.bubble{max-width:74%;padding:11px 15px;border-radius:16px;font-size:14px;line-height:1.7;word-break:break-word}
.bot-bubble{background:#fff;color:#111827;border-bottom-left-radius:4px;border:0.5px solid rgba(0,0,0,.08)}
.user-bubble{background:#111827;color:#fff;border-bottom-right-radius:4px}

.typing-dots{display:flex;gap:4px;padding:4px 2px}
.typing-dots span{width:6px;height:6px;background:#d1d5db;border-radius:50%;animation:bounce .9s infinite}
.typing-dots span:nth-child(2){animation-delay:.15s}
.typing-dots span:nth-child(3){animation-delay:.3s}
@keyframes bounce{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-5px)}}

.feedback-row{display:flex;align-items:center;gap:6px;margin-top:-6px;padding-left:34px}
.feedback-row span{font-size:11px;color:#d1d5db}
.fb-btn{background:none;border:0.5px solid rgba(0,0,0,.1);border-radius:8px;padding:2px 10px;font-size:11px;cursor:pointer;color:#9ca3af;transition:all .12s}
.fb-btn:hover{background:#f9fafb}

.quick-chips{display:flex;gap:6px;flex-wrap:wrap;padding:6px 0 10px}
.quick-chip{background:#fff;border:0.5px solid rgba(0,0,0,.1);border-radius:999px;padding:6px 14px;font-size:12px;font-weight:500;cursor:pointer;color:#374151;transition:all .12s}
.quick-chip:hover{background:#111827;color:#fff;border-color:#111827}

.input-area{padding:10px 0 14px;border-top:0.5px solid rgba(0,0,0,.08)}
.input-row{display:flex;gap:8px;align-items:flex-end;background:#fff;border:0.5px solid rgba(0,0,0,.12);border-radius:12px;padding:8px 10px;transition:border-color .15s}
.input-row:focus-within{border-color:rgba(99,102,241,.4);box-shadow:0 0 0 3px rgba(99,102,241,.06)}
#chat-input{flex:1;border:none;outline:none;font-size:14px;background:transparent;color:#111827;resize:none;max-height:120px;line-height:1.5;font-family:inherit}
#chat-input::placeholder{color:#d1d5db}
.attach-btn{background:none;border:none;cursor:pointer;font-size:17px;color:#d1d5db;padding:2px;flex-shrink:0;transition:color .12s}
.attach-btn:hover{color:#6366f1}
.send-btn{background:#111827;border:none;border-radius:8px;width:32px;height:32px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .12s}
.send-btn:hover{background:#1f2937}
.send-btn svg{width:14px;height:14px;fill:#fff}
.send-btn:disabled{background:#e5e7eb;cursor:not-allowed}

.welcome-msg{text-align:center;padding:28px 16px 6px}
.welcome-msg h2{font-size:20px;font-weight:500;color:#111827;margin:0 0 6px}
.welcome-msg p{font-size:13px;color:#9ca3af;margin:0}

@media(max-width:600px){
  .bubble{max-width:88%;font-size:13px}
  .chat-header-actions{display:none}
}
</style>

<div style="height:calc(100vh - 60px);display:flex;flex-direction:column;background:#f9fafb">
<div class="chat-wrapper">

  <!-- Header -->
  <div class="chat-header">
    <div class="chat-header-left">
      <div class="chat-avatar">✦</div>
      <div>
        <div class="chat-title">Assistente MatchImóveis</div>
        <div class="chat-status">Online</div>
      </div>
    </div>
    <div class="chat-header-actions">
      <button class="header-chip" onclick="enviarMsg('o que devo fazer hoje')">Plano do dia</button>
      <button class="header-chip" onclick="enviarMsg('resumo geral')">Resumo</button>
      <button class="header-chip" onclick="enviarMsg('leads com match')">Match</button>
    </div>
  </div>

  <!-- Mensagens -->
  <div id="chat-messages">
    <div class="welcome-msg">
      <h2>Olá, <%= user.nome||user.name||'corretor' %> 👋</h2>
      <p>Pergunte qualquer coisa sobre seus imóveis, leads e visitas.</p>
    </div>
    <div class="quick-chips" style="justify-content:center">
      <button class="quick-chip" onclick="enviarMsg('o que devo fazer hoje')">O que fazer hoje</button>
      <button class="quick-chip" onclick="enviarMsg('leads com match')">Leads com match</button>
      <button class="quick-chip" onclick="enviarMsg('visitas hoje')">Visitas hoje</button>
      <button class="quick-chip" onclick="enviarMsg('demanda por bairro')">Demanda</button>
      <button class="quick-chip" onclick="enviarMsg('meus imoveis')">Imóveis</button>
    </div>
  </div>

  <!-- Input -->
  <div class="input-area">
    <div class="input-row">
      <input type="file" id="file-input" accept=".xml,.xlsx,.xls,.csv" style="display:none" onchange="uploadArquivo(this)">
      <button class="attach-btn" onclick="document.getElementById('file-input').click()" title="Anexar arquivo">📎</button>
      <textarea id="chat-input" placeholder="Pergunte sobre imóveis, leads, visitas..." rows="1"
        onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();enviarMsg();}"
        oninput="autoResize(this)"></textarea>
      <button class="send-btn" id="send-btn" onclick="enviarMsg()">
        <svg viewBox="0 0 24 24"><path d="M2 21l21-9L2 3v7l15 2-15 2z"/></svg>
      </button>
    </div>
  </div>

</div>
</div>

<script>
const stats = <%- JSON.stringify(stats) %>;

function autoResize(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,120)+'px';}
function scrollBottom(){const c=document.getElementById('chat-messages');c.scrollTop=c.scrollHeight;}

function renderOperacional(data){
  let html='';
  if(data.painel){
    html+=`<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:8px;margin-bottom:14px">
      <div style="background:#f9fafb;padding:12px;border-radius:10px;border:0.5px solid rgba(0,0,0,.08)"><div style="font-size:11px;color:#9ca3af">Visitas</div><div style="font-size:20px;font-weight:500;color:#111827">${data.painel.total||0}</div></div>
      <div style="background:#fff7ed;padding:12px;border-radius:10px;border:0.5px solid #fed7aa"><div style="font-size:11px;color:#9a3412">Prop.</div><div style="font-size:20px;font-weight:500;color:#111827">${data.painel.aguardandoProprietario||0}</div></div>
      <div style="background:#f0fdf4;padding:12px;border-radius:10px;border:0.5px solid #86efac"><div style="font-size:11px;color:#15803d">Confirm.</div><div style="font-size:20px;font-weight:500;color:#111827">${data.painel.confirmadas||0}</div></div>
      <div style="background:#fef2f2;padding:12px;border-radius:10px;border:0.5px solid #fca5a5"><div style="font-size:11px;color:#b91c1c">Canceladas</div><div style="font-size:20px;font-weight:500;color:#111827">${data.painel.canceladas||0}</div></div>
    </div>`;
  }
  if(data.itens&&data.itens.length){
    html+='<div style="display:flex;flex-direction:column;gap:10px">';
    data.itens.forEach((item,idx)=>{
      html+=`<div style="background:#fff;border:0.5px solid rgba(0,0,0,.08);border-radius:12px;padding:14px">
        <div style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start">
          <div>
            <div style="font-weight:500;font-size:14px;color:#111827">${item.nome||item.cliente||'-'}</div>
            <div style="font-size:12px;color:#9ca3af;margin-top:2px">${item.imovelTitulo||item.imovel||''}</div>
            <div style="margin-top:8px"><span style="background:#f9fafb;border:0.5px solid rgba(0,0,0,.08);padding:3px 10px;border-radius:999px;font-size:12px;color:#374151">${item.workflowLabel||item.label||''}</span></div>
            <div style="margin-top:8px;font-size:12px;color:#6b7280">${item.workflowProximaAcao||item.proximaAcao||''}</div>
          </div>
          <div style="display:flex;flex-direction:column;gap:6px">
            ${item.workflowWhatsappDestino||(item.whatsapp&&item.whatsapp.url)?`<a href="${item.workflowWhatsappDestino?'https://wa.me/'+String(item.workflowWhatsappDestino).replace(/\\D/g,'')+'?text='+encodeURIComponent(item.workflowWhatsappTexto||''):item.whatsapp.url}" target="_blank" style="background:#22c55e;color:#fff;padding:7px 12px;border-radius:8px;text-decoration:none;font-size:12px;font-weight:500;text-align:center">WhatsApp</a>`:''}
            <button onclick="enviarMsg('confirma a ${idx+1}')" style="background:#0f766e;color:#fff;border:none;padding:7px 12px;border-radius:8px;font-size:12px;font-weight:500;cursor:pointer">Confirmar</button>
            <button onclick="enviarMsg('remarca a ${idx+1}')" style="background:#d97706;color:#fff;border:none;padding:7px 12px;border-radius:8px;font-size:12px;font-weight:500;cursor:pointer">Remarcar</button>
            <button onclick="enviarMsg('cancela a ${idx+1}')" style="background:#dc2626;color:#fff;border:none;padding:7px 12px;border-radius:8px;font-size:12px;font-weight:500;cursor:pointer">Cancelar</button>
          </div>
        </div>
      </div>`;
    });
    html+='</div>';
  }
  return html;
}

function addMsg(html,tipo){
  const c=document.getElementById('chat-messages');
  const wrap=document.createElement('div');
  wrap.className='msg '+tipo;
  const avatar=document.createElement('div');
  avatar.className='msg-avatar '+tipo;
  avatar.textContent=tipo==='bot'?'✦':'›';
  const bubble=document.createElement('div');
  bubble.className='bubble '+tipo+'-bubble';
  bubble.innerHTML=html;
  wrap.appendChild(avatar);
  wrap.appendChild(bubble);
  c.appendChild(wrap);
  scrollBottom();
  return wrap;
}

function streamMsg(html){
  const c=document.getElementById('chat-messages');
  const wrap=document.createElement('div');
  wrap.className='msg bot';
  const avatar=document.createElement('div');
  avatar.className='msg-avatar bot';
  avatar.textContent='✦';
  const bubble=document.createElement('div');
  bubble.className='bubble bot-bubble';
  bubble.innerHTML='';
  wrap.appendChild(avatar);
  wrap.appendChild(bubble);
  c.appendChild(wrap);
  scrollBottom();

  const tokens=[];
  let i=0;
  while(i<html.length){
    if(html[i]==='<'){
      const end=html.indexOf('>',i);
      if(end===-1){tokens.push(html[i]);i++;continue;}
      tokens.push(html.slice(i,end+1));
      i=end+1;
    } else {tokens.push(html[i]);i++;}
  }

  let idx=0,current='';
  function next(){
    if(idx>=tokens.length){bubble.innerHTML=html;scrollBottom();return;}
    const token=tokens[idx++];
    current+=token;
    bubble.innerHTML=current;
    scrollBottom();
    const isTag=token.startsWith('<');
    const delay=isTag?0:(token===' '?20:Math.random()*18+8);
    setTimeout(next,delay);
  }
  next();
  return wrap;
}

function showTyping(){
  const c=document.getElementById('chat-messages');
  const wrap=document.createElement('div');
  wrap.className='msg bot';
  wrap.id='typing-indicator';
  const avatar=document.createElement('div');
  avatar.className='msg-avatar bot';
  avatar.textContent='✦';
  const bubble=document.createElement('div');
  bubble.className='bubble bot-bubble';
  bubble.innerHTML='<div class="typing-dots"><span></span><span></span><span></span></div>';
  wrap.appendChild(avatar);
  wrap.appendChild(bubble);
  c.appendChild(wrap);
  scrollBottom();
}

function removeTyping(){const t=document.getElementById('typing-indicator');if(t)t.remove();}

function addFeedback(pergunta,resposta){
  const c=document.getElementById('chat-messages');
  const row=document.createElement('div');
  row.className='feedback-row';
  row.dataset.pergunta=pergunta;
  row.dataset.resposta=resposta;
  row.innerHTML='<span>Isso ajudou?</span><button class="fb-btn" onclick="enviarFeedback(true,this)">👍</button><button class="fb-btn" onclick="enviarFeedback(false,this)">👎</button>';
  c.appendChild(row);
  scrollBottom();
}

async function enviarFeedback(util,btn){
  const row=btn.closest('[data-pergunta]');
  const pergunta=row?.dataset.pergunta||'';
  const resposta=row?.dataset.resposta||'';
  try{
    await fetch('/app/assistente/feedback',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({util,pergunta,resposta})});
    row.innerHTML='<span style="color:'+(util?'#22c55e':'#ef4444')+';font-size:12px">'+(util?'Ótimo!':'Vou melhorar!')+'</span>';
  }catch(e){}
}

async function enviarMsg(texto){
  const input=document.getElementById('chat-input');
  const msg=texto||input.value.trim();
  window.msgAtual=msg;
  if(!msg)return;

  const chips=document.querySelector('.quick-chips');
  const welcome=document.querySelector('.welcome-msg');
  if(chips)chips.remove();
  if(welcome)welcome.remove();

  input.value='';
  input.style.height='auto';
  const sendBtn=document.getElementById('send-btn');
  sendBtn.disabled=true;

  addMsg(msg,'user');
  showTyping();

  try{
    await new Promise(r=>setTimeout(r,400+Math.random()*600));
    const res=await fetch('/app/assistente/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mensagem:msg})});
    const data=await res.json();
    removeTyping();

    console.log('DEBUG resposta raw:',JSON.stringify(data.resposta));

    if(data.resposta&&data.resposta.trim().includes('ACAO_IMPORTAR_XML:')){
      try{
        let jsonStr=data.resposta.trim().split('ACAO_IMPORTAR_XML:')[1].trim();
        const fimJson=jsonStr.indexOf('}');
        if(fimJson!==-1)jsonStr=jsonStr.substring(0,fimJson+1);
        const dados=JSON.parse(jsonStr);
        streamMsg('Importando XML para sua conta...');
        const r=await fetch('/app/importar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({xmlUrl:dados.url})});
        const out=await r.json();
        if(out.ok){streamMsg('XML importado com sucesso. Os imóveis foram adicionados à sua carteira.');}
        else{streamMsg('Erro ao importar XML: '+(out.erro||'tente novamente.'));}
      }catch(e){streamMsg('Erro ao processar importação XML.');}
      return;
    }

    if(data.resposta&&data.resposta.trim().includes('ACAO_GERAR_XML:')){
      try{
        let jsonStr=data.resposta.trim().split('ACAO_GERAR_XML:')[1].trim();
        const fimJson=jsonStr.indexOf('}');
        if(fimJson!==-1)jsonStr=jsonStr.substring(0,fimJson+1);
        const dados=JSON.parse(jsonStr);
        if(dados.todos||/todos/i.test(msgAtual||'')){
          streamMsg('Gerando XML para <strong>'+dados.portal.toUpperCase()+'</strong>...');
          await gerarXMLPeloChat(dados.portal);
        } else {
          window._portalPendente=dados.portal;
          streamMsg('Gerar XML para <strong>'+dados.portal.toUpperCase()+'</strong>. Quer incluir:<br><br>'+
            '<span class="quick-chip" onclick="enviarMsg(\'gerar xml todos '+dados.portal+'\')" style="cursor:pointer">Todos os imóveis</span>'+
            '  <a href="/app/imoveis" style="background:#111827;color:#fff;padding:7px 14px;border-radius:8px;text-decoration:none;font-size:12px;font-weight:500;margin-left:6px">Selecionar</a>');
        }
      }catch(e){streamMsg('Erro: '+e.message);}
      return;
    }

    if(data.resposta&&data.resposta.trim().includes('ACAO_CADASTRAR_LEAD:')){
      try{
        let jsonStr=data.resposta.trim().split('ACAO_CADASTRAR_LEAD:')[1].trim();
        const fimJson=jsonStr.indexOf('}');
        if(fimJson!==-1)jsonStr=jsonStr.substring(0,fimJson+1);
        const dados=JSON.parse(jsonStr);
        streamMsg('Cadastrando lead <strong>'+dados.nome+'</strong>...');
        await cadastrarLeadPeloChat(dados);
      }catch(e){streamMsg('Erro ao processar cadastro: '+e.message);}
      return;
    }

    let respostaFinal=data.resposta||'';
    const operacional=renderOperacional(data);
    if(operacional)respostaFinal+=operacional;
    streamMsg(respostaFinal);
    setTimeout(()=>addFeedback(msg,data.resposta),200);

    if(data.chips&&data.chips.length){
      const c=document.getElementById('chat-messages');
      const row=document.createElement('div');
      row.className='quick-chips';
      row.style.paddingLeft='34px';
      data.chips.forEach(ch=>{
        const b=document.createElement('button');
        b.className='quick-chip';
        b.textContent=ch.label;
        b.onclick=()=>enviarMsg(ch.msg);
        row.appendChild(b);
      });
      c.appendChild(row);
      scrollBottom();
    }
  }catch(e){
    removeTyping();
    addMsg('Erro ao conectar. Tente novamente.','bot');
  }

  sendBtn.disabled=false;
  input.focus();
}

async function cadastrarLeadPeloChat(dados){
  showTyping();
  try{
    const res=await fetch('/app/leads/manual',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(dados)});
    const data=await res.json();
    removeTyping();
    if(data.ok){
      streamMsg('Lead cadastrado com sucesso!<br><br>'+
        '<strong>'+data.lead.nome+'</strong><br>'+
        data.lead.contato+'<br>'+
        (data.lead.tipo?data.lead.tipo+'<br>':'')+
        (data.lead.bairro?data.lead.bairro+'<br>':'')+
        '<br><a href="/app/lead/'+data.lead.id+'" style="background:#111827;color:#fff;padding:8px 16px;border-radius:8px;text-decoration:none;font-size:13px;font-weight:500">Ver lead →</a>');
    }else{streamMsg('Erro ao cadastrar: '+(data.erro||'Tente novamente.'));}
  }catch(e){removeTyping();streamMsg('Erro ao conectar. Tente novamente.');}
}

async function gerarXMLPeloChat(portal){
  showTyping();
  try{
    const idsRes=await fetch('/app/imoveis-ids').then(r=>r.json());
    const res=await fetch('/app/gerar-xml',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({portal,ids:idsRes.ids||[]})});
    const data=await res.json();
    removeTyping();
    if(data.url){
      streamMsg('XML gerado!<br><br>Portal: <strong>'+portal.toUpperCase()+'</strong><br>'+data.total+' imóvel(is) incluído(s)<br><br>'+
        '<a href="'+data.url+'" target="_blank" style="background:#111827;color:#fff;padding:8px 16px;border-radius:8px;text-decoration:none;font-size:13px;font-weight:500">Ver XML →</a>'+
        '  <a href="/app/portais" style="background:#f9fafb;color:#374151;padding:8px 16px;border-radius:8px;text-decoration:none;font-size:13px;font-weight:500;border:0.5px solid rgba(0,0,0,.1);margin-left:6px">Portais →</a>');
    }else{streamMsg('Erro ao gerar XML. Tente novamente.');}
  }catch(e){removeTyping();streamMsg('Erro: '+e.message);}
}

async function importarXMLPeloChat(url){
  addMsg('Importando XML: '+url,'user');
  showTyping();
  try{
    const form=new FormData();
    form.append('xmlUrl',url);
    const res=await fetch('/app/importar',{method:'POST',body:form});
    const data=await res.json();
    removeTyping();
    if(data.ok||data.importados){streamMsg((data.importados||0)+' imóvel(is) importado(s) com sucesso! Acesse sua carteira para ver os novos imóveis.');}
    else{streamMsg('Erro ao importar: '+(data.erro||data.error||'Verifique a URL e tente novamente.'));}
  }catch(e){removeTyping();streamMsg('Erro ao conectar. Tente novamente.');}
}

async function uploadArquivo(input){
  const file=input.files[0];
  if(!file)return;
  addMsg('📎 '+file.name,'user');
  showTyping();
  const form=new FormData();
  form.append('arquivo',file);
  try{
    const res=await fetch('/app/assistente/upload',{method:'POST',body:form});
    const data=await res.json();
    removeTyping();
    addMsg(data.resposta||'Arquivo recebido!','bot');
  }catch(e){removeTyping();addMsg('Erro ao enviar arquivo.','bot');}
  input.value='';
}

window.addEventListener('load',()=>{document.getElementById('chat-input').focus();});
</script>

<%- include("partials/app-end") %>
