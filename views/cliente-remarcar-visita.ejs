<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<title>Remarcar visita</title>

<style>

body{
  margin:0;
  padding:0;
  background:#f5f5f5;
  font-family:Arial,sans-serif;
}

.wrap{
  max-width:600px;
  margin:40px auto;
  padding:20px;
}

.card{
  background:white;
  border-radius:20px;
  padding:24px;
  box-shadow:0 4px 20px rgba(0,0,0,.06);
}

h1{
  margin:0 0 20px;
  font-size:28px;
  color:#111827;
}

input,textarea{
  width:100%;
  box-sizing:border-box;
  padding:14px;
  border:1px solid #ddd;
  border-radius:12px;
  margin-bottom:12px;
  font-size:14px;
}

button{
  width:100%;
  border:none;
  border-radius:12px;
  padding:14px;
  background:#f59e0b;
  color:white;
  font-size:14px;
  font-weight:700;
  cursor:pointer;
}

.info{
  margin-bottom:16px;
  color:#444;
  line-height:1.6;
}

</style>
</head>

<body>

<div class="wrap">

<div class="card">

<h1>Remarcar visita</h1>

<div class="info">
<strong>Imóvel:</strong>
<%= visita.imovelTitulo || visita.imovelBairro || 'Imóvel' %>
</div>

<form method="POST" action="/cliente/visita/<%= visita.id %>/remarcar">

<input
type="date"
name="dataVisita"
required
/>

<input
type="time"
name="horaVisita"
required
/>

<textarea
name="observacao"
placeholder="Observação para o corretor..."
rows="5"
></textarea>

<button type="submit">
Solicitar nova data
</button>

</form>

</div>

</div>

</body>
</html>
