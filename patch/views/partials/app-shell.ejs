<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title><%= (typeof title !== 'undefined' && title) ? title + ' · MatchImóveis' : 'MatchImóveis' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&family=Source+Serif+4:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{
      --brand:#FF385C;--brand-dark:#E31C5F;--brand-soft:#FFF1F3;
      --bg:#F7F7F7;--surface:#FFFFFF;--border:#EBEBEB;--divider:#f5f5f5;
      --ink:#111111;--text:#222222;--muted:#717171;--faint:#aaaaaa;
      --tile:#F2F2F2;
      --font-display:'Syne',sans-serif;
      --font-body:'DM Sans',sans-serif;
      --font-serif:'Source Serif 4',Georgia,serif;
      --sidebar:256px;--radius:16px;
    }
    body{font-family:var(--font-body);background:var(--bg);color:var(--text);font-size:13px;line-height:1.6}
    .app{display:flex;min-height:100vh}
    .sidebar{width:var(--sidebar);background:var(--surface);border-right:1px solid var(--border);position:fixed;top:0;left:0;bottom:0;display:flex;flex-direction:column;z-index:100;overflow-y:auto}
    .brand{display:flex;align-items:center;gap:10px;padding:24px 20px 20px;border-bottom:1px solid var(--border)}
    .brand-mark{width:36px;height:36px;background:var(--brand);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;color:#fff}
    .brand-name{font-family:var(--font-display);font-size:17px;font-weight:700;color:var(--ink);letter-spacing:-.3px}
    .brand-name span{color:var(--brand)}
    .user-pill{margin:16px 14px;padding:10px 12px;background:var(--bg);border-radius:14px;display:flex;align-items:center;gap:10px}
    .user-av{width:38px;height:38px;background:var(--brand);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:15px;flex-shrink:0}
    .user-nm{font-size:12px;font-weight:600;color:var(--ink);max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .user-tp{font-size:11px;color:var(--muted);text-transform:capitalize}
    .user-meta{font-size:10px;color:var(--faint);font-weight:600;margin-top:2px}
    .user-coins{font-size:11px;color:var(--text);font-weight:600;margin-top:2px}
    nav.menu{padding:8px 12px;flex:1}
    .menu-sec{font-size:10px;font-weight:700;color:#bbb;text-transform:uppercase;letter-spacing:.8px;padding:14px 8px 6px}
    .menu a{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;color:var(--muted);text-decoration:none;font-size:12px;font-weight:500;transition:all .15s;margin-bottom:1px}
    .menu a:hover{background:var(--bg);color:var(--ink)}
    .menu a.active{background:var(--brand-soft);color:var(--brand);font-weight:600}
    .menu-ic{width:22px;height:22px;border-radius:6px;background:var(--tile);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
    .menu a.active .menu-ic{background:#fff}
    .menu-div{height:1px;background:var(--border);margin:10px 0}
    .sidebar-footer{padding:16px 14px;border-top:1px solid var(--border)}
    .sidebar-footer a{display:flex;align-items:center;gap:8px;color:var(--muted);text-decoration:none;font-size:12px;padding:8px 12px;border-radius:10px;transition:all .15s}
    .sidebar-footer a:hover{color:var(--brand);background:var(--brand-soft)}
    .content{margin-left:var(--sidebar);width:calc(100% - var(--sidebar));min-height:100vh;padding:32px 36px}
    .page-head{margin-bottom:28px}
    .page-head h1{font-family:var(--font-display);font-size:26px;font-weight:700;color:var(--ink);letter-spacing:-.5px;margin-bottom:4px}
    .page-head p{color:var(--muted);font-size:14px}
    .card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:10px 18px;border-radius:10px;font-size:12px;font-weight:600;cursor:pointer;text-decoration:none;border:none;transition:all .15s;font-family:var(--font-body)}
    .btn-primary{background:var(--brand);color:#fff}
    .btn-primary:hover{background:var(--brand-dark)}
    .btn-outline{background:transparent;color:var(--ink);border:1.5px solid var(--border)}
    .btn-outline:hover{background:var(--bg)}
    input,select,textarea{width:100%;border:1.5px solid var(--border);border-radius:10px;padding:11px 14px;font-size:13px;font-family:var(--font-body);color:var(--text);background:#fff;outline:none;transition:border .15s}
    input:focus,select:focus,textarea:focus{border-color:var(--ink)}
    label{display:block;font-size:12px;font-weight:600;color:var(--ink);margin-bottom:6px}
    .badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600;background:var(--tile);color:var(--ink);white-space:nowrap}
    .badge-red{background:var(--brand-soft);color:var(--brand)}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
    .live{display:inline-block;width:7px;height:7px;background:var(--ink);border-radius:50%;animation:pulse 2s infinite;margin-right:5px}
    @keyframes sinoPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
    .sino-alerta{animation:sinoPulse 1s infinite}
    @media(max-width:900px){.sidebar{transform:translateX(-100%)}.content{margin-left:0;width:100%;padding:20px}}
  </style>
</head>
<body>
<div class="app">
<aside class="sidebar">
  <div class="brand">
    <div class="brand-mark">🏠</div>
    <span class="brand-name">Match<span>Imóveis</span></span>
  </div>
  <div class="user-pill">
    <div class="user-av"><%= ((typeof user!=='undefined'&&user&&user.nome)?user.nome:'A').charAt(0).toUpperCase() %></div>
    <div>
      <div class="user-nm"><%= (typeof user!=='undefined'&&user&&user.nome)?user.nome:'Usuário' %></div>
      <div class="user-tp"><%= (typeof user!=='undefined'&&user&&user.tipo)?user.tipo:'corretor' %></div>
      <div class="user-meta">ID: <%= (typeof user!=='undefined'&&user&&(user.codigoUsuario||user.codigo))?(user.codigoUsuario||user.codigo):'-' %></div>
      <div class="user-coins">🪙 <%= (typeof user!=='undefined'&&user&&user.matchCoins)||0 %> Match Coins</div>
    </div>
  </div>
  <nav class="menu">
    <div class="menu-sec">Principal</div>
    <a class="<%= active==='home'?'active':'' %>" href="/app-home"><span class="menu-ic">📊</span>Dashboard</a>
    <a class="<%= active==='imoveis'?'active':'' %>" href="/app/imoveis"><span class="menu-ic">🏠</span>Meus Imóveis</a>
    <a class="<%= active==='leads'?'active':'' %>" href="/app/leads"><span class="menu-ic">👥</span>Leads</a>
    <a class="<%= active==='visitas'?'active':'' %>" href="/app/visitas"><span class="menu-ic">📅</span>Visitas</a>
    <a class="<%= active==='notificacoes'?'active':'' %>" href="/app/notificacoes"><span class="menu-ic">🔔</span>Notificações</a>
    <div class="menu-div"></div>
    <div class="menu-sec">Configurar</div>
    <a class="<%= active==='cadastro'?'active':'' %>" href="/app/cadastro"><span class="menu-ic">➕</span>Cadastrar Imóvel</a>
    <a class="<%= active==='portais'?'active':'' %>" href="/app/portais"><span class="menu-ic">🔗</span>Portais / XML</a>
    <a class="<%= active==='perfil'?'active':'' %>" href="/app/perfil"><span class="menu-ic">👤</span>Perfil</a>
    <a class="<%= active==='coins'?'active':'' %>" href="/app/coins"><span class="menu-ic">🪙</span>Match Coins</a>
    <a class="<%= active==='assistente'?'active':'' %>" href="/app/assistente"><span class="menu-ic">🤖</span>Assistente</a>
  </nav>
  <div class="sidebar-footer"><a href="/login"><span class="menu-ic">🚪</span>Sair</a></div>
</aside>
<main class="content">
  <div id="sino-notificacao-topo-content" style="display:flex;justify-content:flex-end;gap:10px;margin-bottom:12px">
    <a href="/app/notificacoes" title="Central de notificações" style="position:relative;text-decoration:none;background:#fff;border:1px solid var(--border);border-radius:999px;width:42px;height:42px;display:flex;align-items:center;justify-content:center">
      <span class="<%= (typeof notificacoesNaoLidas !== 'undefined' && notificacoesNaoLidas > 0) ? 'sino-alerta' : '' %>" style="font-size:20px">🔔</span>
      <% if (typeof notificacoesNaoLidas !== 'undefined' && notificacoesNaoLidas > 0) { %>
        <span style="position:absolute;top:-5px;right:-5px;background:var(--brand);color:#fff;font-size:10px;font-weight:800;padding:2px 6px;border-radius:999px"><%= notificacoesNaoLidas %></span>
      <% } %>
    </a>
  </div>
  <% if(typeof title!=='undefined'&&title){ %>
  <div class="page-head">
    <h1><%= title %></h1>
    <% if(typeof subtitle!=='undefined'&&subtitle){ %><p><%= subtitle %></p><% } %>
  </div>
  <% } %>
</main>
</div>
</body>
</html>
