<%- include('partials/app-shell',{active:'leads',title:'Detalhe da Lead',subtitle:'',user:user}) %>

<style>
.ld-layout{display:grid;grid-template-columns:1fr 320px;gap:16px;align-items:start}
.ld-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:12px}
.ld-title{font-size:10px;font-weight:700;color:var(--text-ter);text-transform:uppercase;letter-spacing:.6px;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border-light)}
.info-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border-light);font-size:12px;gap:12px}
.info-row:last-child{border:none}
.info-lbl{color:var(--text-sec);flex-shrink:0}
.info-val{font-weight:500;color:var(--dark);text-align:right}
.tag-pill{display:inline-block;padding:2px 9px;border-radius:20px;font-size:10px;font-weight:600;margin:2px}
.match-card{display:grid;grid-template-columns:64px 1fr auto;gap:10px;align-items:center;padding:10px;background:var(--bg);border-radius:9px;border:1px solid var(--border-light);margin-bottom:8px;text-decoration:none;color:inherit;transition:border-color .1s}
.match-card:hover{border-color:var(--brand)}
.match-foto{width:64px;height:50px;object-fit:cover;border-radius:7px}
.match-ph{width:64px;height:50px;border-radius:7px;background:var(--border);display:flex;align-items:center;justify-content:center;color:var(--text-ter);font-size:18px}
.tl-item{display:grid;grid-template-columns:28px 1fr;gap:8px;padding:9px 0;border-bottom:1px solid var(--border-light)}
.tl-item:last-child{border:none}
.tl-ic{width:22px;height:22px;border-radius:50%;background:var(--bg);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;margin-top:1px}
.tl-acao{font-size:12px;font-weight:500;color:var(--dark)}
.tl-det{font-size:11px;color:var(--text-sec);margin-top:1px}
.tl-data{font-size:10px;color:var(--text-ter);margin-top:2px}
.acao-btn{display:flex;align-items:center;justify-content:center;gap:7px;width:100%;padding:10px 14px;border-radius:9px;font-size:12px;font-weight:600;text-decoration:none;border:none;cursor:pointer;margin-bottom:7px;transition:opacity .15s}
.acao-btn:hover{opacity:.88}
.perfil-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:8px}
.perfil-item{background:var(--bg);border:1px solid var(--border-light);border-radius:8px;padding:9px 11px}
.perfil-item-lbl{font-size:10px;color:var(--text-ter);margin-bottom:2px}
.perfil-item-val{font-size:13px;font-weight:600;color:var(--dark)}
.copiloto{border-radius:var(--radius);padding:16px;margin-bottom:14px}
@media(max-width:900px){.ld-layout{grid-template-columns:1fr}}
</style>

<!-- Voltar -->
<div style="margin-bottom:16px">
  <a href="/app/leads" style="font-size:12px;color:var(--text-sec);text-decoration:none;display:inline-flex;align-items:center;gap:4px">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    Voltar para Leads
  </a>
</div>

<%
const _p    = lead.perfilIA || {};
const _mat  = lead.matches || lead.matchesAuto || [];
const _matA = lead.matchesAuto || [];
const _score= lead.score || 0;
const _temp = lead.temperatura || 'frio';
const _fase = lead.faseFunil || 'novo';
const _msgs = (lead.mensagens||[]).filter(m=>m.de==='cliente').length;
const _fone = (lead.contato||lead.telefone||'').replace(/\D/g,'');
const _burl = typeof baseUrl!=='undefined' ? baseUrl : 'https://matchimoveis.onrender.com';
const _vurl = _burl+'/cliente/oferta/'+(lead.leadId||lead.id);
const _wtxt = encodeURIComponent('Olá '+(lead.nome||'')+'! Separei imóveis que combinam com o que você procura: '+_vurl);
const _tcor = _temp==='quente'?'var(--brand)':_temp==='morno'?'#d97706':'var(--text-ter)';
const _tbg  = _temp==='quente'?'var(--brand-light)':_temp==='morno'?'#fffbeb':'var(--bg)';
const _tbor = _temp==='quente'?'#fda4af':_temp==='morno'?'#fcd34d':'var(--border)';
let _copTitulo='', _copDesc='', _copAcoes=[];
if(_msgs===0){_copTitulo='Primeiro contato';_copDesc='Lead ainda não foi contatada.';_copAcoes=['whatsapp'];}
else if(!_p.tipo&&!_p.quartos){_copTitulo='Qualificando lead';_copDesc='Continue a conversa para entender o perfil.';_copAcoes=['whatsapp'];}
else if(_mat.length===0){_copTitulo='Sem match ainda';_copDesc='Imóveis da carteira não combinaram com esse perfil.';_copAcoes=['whatsapp'];}
else if(_mat.length>0&&_fase!=='decidido'){_copTitulo='Match encontrado — envie a vitrine!';_copDesc=_mat.length+' imóvel(is) compatível(is).';_copAcoes=['vitrine','whatsapp'];}
else if(_fase==='interessado'||_fase==='decidido'){_copTitulo='Lead interessada — agende a visita!';_copDesc='Hora de confirmar uma visita!';_copAcoes=['visita','whatsapp'];}
else{_copTitulo='Acompanhando';_copDesc='Continue a conversa normalmente.';_copAcoes=['whatsapp'];}
%>

<div class="ld-layout">

  <!-- COLUNA PRINCIPAL -->
  <main>

    <!-- Copiloto -->
    <div class="copiloto" style="background:<%=_tbg%>;border:1.5px solid <%=_tbor%>">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:12px">
        <div>
          <div style="font-size:10px;font-weight:700;color:<%=_tcor%>;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Copiloto Match</div>
          <div style="font-size:14px;font-weight:600;color:var(--dark)"><%=_copTitulo%></div>
          <div style="font-size:12px;color:var(--text-sec);margin-top:2px"><%=_copDesc%></div>
        </div>
        <div style="display:flex;gap:8px">
          <div style="text-align:center;background:var(--white);border-radius:8px;padding:8px 14px;border:1px solid <%=_tbor%>">
            <div style="font-size:20px;font-weight:700;color:<%=_tcor%>"><%=_score%></div>
            <div style="font-size:9px;color:var(--text-ter);font-weight:600;text-transform:uppercase">Score</div>
          </div>
          <div style="text-align:center;background:var(--white);border-radius:8px;padding:8px 14px;border:1px solid <%=_tbor%>">
            <div style="font-size:20px;font-weight:700;color:var(--dark)"><%=_mat.length%></div>
            <div style="font-size:9px;color:var(--text-ter);font-weight:600;text-transform:uppercase">Matches</div>
          </div>
          <div style="text-align:center;background:var(--white);border-radius:8px;padding:8px 14px;border:1px solid <%=_tbor%>">
            <div style="font-size:20px;font-weight:700;color:var(--dark)"><%=_msgs%></div>
            <div style="font-size:9px;color:var(--text-ter);font-weight:600;text-transform:uppercase">Msgs</div>
          </div>
        </div>
      </div>

      <!-- Perfil detectado -->
      <% if(_p.tipo||_p.quartos||_p.bairro||_p.valorMax) { %>
      <div style="background:var(--white);border-radius:8px;padding:8px 12px;margin-bottom:10px;border:1px solid <%=_tbor%>;display:flex;flex-wrap:wrap;gap:5px;align-items:center">
        <span style="font-size:10px;font-weight:600;color:var(--text-ter)">Perfil:</span>
        <% if(_p.intencao){%><span class="tag-pill" style="background:#eff6ff;color:#1d4ed8"><%=_p.intencao%></span><%}%>
        <% if(_p.tipo){%><span class="tag-pill" style="background:var(--bg);color:var(--text)"><%=_p.tipo%></span><%}%>
        <% if(_p.quartos){%><span class="tag-pill" style="background:var(--bg);color:var(--text)"><%=_p.quartos%>q</span><%}%>
        <% if(_p.bairro){%><span class="tag-pill" style="background:#f0fdf4;color:#15803d"><%=_p.bairro%></span><%}%>
        <% if(_p.rua){%><span class="tag-pill" style="background:#f0fdf4;color:#15803d"><%=_p.rua%></span><%}%>
        <% if(_p.valorMax){%><span class="tag-pill" style="background:#f0fdf4;color:#15803d">até R$<%=Math.round(Number(_p.valorMax)/1000)%>k</span><%}%>
        <% if(_p.urgencia==='alta'){%><span class="tag-pill" style="background:#fef2f2;color:#dc2626">urgente</span><%}%>
      </div>
      <% } %>

      <!-- Botões copiloto -->
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <% if(_copAcoes.includes('vitrine')&&_fone) { %>
        <% if(lead.vitrineEnviadaEm) { %>
        <a href="https://wa.me/55<%=_fone%>?text=<%=_wtxt%>" target="_blank" style="background:#f9fafb;color:#6b7280;padding:9px 16px;border-radius:8px;font-size:12px;font-weight:500;text-decoration:none;display:inline-flex;align-items:center;gap:5px;border:0.5px solid rgba(0,0,0,.1)" title="Sistema enviou — clique para reenviar">
          ✓ Vitrine enviada <%= new Date(lead.vitrineEnviadaEm).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}) %>
        </a>
        <% } else { %>
        <a href="https://wa.me/55<%=_fone%>?text=<%=_wtxt%>" target="_blank" style="background:#25D366;color:#fff;padding:9px 16px;border-radius:8px;font-size:12px;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:5px">Enviar vitrine</a>
        <% } %>
        <% } %>
        <% if(_copAcoes.includes('visita')) { %>
        <button onclick="abrirModalAgendarVisita()" style="background:#7c3aed;color:#fff;padding:9px 16px;border-radius:8px;font-size:12px;font-weight:600;border:none;cursor:pointer">Agendar visita</button>
        <% } %>
        <% if(_copAcoes.includes('whatsapp')&&_fone) { %>
        <a href="https://wa.me/55<%=_fone%>" target="_blank" style="background:var(--dark);color:#fff;padding:9px 16px;border-radius:8px;font-size:12px;font-weight:600;text-decoration:none">WhatsApp</a>
        <% } %>
      </div>
    </div>

    <!-- Dados da lead -->
    <div class="ld-card">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
        <div style="width:44px;height:44px;border-radius:50%;background:var(--dark);display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;font-weight:700;flex-shrink:0"><%= (lead.nome||'?')[0].toUpperCase() %></div>
        <div>
          <div style="font-size:16px;font-weight:600;color:var(--dark)"><%= lead.nome||'Lead sem nome' %></div>
          <div style="font-size:12px;color:var(--text-sec);margin-top:2px"><%= [lead.contato||lead.telefone, lead.email].filter(Boolean).join(' · ') %></div>
          <div style="margin-top:4px">
            <% if(lead.fonte){%><span class="tag-pill" style="background:#eff6ff;color:#2563eb"><%=lead.fonte%></span><%}%>
            <% if(lead.canal){%><span class="tag-pill" style="background:#f0fdf4;color:#16a34a"><%=lead.canal%></span><%}%>
            <% if(lead.origem){%><span class="tag-pill" style="background:var(--bg);color:var(--text-sec)"><%=String(lead.origem).replace(/_/g,' ')%></span><%}%>
          </div>
        </div>
      </div>
      <% if(lead.criadoEm||lead.data_cadastro_br||lead.data_cadastro) { %>
      <div class="info-row"><span class="info-lbl">📅 Entrada</span><span class="info-val"><%= lead.data_cadastro_br||new Date(lead.criadoEm||lead.data_cadastro).toLocaleString('pt-BR',{timeZone:'America/Sao_Paulo'}) %></span></div>
      <% } %>
      <% if(lead.ultimaMensagemEm) { %>
      <div class="info-row"><span class="info-lbl">💬 Última interação</span><span class="info-val"><%= new Date(lead.ultimaMensagemEm).toLocaleString('pt-BR',{timeZone:'America/Sao_Paulo'}) %></span></div>
      <% } %>
    </div>

    <!-- Perfil de busca completo -->
    <% if(Object.keys(_p).length) { %>
    <div class="ld-card">
      <div class="ld-title">Perfil de busca detectado pela IA</div>
      <div class="perfil-grid">
        <% if(_p.tipo){%><div class="perfil-item"><div class="perfil-item-lbl">Tipo</div><div class="perfil-item-val"><%=_p.tipo%></div></div><%}%>
        <% if(_p.quartos){%><div class="perfil-item"><div class="perfil-item-lbl">Quartos</div><div class="perfil-item-val"><%=_p.quartos%></div></div><%}%>
        <% if(_p.suites){%><div class="perfil-item"><div class="perfil-item-lbl">Suítes</div><div class="perfil-item-val"><%=_p.suites%></div></div><%}%>
        <% if(_p.vagas){%><div class="perfil-item"><div class="perfil-item-lbl">Vagas</div><div class="perfil-item-val"><%=_p.vagas%></div></div><%}%>
        <% if(_p.banheiros){%><div class="perfil-item"><div class="perfil-item-lbl">Banheiros</div><div class="perfil-item-val"><%=_p.banheiros%></div></div><%}%>
        <% if(_p.area){%><div class="perfil-item"><div class="perfil-item-lbl">Área</div><div class="perfil-item-val"><%=_p.area%>m²</div></div><%}%>
        <% if(_p.bairro){%><div class="perfil-item"><div class="perfil-item-lbl">Bairro</div><div class="perfil-item-val"><%=_p.bairro%></div></div><%}%>
        <% if(_p.rua){%><div class="perfil-item"><div class="perfil-item-lbl">Rua</div><div class="perfil-item-val"><%=_p.rua%></div></div><%}%>
        <% if(_p.cidade){%><div class="perfil-item"><div class="perfil-item-lbl">Cidade</div><div class="perfil-item-val"><%=_p.cidade%></div></div><%}%>
        <% if(_p.valorMax){%><div class="perfil-item"><div class="perfil-item-lbl">Valor máx.</div><div class="perfil-item-val">R$<%=Math.round(Number(_p.valorMax)/1000)%>k</div></div><%}%>
        <% if(_p.intencao){%><div class="perfil-item"><div class="perfil-item-lbl">Intenção</div><div class="perfil-item-val"><%=_p.intencao%></div></div><%}%>
        <% if(_p.urgencia){%><div class="perfil-item"><div class="perfil-item-lbl">Urgência</div><div class="perfil-item-val"><%=_p.urgencia%></div></div><%}%>
        <% if(_p.faseFunil){%><div class="perfil-item"><div class="perfil-item-lbl">Funil</div><div class="perfil-item-val"><%=_p.faseFunil%></div></div><%}%>
        <% if(_p.motivacao){%><div class="perfil-item"><div class="perfil-item-lbl">Motivação</div><div class="perfil-item-val"><%=_p.motivacao%></div></div><%}%>
        <% if(_p.sentimento){%><div class="perfil-item"><div class="perfil-item-lbl">Sentimento</div><div class="perfil-item-val"><%=_p.sentimento%></div></div><%}%>
      </div>
    </div>
    <% } %>

    <!-- Ciclos de busca -->
    <% if(lead.ciclosBusca && lead.ciclosBusca.length > 0) { %>
    <div class="ld-card">
      <div class="ld-title">🔄 Histórico de buscas (<%= lead.ciclosBusca.length + 1 %> perfis)</div>
      <% lead.ciclosBusca.slice().reverse().forEach(function(ciclo) { %>
      <div style="border:1px solid var(--border-light);border-radius:8px;padding:10px;margin-bottom:8px;background:var(--bg)">
        <div style="font-size:11px;color:var(--text-ter);margin-bottom:6px">Perfil anterior · <%= new Date(ciclo.em).toLocaleDateString("pt-BR") %></div>
        <div style="display:flex;flex-wrap:wrap;gap:6px">
          <% if(ciclo.perfil.tipo){%><span style="background:#f3f4f6;border-radius:6px;padding:3px 8px;font-size:12px"><%=ciclo.perfil.tipo%></span><%}%>
          <% if(ciclo.perfil.quartos){%><span style="background:#f3f4f6;border-radius:6px;padding:3px 8px;font-size:12px"><%=ciclo.perfil.quartos%> qtos</span><%}%>
          <% if(ciclo.perfil.bairro){%><span style="background:#f3f4f6;border-radius:6px;padding:3px 8px;font-size:12px"><%=ciclo.perfil.bairro%></span><%}%>
          <% if(ciclo.perfil.valorMax){%><span style="background:#f3f4f6;border-radius:6px;padding:3px 8px;font-size:12px">R$<%=Math.round(Number(ciclo.perfil.valorMax)/1000)%>k</span><%}%>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
    <!-- Imóvel de interesse -->
    <% if(lead.imovel_interesse) { %>
    <div class="ld-card">
      <div class="ld-title">Imóvel que gerou a lead</div>
      <div class="info-row"><span class="info-lbl">Referência</span><span class="info-val">#<%= lead.imovel_interesse %></span></div>
      <% if(lead.titulo_interesse){%><div class="info-row"><span class="info-lbl">Título</span><span class="info-val"><%=lead.titulo_interesse%></span></div><%}%>
      <% if(lead.tipo){%><div class="info-row"><span class="info-lbl">Tipo</span><span class="info-val"><%=lead.tipo%></span></div><%}%>
      <% if(lead.bairro){%><div class="info-row"><span class="info-lbl">Bairro</span><span class="info-val"><%=lead.bairro%></span></div><%}%>
      <% if(lead.valor_imovel){%><div class="info-row"><span class="info-lbl">Valor</span><span class="info-val">R$ <%=Number(lead.valor_imovel).toLocaleString('pt-BR')%></span></div><%}%>
      <a href="/imovel/<%= lead.imovel_interesse %>" target="_blank" class="btn btn-outline btn-sm" style="margin-top:10px;display:inline-flex">Ver imóvel →</a>
    </div>
    <% } %>

    <!-- Matches da carteira -->
    <div class="ld-card">
      <div class="ld-title">Imóveis compatíveis da carteira (<%= _mat.length %>)</div>
      <% if(!_mat.length) { %>
        <div style="text-align:center;padding:20px;color:var(--text-ter);font-size:13px">Nenhum imóvel compatível encontrado na carteira.</div>
      <% } else { %>
        <% _mat.forEach(m => { %>
        <a href="/app/imovel/<%= m.idExterno||m.id||'' %>" target="_blank" class="match-card">
          <% if(m.fotos&&m.fotos[0]) { %><img class="match-foto" src="<%= m.fotos[0] %>"><% } else { %><div class="match-ph"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg></div><% } %>
          <div>
            <div style="font-size:12px;font-weight:600;color:var(--dark)"><%= m.tipo||'Imóvel' %> · <%= m.bairro||'-' %></div>
            <div style="font-size:11px;color:var(--text-sec);margin-top:2px"><%= [m.area_m2?m.area_m2+'m²':null, m.quartos?m.quartos+'q':null, m.vagas?m.vagas+'vg':null].filter(Boolean).join(' · ') %></div>
            <% if(m.score){%><div style="font-size:10px;color:#7c3aed;font-weight:600;margin-top:2px">Score <%=m.score%></div><%}%>
          </div>
          <div style="font-size:13px;font-weight:700;color:var(--brand);white-space:nowrap">R$ <%= Number(m.valor_imovel||m.valor||0).toLocaleString('pt-BR') %></div>
        </a>
        <% }) %>
      <% } %>
    </div>

    <!-- Matches automáticos WhatsApp -->
    <% if(_matA.length) { %>
    <div class="ld-card">
      <div class="ld-title">Matches automáticos via WhatsApp (<%= _matA.length %>)</div>
      <% _matA.forEach(m => { %>
      <a href="/app/imovel/<%= m.idInterno||m.id||'' %>" target="_blank" class="match-card">
        <div class="match-ph" style="background:var(--brand-light)"><span style="font-size:13px;font-weight:700;color:var(--brand)"><%= m.rank||'' %></span></div>
        <div>
          <div style="font-size:12px;font-weight:600;color:var(--dark)"><%= m.titulo||m.endereco||'Imóvel #'+(m.rank||'') %></div>
          <div style="font-size:11px;color:var(--text-sec);margin-top:2px"><%= m.tipo||'' %> · <%= m.quartos||0 %>q · <%= m.bairro||'' %></div>
        </div>
        <div style="text-align:right">
          <div style="font-size:12px;font-weight:700;color:var(--brand)">Score <%= m.score||0 %></div>
          <div style="font-size:11px;color:var(--text-sec)"><%= m.valor?'R$'+Number(m.valor).toLocaleString('pt-BR'):'' %></div>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>

    <!-- Timeline -->
    <div class="ld-card">
      <div class="ld-title">Timeline de eventos</div>
      <%
      const tlEventos = [];
      if(lead.matchAutoEm) tlEventos.push({ ic:'🎯', acao:'Match automático gerado', det:(lead.matchesAuto||[]).length+' imóveis compatíveis', data:lead.matchAutoEm });
      if((lead.matches||[]).length) tlEventos.push({ ic:'✅', acao:'Match base interna', det:(lead.matches||[]).length+' imóveis', data:lead.matchAtualizadoEm||lead.createdAt||'' });
      if(lead.imovel_interesse) tlEventos.push({ ic:'🏠', acao:'Interesse em imóvel', det:'#'+lead.imovel_interesse, data:lead.createdAt||lead.data_cadastro||'' });
      if(typeof visitasDaLead!=='undefined'&&visitasDaLead&&visitasDaLead.length) {
        visitasDaLead.forEach(v => tlEventos.push({ ic:'📅', acao:'Visita agendada', det:'Imóvel #'+(v.imovelId||'-')+' — '+v.status, data:v.createdAt||v.data||'' }));
      }
      if(lead.scoreAtualizadoEm) tlEventos.push({ ic:'⚡', acao:'Score atualizado', det:'Score: '+(lead.score||0), data:lead.scoreAtualizadoEm });
      if(lead.criadoEm||lead.data_cadastro) tlEventos.push({ ic:'🆕', acao:'Lead criada', det:'Origem: '+(lead.origem||'manual'), data:lead.criadoEm||lead.data_cadastro||'' });
      if(lead.vitrineEnviadaEm) tlEventos.push({ ic:'🏪', acao:'Vitrine enviada', det:(lead.matchCount||0)+' imóveis na vitrine', data:lead.vitrineEnviadaEm });
      if(lead.tipoLead && lead.tipoLeadAtualizadoEm) tlEventos.push({ ic:'🏷️', acao:'Lead classificada', det:lead.tipoLead==='vendedor'?'Tem imóvel para vender':lead.tipoLead==='corretor'?'Corretor parceiro':'Buscando imóvel', data:lead.tipoLeadAtualizadoEm });
      if(lead.imovelVendedor&&lead.imovelVendedor.cadastradoEm) tlEventos.push({ ic:'🏠', acao:'Imóvel do cliente cadastrado', det:(lead.imovelVendedor.tipo||'')+' em '+(lead.imovelVendedor.bairro||'-'), data:lead.imovelVendedor.cadastradoEm });
      if(lead.cicloAnterior) tlEventos.push({ ic:'🔄', acao:'Novo ciclo de busca', det:'Continuação de lead anterior', data:lead.criadoEm||'' });
      (lead.historico||[]).filter(h=>h.acao!=='visualizou_detalhes_lead').forEach(h => tlEventos.push({ ic:'📋', acao:h.acao, det:'', data:h.data||'' }));
      if(lead.criadoEm||lead.data_cadastro) tlEventos.push({ ic:'🆕', acao:'Lead criada', det:'Origem: '+(lead.origem||'manual'), data:lead.criadoEm||lead.data_cadastro||'' });
      if(lead.vitrineEnviadaEm) tlEventos.push({ ic:'🏪', acao:'Vitrine enviada', det:(lead.matchCount||0)+' imóveis na vitrine', data:lead.vitrineEnviadaEm });
      if(lead.tipoLead && lead.tipoLeadAtualizadoEm) tlEventos.push({ ic:'🏷️', acao:'Lead classificada', det:lead.tipoLead==='vendedor'?'Tem imóvel para vender':lead.tipoLead==='corretor'?'Corretor parceiro':'Buscando imóvel', data:lead.tipoLeadAtualizadoEm });
      if(lead.imovelVendedor && lead.imovelVendedor.cadastradoEm) tlEventos.push({ ic:'🏠', acao:'Imóvel do cliente cadastrado', det:(lead.imovelVendedor.tipo||'')+ ' em '+(lead.imovelVendedor.bairro||'-'), data:lead.imovelVendedor.cadastradoEm });
      if(lead.cicloAnterior) tlEventos.push({ ic:'🔄', acao:'Novo ciclo de busca', det:'Lead anterior: '+lead.cicloAnterior, data:lead.criadoEm||'' });
      if(lead.faseFunil) tlEventos.push({ ic:'📊', acao:'Fase do funil', det:lead.faseFunil, data:lead.memoriaOperacional&&lead.memoriaOperacional.atualizadoEm||'' });
      (lead.historico||[]).forEach(h => {
        if(h.acao !== 'visualizou_detalhes_lead') tlEventos.push({ ic:'📋', acao:h.acao, det:'', data:h.data||'' });
      });
      tlEventos.sort((a,b) => new Date(b.data||0)-new Date(a.data||0));
      %>
      <% if(tlEventos.length) { %>
        <% tlEventos.slice(0,12).forEach(ev => { %>
        <div class="tl-item">
          <div class="tl-ic"><%= ev.ic %></div>
          <div>
            <div class="tl-acao"><%= ev.acao %></div>
            <% if(ev.det){%><div class="tl-det"><%= ev.det %></div><%}%>
            <div class="tl-data"><%= ev.data ? new Date(ev.data).toLocaleString('pt-BR') : '' %></div>
          </div>
        </div>
        <% }) %>
        <% if(tlEventos.length>12){%><div style="font-size:11px;color:var(--text-ter);text-align:center;padding-top:8px"><%= tlEventos.length-12 %> eventos anteriores</div><%}%>
      <% } else { %>
        <div style="font-size:12px;color:var(--text-ter);text-align:center;padding:16px">Nenhuma interação registrada.</div>
      <% } %>
    </div>

  </main>

  <!-- SIDEBAR -->
  <aside>

    <!-- Ações rápidas -->
    <div class="ld-card">
      <div class="ld-title">Ações rápidas</div>

      <% if(_fone) { %>
      <% if(lead.waQualificacaoEnviadoEm) { %>
      <a href="https://wa.me/55<%=_fone%>" target="_blank" class="acao-btn" style="background:#f9fafb;color:#6b7280;border:0.5px solid rgba(0,0,0,.1)" title="Sistema enviou qualificação — clique para abrir">✓ WA enviado <%= new Date(lead.waQualificacaoEnviadoEm).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}) %></a>
      <% } else { %>
      <a href="https://wa.me/55<%=_fone%>" target="_blank" class="acao-btn" style="background:#25D366;color:#fff">WhatsApp</a>
      <% } %>
      <a href="tel:<%=_fone%>" class="acao-btn" style="background:var(--bg);color:var(--dark);border:1px solid var(--border)">Ligar</a>
      <% } %>

      <% if(_mat.length&&_fone) { %>
      <% if(lead.vitrineEnviadaEm) { %>
      <a href="https://wa.me/55<%=_fone%>?text=<%=_wtxt%>" target="_blank" class="acao-btn" style="background:#f9fafb;color:#6b7280;border:0.5px solid rgba(0,0,0,.1)" title="Sistema enviou — clique para reenviar">✓ Vitrine enviada <%= new Date(lead.vitrineEnviadaEm).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}) %></a>
      <% } else { %>
      <a href="https://wa.me/55<%=_fone%>?text=<%=_wtxt%>" target="_blank" class="acao-btn" style="background:var(--brand);color:#fff">Enviar vitrine</a>
      <% } %>
      <% } %>

      <a href="/cliente/oferta/<%=lead.leadId||lead.id%>?userId=<%=encodeURIComponent(lead.userId||lead.usuarioId||lead.corretorId||'')%>" target="_blank" class="acao-btn" style="background:var(--bg);color:var(--dark);border:1px solid var(--border)">Ver vitrine</a>

      <form method="POST" action="/app/lead/<%= lead.id||lead.leadId %>/buscar-quintoandar" style="margin-bottom:7px">
        <!-- Match QuintoAndar oculto -->
      </form>
    </div>

    <!-- Status comercial -->
    <div class="ld-card">
      <div class="ld-title">Status comercial</div>
      <div class="info-row"><span class="info-lbl">Temperatura</span><span class="info-val" style="color:<%=_tcor%>"><%= _temp %></span></div>
      <div class="info-row"><span class="info-lbl">Funil</span><span class="info-val"><%= _fase %></span></div>
      <div class="info-row"><span class="info-lbl">Score</span><span class="info-val"><%= _score %></span></div>
      <div class="info-row"><span class="info-lbl">Etapa</span><span class="info-val"><%= lead.scoreEtapa||'Novo' %></span></div>
      <div class="info-row"><span class="info-lbl">Matches carteira</span><span class="info-val"><%= _mat.length %></span></div>
<!-- Matches QA oculto -->
      <div class="info-row"><span class="info-lbl">Mensagens</span><span class="info-val"><%= _msgs %></span></div>
      <% if(lead.vitrineEnviada){%><div class="info-row"><span class="info-lbl">Vitrine enviada</span><span class="info-val" style="color:#16a34a">✓ <%= lead.vitrineEnviadaEm ? new Date(lead.vitrineEnviadaEm).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) : '' %></span></div><%}%>
      <% if(lead.waFollowupVitrineEnviadoEm){%><div class="info-row"><span class="info-lbl">Follow-up vitrine</span><span class="info-val" style="color:#6b7280">✓ Sistema enviou</span></div><%}%>
      <% if(lead.waAgendarVisitaEnviadoEm){%><div class="info-row"><span class="info-lbl">WA agendar visita</span><span class="info-val" style="color:#6b7280">✓ Sistema enviou</span></div><%}%>
      <% if(lead.visitaSolicitada){%><div class="info-row"><span class="info-lbl">Visita solicitada</span><span class="info-val" style="color:#16a34a">✓</span></div><%}%>
      <% if(lead.visitaConfirmada){%><div class="info-row"><span class="info-lbl">Visita confirmada</span><span class="info-val" style="color:#16a34a">✓</span></div><%}%>
      <% if(lead.propostaFeita){%><div class="info-row"><span class="info-lbl">Proposta</span><span class="info-val" style="color:#16a34a">✓</span></div><%}%>
    </div>

    <!-- Visitas da lead -->
    <% if(typeof visitasDaLead!=='undefined'&&visitasDaLead&&visitasDaLead.length) { %>
    <div class="ld-card">
      <div class="ld-title">Visitas (<%= visitasDaLead.length %>)</div>
      <% visitasDaLead.forEach(v => { %>
      <div style="padding:10px;background:var(--bg);border-radius:8px;border:1px solid var(--border-light);margin-bottom:8px;font-size:12px">
        <div style="font-weight:500;color:var(--dark);margin-bottom:3px"><%= v.imovelTitulo||v.imovelBairro||'Imóvel' %></div>
        <div style="color:var(--text-sec)"><%= v.dataVisita %> às <%= v.horaVisita %></div>
        <div style="margin-top:4px">
          <span style="padding:2px 7px;border-radius:20px;font-size:10px;font-weight:600;background:<%= v.status==='confirmada'?'#f0fdf4':v.status==='cancelada'?'#fef2f2':'#fef9c3' %>;color:<%= v.status==='confirmada'?'#16a34a':v.status==='cancelada'?'#dc2626':'#a16207' %>"><%= v.status||'solicitada' %></span>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Imóvel do vendedor -->
    <% if(lead.tipoLead === 'vendedor') { %>
    <div class="ld-card">
      <div class="ld-title">🏠 Imóvel para Vender/Alugar</div>
      <% if(lead.imovelVendedor) { %>
      <div style="padding:10px;background:var(--bg);border-radius:8px;border:1px solid var(--border-light);font-size:12px">
        <div style="font-weight:600;color:var(--dark);margin-bottom:6px"><%= lead.imovelVendedor.tipo||'Imóvel' %> · <%= lead.imovelVendedor.bairro||'-' %></div>
        <div style="color:var(--text-sec);margin-bottom:3px"><%= lead.imovelVendedor.quartos||0 %> quartos · <%= lead.imovelVendedor.area||'-' %>m²</div>
        <div style="color:var(--text-sec);margin-bottom:6px">R$ <%= Number(lead.imovelVendedor.valor||0).toLocaleString('pt-BR') %> · <%= lead.imovelVendedor.finalidade||'venda' %></div>
        <% if(lead.imovelVendedor.obs) { %><div style="color:var(--text-ter);font-style:italic"><%= lead.imovelVendedor.obs %></div><% } %>
        <button onclick="abrirFormImovelVendedor()" style="margin-top:8px;font-size:10px;padding:4px 10px;border-radius:6px;border:1px solid var(--border);background:#fff;cursor:pointer;color:var(--text-sec)">Editar</button>
      </div>
      <% } else { %>
      <div style="font-size:12px;color:var(--text-sec);margin-bottom:10px">Nenhum imóvel cadastrado ainda.</div>
      <button onclick="abrirFormImovelVendedor()" style="font-size:11px;padding:6px 14px;border-radius:8px;border:1px solid var(--brand);background:#fff;cursor:pointer;color:var(--brand);font-weight:600">+ Cadastrar imóvel</button>
      <% } %>

      <!-- Formulário inline -->
      <div id="form-imovel-vendedor" style="display:none;margin-top:12px">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px">
          <div>
            <label style="font-size:10px;color:var(--text-ter);font-weight:600">TIPO</label>
            <select id="iv-tipo" style="width:100%;padding:6px;border-radius:6px;border:1px solid var(--border);font-size:12px;margin-top:3px">
              <option value="apartamento">Apartamento</option>
              <option value="casa">Casa</option>
              <option value="terreno">Terreno</option>
              <option value="comercial">Comercial</option>
            </select>
          </div>
          <div>
            <label style="font-size:10px;color:var(--text-ter);font-weight:600">FINALIDADE</label>
            <select id="iv-finalidade" style="width:100%;padding:6px;border-radius:6px;border:1px solid var(--border);font-size:12px;margin-top:3px">
              <option value="venda">Venda</option>
              <option value="aluguel">Aluguel</option>
            </select>
          </div>
          <div>
            <label style="font-size:10px;color:var(--text-ter);font-weight:600">BAIRRO</label>
            <input id="iv-bairro" type="text" style="width:100%;padding:6px;border-radius:6px;border:1px solid var(--border);font-size:12px;margin-top:3px" placeholder="Bairro">
          </div>
          <div>
            <label style="font-size:10px;color:var(--text-ter);font-weight:600">QUARTOS</label>
            <input id="iv-quartos" type="number" min="0" style="width:100%;padding:6px;border-radius:6px;border:1px solid var(--border);font-size:12px;margin-top:3px" placeholder="0">
          </div>
          <div>
            <label style="font-size:10px;color:var(--text-ter);font-weight:600">ÁREA (m²)</label>
            <input id="iv-area" type="number" style="width:100%;padding:6px;border-radius:6px;border:1px solid var(--border);font-size:12px;margin-top:3px" placeholder="0">
          </div>
          <div>
            <label style="font-size:10px;color:var(--text-ter);font-weight:600">VALOR (R$)</label>
            <input id="iv-valor" type="number" style="width:100%;padding:6px;border-radius:6px;border:1px solid var(--border);font-size:12px;margin-top:3px" placeholder="0">
          </div>
        </div>
        <div style="margin-bottom:8px">
          <label style="font-size:10px;color:var(--text-ter);font-weight:600">OBSERVAÇÕES</label>
          <textarea id="iv-obs" rows="2" style="width:100%;padding:6px;border-radius:6px;border:1px solid var(--border);font-size:12px;margin-top:3px;resize:none" placeholder="Detalhes adicionais..."></textarea>
        </div>
        <div style="display:flex;gap:6px">
          <button onclick="salvarImovelVendedor('<%= lead.id %>')" style="flex:1;padding:8px;border-radius:8px;background:var(--brand);color:#fff;border:none;font-size:12px;font-weight:600;cursor:pointer">Salvar</button>
          <button onclick="document.getElementById('form-imovel-vendedor').style.display='none'" style="padding:8px 14px;border-radius:8px;background:var(--bg);color:var(--text-sec);border:1px solid var(--border);font-size:12px;cursor:pointer">Cancelar</button>
        </div>
      </div>
    </div>
    <% } %>

<!-- QuintoAndar oculto -->

  </aside>

</div>

<!-- Modal Cadastro Imóvel -->
<div id="modal-cadastro-imovel" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center;padding:20px">
  <div style="background:#fff;border-radius:16px;width:100%;max-width:900px;height:85vh;display:flex;flex-direction:column;overflow:hidden">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid #e5e5e3">
      <div style="font-size:15px;font-weight:600;color:#111">Cadastrar Imóvel do Cliente</div>
      <button onclick="fecharModalCadastroImovel()" style="background:none;border:none;font-size:20px;cursor:pointer;color:#6b7280">×</button>
    </div>
    <iframe id="iframe-cadastro" src="/app/cadastro?leadId=<%=lead.id%>&modal=1" style="flex:1;border:none;width:100%"></iframe>
  </div>
</div>

<!-- Modal Agendar Visita -->
<div id="modal-agendar-visita" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center;padding:20px">
  <div style="background:#fff;border-radius:16px;width:100%;max-width:520px;padding:24px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
      <div style="font-size:15px;font-weight:600;color:#111">Agendar Visita</div>
      <button onclick="fecharModalAgendarVisita()" style="background:none;border:none;font-size:20px;cursor:pointer;color:#6b7280">×</button>
    </div>

    <div style="margin-bottom:14px">
      <label style="font-size:11px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.5px">Imóvel</label>
      <select id="av-imovel" style="width:100%;margin-top:4px;padding:9px 11px;border:1px solid #e5e5e3;border-radius:8px;font-size:13px">
        <option value="">Selecione um imóvel...</option>
        <% (lead.matches||lead.matchesAuto||[]).forEach(m => { %>
        <option value="<%= m.id||m.codigoInterno||'' %>" data-titulo="<%= (m.titulo||m.tipo||'Imóvel')+' · '+(m.bairro||'-') %>">
          <%= (m.titulo||m.tipo||'Imóvel') %> · <%= m.bairro||'-' %> · <%= m.quartos||0 %>q
        </option>
        <% }) %>
      </select>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
      <div>
        <label style="font-size:11px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.5px">Data</label>
        <input type="date" id="av-data" style="width:100%;margin-top:4px;padding:9px 11px;border:1px solid #e5e5e3;border-radius:8px;font-size:13px">
      </div>
      <div>
        <label style="font-size:11px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.5px">Hora</label>
        <input type="time" id="av-hora" style="width:100%;margin-top:4px;padding:9px 11px;border:1px solid #e5e5e3;border-radius:8px;font-size:13px">
      </div>
    </div>

    <div style="margin-bottom:20px">
      <label style="font-size:11px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.5px">Observações</label>
      <textarea id="av-obs" rows="2" style="width:100%;margin-top:4px;padding:9px 11px;border:1px solid #e5e5e3;border-radius:8px;font-size:13px;resize:none" placeholder="Alguma observação para a visita..."></textarea>
    </div>

    <div style="display:flex;gap:8px">
      <button onclick="confirmarAgendarVisita('<%= lead.id %>','<%= lead.nome||lead.telefone %>','<%= (lead.telefone||lead.whatsapp||'').replace(/\D/g,'') %>')" style="flex:1;padding:10px;border-radius:8px;background:#7c3aed;color:#fff;border:none;font-size:13px;font-weight:600;cursor:pointer">Agendar</button>
      <button onclick="fecharModalAgendarVisita()" style="padding:10px 16px;border-radius:8px;background:#f9fafb;color:#6b7280;border:1px solid #e5e5e3;font-size:13px;cursor:pointer">Cancelar</button>
    </div>
  </div>
</div>

<script>
function abrirFormImovelVendedor(){
  const f = document.getElementById('form-imovel-vendedor');
  if(f) f.style.display = f.style.display==='none'?'block':'none';
}
function abrirModalAgendarVisita(){
  document.getElementById('modal-agendar-visita').style.display='flex';
  // preenche data de hoje
  const hoje = new Date().toISOString().split('T')[0];
  document.getElementById('av-data').value = hoje;
}
function fecharModalAgendarVisita(){
  document.getElementById('modal-agendar-visita').style.display='none';
}
async function confirmarAgendarVisita(leadId, nome, telefone){
  const imovelId = document.getElementById('av-imovel').value;
  const data = document.getElementById('av-data').value;
  const hora = document.getElementById('av-hora').value;
  const obs = document.getElementById('av-obs').value;
  if(!imovelId) return alert('Selecione um imóvel');
  if(!data) return alert('Informe a data');
  if(!hora) return alert('Informe o horário');
  const r = await fetch('/app/visita/agendar-corretor', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ leadId, imovelId, nome, telefone, dataVisita:data, horaVisita:hora, obs })
  });
  const d = await r.json();
  if(d.ok){ fecharModalAgendarVisita(); location.reload(); }
  else alert('Erro: '+d.erro);
}
function abrirModalCadastroImovel(){
  document.getElementById('modal-cadastro-imovel').style.display='flex';
}
function fecharModalCadastroImovel(){
  document.getElementById('modal-cadastro-imovel').style.display='none';
}
async function salvarImovelVendedor(leadId){
  const payload = {
    tipo: document.getElementById('iv-tipo').value,
    finalidade: document.getElementById('iv-finalidade').value,
    bairro: document.getElementById('iv-bairro').value,
    quartos: document.getElementById('iv-quartos').value,
    area: document.getElementById('iv-area').value,
    valor: document.getElementById('iv-valor').value,
    obs: document.getElementById('iv-obs').value
  };
  const r = await fetch('/app/lead/'+leadId+'/imovel-vendedor', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify(payload)
  });
  const d = await r.json();
  if(d.ok) location.reload();
  else alert('Erro: '+d.erro);
}
</script>
<%- include('partials/app-end') %>
