<%- include("partials/app-shell",{active:"assistente",user:user}) %>

<style>
  /* ── RESET DA MAIN ─────────────────────────────────────────────────────────── */
  main { padding: 0 !important; height: calc(100vh - 60px); display: flex; flex-direction: column; background: #f8f7f4; }

  /* ── LAYOUT GERAL ──────────────────────────────────────────────────────────── */
  .chat-wrapper { display: flex; flex-direction: column; height: 100%; max-width: 860px; margin: 0 auto; width: 100%; padding: 0 16px; box-sizing: border-box; }

  /* ── HEADER ────────────────────────────────────────────────────────────────── */
  .chat-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 0 12px; border-bottom: 1px solid #ece9e3; }
  .chat-header-left { display: flex; align-items: center; gap: 10px; }
  .chat-avatar { width: 36px; height: 36px; background: #ff385c; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
  .chat-title { font-weight: 700; font-size: 15px; color: #1a1a1a; font-family: 'Georgia', serif; }
  .chat-status { font-size: 11px; color: #22c55e; font-weight: 600; display: flex; align-items: center; gap: 4px; }
  .chat-status::before { content: ''; width: 6px; height: 6px; background: #22c55e; border-radius: 50%; display: inline-block; }
  .chat-header-actions { display: flex; gap: 8px; }
  .chip-pill { background: white; border: 1px solid #e5e0d8; border-radius: 20px; padding: 6px 14px; font-size: 12px; font-weight: 600; cursor: pointer; color: #555; transition: all .15s; white-space: nowrap; }
  .chip-pill:hover { background: #ff385c; color: white; border-color: #ff385c; }

  /* ── ÁREA DE MENSAGENS ─────────────────────────────────────────────────────── */
  #chat-messages { flex: 1; overflow-y: auto; padding: 24px 0; display: flex; flex-direction: column; gap: 20px; scroll-behavior: smooth; }
  #chat-messages::-webkit-scrollbar { width: 4px; }
  #chat-messages::-webkit-scrollbar-track { background: transparent; }
  #chat-messages::-webkit-scrollbar-thumb { background: #ddd; border-radius: 4px; }

  /* ── MENSAGENS ─────────────────────────────────────────────────────────────── */
  .msg { display: flex; align-items: flex-end; gap: 10px; animation: fadeUp .25s ease; }
  .msg.user { flex-direction: row-reverse; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  .msg-avatar { width: 28px; height: 28px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; margin-bottom: 2px; }
  .msg-avatar.bot { background: #ff385c; }
  .msg-avatar.user { background: #1a1a1a; }

  .bubble { max-width: 72%; padding: 13px 17px; border-radius: 18px; font-size: 14px; line-height: 1.75; word-break: break-word; }
  .bot-bubble { background: white; color: #1a1a1a; border-bottom-left-radius: 5px; box-shadow: 0 1px 4px rgba(0,0,0,.06); }
  .user-bubble { background: #1a1a1a; color: white; border-bottom-right-radius: 5px; }

  /* ── TYPING ────────────────────────────────────────────────────────────────── */
  .typing-dots { display: flex; gap: 4px; padding: 4px 2px; }
  .typing-dots span { width: 7px; height: 7px; background: #aaa; border-radius: 50%; animation: bounce .9s infinite; }
  .typing-dots span:nth-child(2) { animation-delay: .15s; }
  .typing-dots span:nth-child(3) { animation-delay: .3s; }
  @keyframes bounce { 0%,80%,100% { transform: translateY(0); } 40% { transform: translateY(-6px); } }

  /* ── FEEDBACK ──────────────────────────────────────────────────────────────── */
  .feedback-row { display: flex; align-items: center; gap: 6px; margin-top: -8px; padding-left: 38px; }
  .feedback-row span { font-size: 11px; color: #bbb; }
  .fb-btn { background: none; border: 1px solid #e5e0d8; border-radius: 12px; padding: 2px 10px; font-size: 11px; cursor: pointer; color: #888; transition: all .15s; }
  .fb-btn:hover { background: #f3f4f6; }

  /* ── CHIPS RÁPIDOS ─────────────────────────────────────────────────────────── */
  .quick-chips { display: flex; gap: 8px; flex-wrap: wrap; padding: 8px 0 12px; }
  .quick-chip { background: white; border: 1px solid #e5e0d8; border-radius: 20px; padding: 7px 14px; font-size: 12px; font-weight: 600; cursor: pointer; color: #444; transition: all .15s; }
  .quick-chip:hover { background: #ff385c; color: white; border-color: #ff385c; transform: translateY(-1px); }

  /* ── INPUT AREA ────────────────────────────────────────────────────────────── */
  .input-area { padding: 12px 0 16px; border-top: 1px solid #ece9e3; }
  .input-row { display: flex; gap: 10px; align-items: flex-end; background: white; border: 1.5px solid #e5e0d8; border-radius: 16px; padding: 10px 12px; transition: border-color .2s; }
  .input-row:focus-within { border-color: #ff385c; box-shadow: 0 0 0 3px rgba(255,56,92,.08); }
  #chat-input { flex: 1; border: none; outline: none; font-size: 14px; background: transparent; color: #1a1a1a; resize: none; max-height: 120px; line-height: 1.5; font-family: inherit; }
  #chat-input::placeholder { color: #bbb; }
  .attach-btn { background: none; border: none; cursor: pointer; font-size: 18px; color: #aaa; padding: 2px; transition: color .15s; flex-shrink: 0; }
  .attach-btn:hover { color: #ff385c; }
  .send-btn { background: #ff385c; border: none; border-radius: 10px; width: 36px; height: 36px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .15s; flex-shrink: 0; }
  .send-btn:hover { background: #e0334f; transform: scale(1.05); }
  .send-btn svg { width: 16px; height: 16px; fill: white; }
  .send-btn:disabled { background: #e5e0d8; cursor: not-allowed; transform: none; }

  /* ── BOAS-VINDAS ───────────────────────────────────────────────────────────── */
  .welcome-msg { text-align: center; padding: 32px 16px 8px; }
  .welcome-msg h2 { font-size: 22px; font-weight: 700; color: #1a1a1a; font-family: 'Georgia', serif; margin: 0 0 6px; }
  .welcome-msg p { font-size: 14px; color: #888; margin: 0; }

  @media (max-width: 600px) {
    .bubble { max-width: 88%; font-size: 13px; }
    .chat-header-actions { display: none; }
  }
</style>

<div style="height:calc(100vh - 60px);display:flex;flex-direction:column;background:#f8f7f4">
  <div class="chat-wrapper">

    <!-- HEADER -->
    <div class="chat-header">
      <div class="chat-header-left">
        <div class="chat-avatar">🤖</div>
        <div>
          <div class="chat-title">Assistente MatchImóveis</div>
          <div class="chat-status">Online</div>
        </div>
      </div>
      <div class="chat-header-actions">
        <button class="chip-pill" onclick="enviarMsg('o que devo fazer hoje')">📋 Plano do dia</button>
        <button class="chip-pill" onclick="enviarMsg('resumo geral')">📊 Resumo</button>
        <button class="chip-pill" onclick="enviarMsg('leads com match')">🎯 Match</button>
      </div>
    </div>

    <!-- MENSAGENS -->
    <div id="chat-messages">
      <!-- Boas-vindas -->
      <div class="welcome-msg">
        <h2>Olá, <%= user.nome || user.name || 'corretor' %>! 👋</h2>
        <p>Pergunte qualquer coisa sobre seus imóveis, leads e visitas.</p>
      </div>

      <!-- Chips rápidos iniciais -->
      <div class="quick-chips" style="justify-content:center">
        <button class="quick-chip" onclick="enviarMsg('o que devo fazer hoje')">📋 O que fazer hoje</button>
        <button class="quick-chip" onclick="enviarMsg('leads com match')">🎯 Leads com match</button>
        <button class="quick-chip" onclick="enviarMsg('visitas hoje')">📅 Visitas hoje</button>
        <button class="quick-chip" onclick="enviarMsg('demanda por bairro')">📍 Demanda</button>
        <button class="quick-chip" onclick="enviarMsg('meus imoveis')">🏠 Imóveis</button>
      </div>
    </div>

    <!-- INPUT -->
    <div class="input-area">
      <div class="input-row">
        <input type="file" id="file-input" accept=".xml,.xlsx,.xls,.csv" style="display:none" onchange="uploadArquivo(this)">
        <button class="attach-btn" onclick="document.getElementById('file-input').click()" title="Anexar arquivo">
          📎
        </button>
        <textarea id="chat-input" placeholder="Pergunte sobre seus imóveis, leads, visitas..." rows="1"
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();enviarMsg();}"
          oninput="autoResize(this)"></textarea>
        <button class="send-btn" id="send-btn" onclick="enviarMsg()">
          <svg viewBox="0 0 24 24"><path d="M2 21l21-9L2 3v7l15 2-15 2z"/></svg>
        </button>
      </div>
    </div>

  </div>
</div>

<script>
const stats = <%- JSON.stringify(stats) %>;

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

function scrollBottom() {
  const c = document.getElementById('chat-messages');
  c.scrollTop = c.scrollHeight;
}

function addMsg(html, tipo) {
  const c = document.getElementById('chat-messages');
  const wrap = document.createElement('div');
  wrap.className = 'msg ' + tipo;

  const avatar = document.createElement('div');
  avatar.className = 'msg-avatar ' + tipo;
  avatar.textContent = tipo === 'bot' ? '🤖' : '👤';

  const bubble = document.createElement('div');
  bubble.className = 'bubble ' + tipo + '-bubble';
  bubble.innerHTML = html;

  wrap.appendChild(avatar);
  wrap.appendChild(bubble);
  c.appendChild(wrap);
  scrollBottom();
  return wrap;
}

// Streaming — escreve o HTML progressivamente como o Claude
function streamMsg(html) {
  const c = document.getElementById('chat-messages');
  const wrap = document.createElement('div');
  wrap.className = 'msg bot';

  const avatar = document.createElement('div');
  avatar.className = 'msg-avatar bot';
  avatar.textContent = '🤖';

  const bubble = document.createElement('div');
  bubble.className = 'bubble bot-bubble';
  bubble.innerHTML = '';

  wrap.appendChild(avatar);
  wrap.appendChild(bubble);
  c.appendChild(wrap);
  scrollBottom();

  // Quebra o HTML em tokens (tags e texto)
  const tokens = [];
  let i = 0;
  while (i < html.length) {
    if (html[i] === '<') {
      // Tag HTML — adiciona inteira de uma vez
      const end = html.indexOf('>', i);
      if (end === -1) { tokens.push(html[i]); i++; continue; }
      tokens.push(html.slice(i, end + 1));
      i = end + 1;
    } else {
      tokens.push(html[i]);
      i++;
    }
  }

  let idx = 0;
  let current = '';

  function next() {
    if (idx >= tokens.length) {
      bubble.innerHTML = html; // garante fidelidade no final
      scrollBottom();
      return;
    }
    const token = tokens[idx++];
    current += token;
    bubble.innerHTML = current;
    scrollBottom();

    // Tags HTML: sem delay. Texto: delay variável para efeito humano
    const isTag = token.startsWith('<');
    const delay = isTag ? 0 : (token === ' ' ? 20 : Math.random() * 18 + 8);
    setTimeout(next, delay);
  }

  next();
  return wrap;
}

// Streaming — escreve o HTML progressivamente como o Claude
