<%- include("partials/app-shell",{active:"importar",user:user}) %>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<title>Importar Leads</title>
<meta name="viewport" content="width=device-width,initial-scale=1">

<style>
*{box-sizing:border-box}
body{
  margin:0;
  font-family:Arial,Helvetica,sans-serif;
  background:#FFFFFF;
  color:#241433;
}
.layout{display:flex;min-height:100vh}
.sidebar{
  width:270px;
  background:#FFFFFF;
  color:#fff;
  padding:22px;
  display:flex;
  flex-direction:column;
  gap:18px;
}
.logo{
  font-size:24px;
  font-weight:900;
  letter-spacing:-.5px;
}
.userbox{
  display:flex;
  gap:12px;
  align-items:center;
  background:rgba(255,255,255,.14);
  border:1px solid rgba(255,255,255,.18);
  border-radius:18px;
  padding:13px;
}
.avatar{
  width:48px;
  height:48px;
  border-radius:50%;
  background:#FFFFFF;
}
.uname{font-weight:800}
.utype{font-size:12px;color:#eee}
.menu{
  display:flex;
  flex-direction:column;
  gap:9px;
  margin-top:8px;
}
.menu a{
  color:#fff;
  text-decoration:none;
  padding:13px 14px;
  border-radius:14px;
  background:rgba(255,255,255,.12);
  font-weight:700;
}
.menu a:hover,.menu a.active{
  background:#fff;
  color:#FF385C;
}
.logout{
  margin-top:auto;
  background:#fff!important;
  color:#FF385C!important;
  text-align:center;
}
.content{flex:1;padding:34px}
.top h1{margin:0 0 7px;font-size:32px;color:#FF385C}
.muted{color:#6b5b7c}
.grid{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:20px;
  margin-top:24px;
}
.card{
  background:#fff;
  border:1px solid #FF385C;
  border-radius:24px;
  padding:25px;
  box-shadow:0 12px 35px rgba(91,33,182,.10);
}
.card h2{color:#FF385C;margin-top:0}
.btn{
  display:inline-block;
  background:#FFFFFF;
  color:#fff;
  border:0;
  border-radius:14px;
  padding:13px 17px;
  text-decoration:none;
  font-weight:800;
  cursor:pointer;
}
input,select{
  width:100%;
  padding:13px;
  border:1px solid #FF385C;
  border-radius:14px;
  background:#fff;
}
label{font-weight:800;font-size:13px;color:#FF385C}
.formgrid{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:15px;
}
@media(max-width:900px){
  .layout{flex-direction:column}
  .sidebar{width:100%}
  .grid{grid-template-columns:1fr}
  .formgrid{grid-template-columns:1fr}
}
</style>
<link rel="stylesheet" href="/airbnb.css">
</head>
<body>
<div class="layout">
  

  <main class="content">
    
<div class="top">
  <h1>Importar leads</h1>
  <p class="muted">Suba a planilha dos leads para o sistema gerar os matches.</p>
</div>

<div class="card">
  <form action="/process" method="post" enctype="multipart/form-data">
    <label>Arquivo CSV, Excel ou Numbers</label><br><br>
    <input type="file" name="file" accept=".csv,.xlsx,.xls,.numbers" required>
    <br><br>
    <button class="btn" type="submit">Importar e processar</button>
  </form>
</div>

  </main>
</div>
</body>
</html>
<%- include('partials/app-end') %>
