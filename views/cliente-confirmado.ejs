<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>Obrigado • MatchImóveis</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f4;color:#1a1a1a}
    .topbar{background:#fff;border-bottom:1px solid #e5e7eb;padding:16px 24px}
    .logo{color:#FF385C;font-size:20px;font-weight:700}
    .container{max-width:560px;margin:40px auto;padding:0 20px}
    .card{background:#fff;border-radius:16px;padding:32px;border:0.5px solid rgba(0,0,0,.08);text-align:center}
    .icon{font-size:52px;margin-bottom:16px}
    h1{font-size:20px;font-weight:600;margin-bottom:8px;color:#111}
    .sub{color:#6b7280;font-size:14px;line-height:1.6;max-width:380px;margin:0 auto}
    .info{background:#f9fafb;border-radius:10px;padding:16px;margin-top:20px;text-align:left}
    .info-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f3f4f6;font-size:13px}
    .info-row:last-child{border:none}
    .info-label{color:#9ca3af}
    .info-val{font-weight:500;color:#111}
    .footer{text-align:center;font-size:11px;color:#d1d5db;margin-top:24px}
  </style>
</head>
<body>
  <div class="topbar"><span class="logo">MatchImóveis</span></div>
  <div class="container">
    <div class="card">
      <% if(status==='confirmado'){ %>
        <div class="icon">🎉</div>
        <h1>Presença confirmada!</h1>
        <p class="sub">Ótimo! Você receberá um lembrete antes da visita. Até lá!</p>
      <% } else if(status==='recusado'){ %>
        <div class="icon">😔</div>
        <h1>Tudo bem!</h1>
        <p class="sub">Quando quiser ver outros imóveis ou remarcar, é só falar com o corretor.</p>
      <% } else if(status==='remarcado'){ %>
        <div class="icon">📅</div>
        <h1>Nova data solicitada!</h1>
        <p class="sub">Sua solicitação foi registrada. O corretor irá confirmar a nova data em breve.</p>
      <% } %>
      <div class="info">
        <div class="info-row"><span class="info-label">Imóvel</span><span class="info-val"><%= visita.imovelTitulo||visita.imovelBairro||'—' %></span></div>
        <div class="info-row"><span class="info-label">Data</span><span class="info-val"><%= visita.dataVisita||'—' %></span></div>
        <% if(visita.horaVisita){ %><div class="info-row"><span class="info-label">Horário</span><span class="info-val"><%= visita.horaVisita %></span></div><% } %>
      </div>
    </div>
    <p class="footer">MatchImóveis · Assistente imobiliário com memória</p>
  </div>
</body>
</html>
