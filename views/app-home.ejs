<%- include("partials/app-shell",{active:"home",title:"Dashboard",subtitle:"",user:user}) %>

<style>
.dash-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px}
.kpi{background:#fff;border:1px solid #E5E5E5;border-radius:14px;padding:18px;position:relative;overflow:hidden}
.kpi-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:#6B6B6B;margin-bottom:8px}
.kpi-num{font-size:34px;font-weight:700;letter-spacing:-1.5px;line-height:1;color:#1A1A1A}
.kpi-sub{font-size:12px;color:#9B9B9B;margin-top:5px}
.kpi-icon{position:absolute;right:16px;top:16px;font-size:20px;opacity:.12}
.dash-row{display:grid;grid-template-columns:1.4fr 1fr;gap:12px;margin-bottom:16px}
.section-title{font-size:13px;font-weight:600;color:#1A1A1A;margin-bottom:14px;display:flex;align-items:center;justify-content:space-between}
.section-title a{font-size:12px;font-weight:500;color:#FF385C;text-decoration:none}
.feed{display:flex;flex-direction:column;gap:0}
.feed-item{display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid #F5F5F5}
.feed-item:last-child{border-bottom:none}
.feed-dot{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;background:#F5F5F5}
.feed-content{flex:1;min-width:0}
.feed-nome{font-size:13px;font-weight:600;color:#1A1A1A;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.feed-desc{font-size:12px;color:#6B6B6B}
.rate-wrap{display:flex;flex-direction:column;gap:14px}
.rate-item{display:flex;flex-direction:column;gap:5px}
.rate-label{display:flex;justify-content:space-between;font-size:12px;color:#6B6B6B}
.rate-bar{height:5px;background:#F0F0F0;border-radius:3px;overflow:hidden}
.rate-fill{height:5px;background:#1A1A1A;border-radius:3px}
.acoes{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.acao{display:flex;align-items:center;gap:10px;padding:12px;border-radius:10px;border:1px solid #E5E5E5;background:#fff;text-decoration:none;color:#1A1A1A;transition:all .15s}
.acao:hover{border-color:#FF385C;background:#FFF5F6}
.acao-icon{font-size:18px}
.acao-text strong{display:block;font-size:13px;font-weight:600}
.acao-text span{font-size:11px;color:#6B6B6B}
.tag-match{background:#F5F5F5;color:#6B6B6B;padding:3px 10px;border-radius:20px;font-size:11px}
.tag-com-match{background:#FFF1F2;color:#FF385C;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.live-dot{display:inline-block;width:6px;height:6px;background:#1A1A1A;border-radius:50%;animation:pulse 2s infinite;margin-right:6px}
</style>

<div class="dash-grid">
  <div class="kpi">
    <div class="kpi-icon">🏠</div>
    <div class="kpi-label">Imóveis na carteira</div>
    <div class="kpi-num"><%= stats.imoveisAtivos %></div>
    <div class="kpi-sub">Base ativa</div>
  </div>
  <div class="kpi">
    <div class="kpi-icon">🎯</div>
    <div class="kpi-label">Matches gerados</div>
    <div class="kpi-num"><%= stats.matchesGerados %></div>
    <div class="kpi-sub"><%= stats.comMatch %> leads com match</div>
  </div>
  <div class="kpi">
    <div class="kpi-icon">👥</div>
    <div class="kpi-label">Total de leads</div>
    <div class="kpi-num"><%= stats.leadsNovos %></div>
    <div class="kpi-sub">Taxa de match: <%= stats.taxaMatch %>%</div>
  </div>
  <div class="kpi">
    <div class="kpi-icon">📅</div>
    <div class="kpi-label">Visitas agendadas</div>
    <div class="kpi-num"><%= stats.visitasAgendadas %></div>
    <div class="kpi-sub"><%= stats.visitasHoje %> hoje</div>
  </div>
</div>

<div class="dash-row">
  <div class="card" style="margin:0">
    <div class="section-title">
      <span><span class="live-dot"></span>Atividade recente</span>
      <a href="/app/leads">Ver todos</a>
    </div>
    <div class="feed">
      <% if(!recentes || !recentes.length) { %>
        <p style="color:#9B9B9B;font-size:13px;text-align:center;padding:24px 0">Nenhuma atividade ainda</p>
      <% } else { %>
        <% recentes.forEach(function(l) {
          var temMatch = l.matches && l.matches.length > 0;
          var origin = l.origin || {};
          var bairro = origin.bairro || l.bairro || '-';
          var tipo = origin.tipo || l.tipo || '';
          var valor = origin.valor_imovel || l.valor_imovel || 0;
        %>
        <div class="feed-item">
          <div class="feed-dot"><%= temMatch ? '🎯' : '👤' %></div>
          <div class="feed-content">
            <div class="feed-nome"><%= l.nome || l.clientName || 'Lead' %></div>
            <div class="feed-desc"><%= bairro %><% if(tipo){ %> · <%= tipo %><% } %><% if(valor){ %> · R$ <%= Number(valor).toLocaleString('pt-BR') %><% } %></div>
          </div>
          <div>
            <% if(temMatch) { %>
              <span class="tag-com-match"><%= l.matches.length %> match</span>
            <% } else { %>
              <span class="tag-match">sem match</span>
            <% } %>
          </div>
        </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <div style="display:flex;flex-direction:column;gap:12px">
    <div class="card" style="margin:0">
      <div class="section-title"><span>Métricas</span></div>
      <div class="rate-wrap">
        <div class="rate-item">
          <div class="rate-label"><span>Taxa de match</span><span><%= stats.taxaMatch %>%</span></div>
          <div class="rate-bar"><div class="rate-fill" style="width:<%= stats.taxaMatch %>%"></div></div>
        </div>
        <div class="rate-item">
          <% var pctMatch = stats.leadsNovos > 0 ? Math.round(stats.comMatch/stats.leadsNovos*100) : 0; %>
          <div class="rate-label"><span>Leads com match</span><span><%= stats.comMatch %> / <%= stats.leadsNovos %></span></div>
          <div class="rate-bar"><div class="rate-fill" style="width:<%= pctMatch %>%"></div></div>
        </div>
        <div class="rate-item">
          <% var pctVisitas = stats.visitasAgendadas > 0 ? Math.round(stats.visitasHoje/stats.visitasAgendadas*100) : 0; %>
          <div class="rate-label"><span>Visitas hoje</span><span><%= stats.visitasHoje %></span></div>
          <div class="rate-bar"><div class="rate-fill" style="width:<%= pctVisitas %>%"></div></div>
        </div>
      </div>
    </div>

    <div class="card" style="margin:0">
      <div class="section-title"><span>Ações rápidas</span></div>
      <div class="acoes">
        <a href="/app/leads" class="acao">
          <span class="acao-icon">👥</span>
          <div class="acao-text"><strong>Leads</strong><span>Gerenciar</span></div>
        </a>
        <a href="/app/imoveis" class="acao">
          <span class="acao-icon">🏠</span>
          <div class="acao-text"><strong>Imóveis</strong><span>Carteira</span></div>
        </a>
        <a href="/app/cadastro" class="acao">
          <span class="acao-icon">➕</span>
          <div class="acao-text"><strong>Cadastrar</strong><span>Novo imóvel</span></div>
        </a>
        <a href="/app/visitas" class="acao">
          <span class="acao-icon">📅</span>
          <div class="acao-text"><strong>Visitas</strong><span>Agenda</span></div>
        </a>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
  <div class="card" style="margin:0">
    <div class="section-title"><span>Visitas por status</span></div>
    <canvas id="chartVisitas" height="200"></canvas>
  </div>
  <div class="card" style="margin:0">
    <div class="section-title"><span>Leads por status</span></div>
    <canvas id="chartLeads" height="200"></canvas>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
  <div class="card" style="margin:0">
    <div class="section-title"><span>Imóveis por tipo</span></div>
    <canvas id="chartImoveisTipo" height="200"></canvas>
  </div>
  <div class="card" style="margin:0">
    <div class="section-title"><span>Imóveis por bairro</span></div>
    <canvas id="chartImoveisBairro" height="200"></canvas>
  </div>
</div>

<div style="margin-bottom:16px">
  <div class="card" style="margin:0">
    <div class="section-title"><span>Leads por bairro</span></div>
    <canvas id="chartLeadsBairro" height="120"></canvas>
  </div>
</div>

<script>
const COLORS=['#1A1A1A','#6B6B6B','#9B9B9B','#C5C5C5','#E5E5E5','#FF385C','#555','#333'];

function makeDonut(id,data){
  const labels=Object.keys(data),vals=Object.values(data);
  new Chart(document.getElementById(id),{
    type:'doughnut',
    data:{labels,datasets:[{data:vals,backgroundColor:COLORS,borderWidth:2,borderColor:'#fff'}]},
    options:{plugins:{legend:{position:'right',labels:{font:{size:11},color:'#6B6B6B'}}},cutout:'65%'}
  });
}
function makeBar(id,data,horizontal){
  const labels=Object.keys(data),vals=Object.values(data);
  new Chart(document.getElementById(id),{
    type:'bar',
    data:{labels,datasets:[{data:vals,backgroundColor:'#1A1A1A',borderRadius:4,borderSkipped:false}]},
    options:{indexAxis:horizontal?'y':'x',plugins:{legend:{display:false}},scales:{x:{grid:{display:false},ticks:{color:'#6B6B6B',font:{size:10}}},y:{grid:{color:'#F5F5F5'},ticks:{color:'#6B6B6B',font:{size:10}}}}}
  });
}
const visitasStatus=<%- graficoVisitasStatus %>;
const leadsStatus=<%- graficoLeadsStatus %>;
const imoveisTipo=<%- graficoImoveisTipo %>;
const imoveisBairro=<%- graficoImoveisBairro %>;
const leadsBairro=<%- graficoLeadsBairro %>;
makeDonut('chartVisitas',visitasStatus);
makeDonut('chartLeads',{'Extraído OK':leadsStatus.ok||0,'Incompleto':leadsStatus.incompleto||0,'Sem status':leadsStatus.semStatus||0});
makeDonut('chartImoveisTipo',imoveisTipo);
makeBar('chartImoveisBairro',imoveisBairro,true);
makeBar('chartLeadsBairro',leadsBairro,true);
</script>
<%- include('partials/app-end') %>
