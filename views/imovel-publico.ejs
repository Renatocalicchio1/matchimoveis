<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= imovel.titulo || imovel.tipo + ' em ' + imovel.bairro %> • MatchImóveis</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f5;color:#222}
    header{background:#fff;border-bottom:1px solid #e5e7eb;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
    .logo{font-weight:900;font-size:20px;color:#FF385C;letter-spacing:-0.5px}
    .container{max-width:980px;margin:0 auto;padding:24px 16px}
    .detalhe-hero{display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:240px 240px;gap:4px;border-radius:16px;overflow:hidden;margin-bottom:28px;cursor:pointer}
    .detalhe-hero img{width:100%;height:100%;object-fit:cover;transition:opacity .2s}
    .detalhe-hero img:hover{opacity:.92}
    .detalhe-hero img:first-child{grid-row:1/3}
    .hero-mais{position:relative}
    .hero-mais img{width:100%;height:100%;object-fit:cover}
    .hero-mais-overlay{position:absolute;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;color:#fff;font-size:20px;font-weight:700}
    .layout{display:grid;grid-template-columns:1fr 320px;gap:24px}
    .card{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;margin-bottom:16px}
    .badge-tipo{display:inline-block;background:#fee2e2;color:#dc2626;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:10px}
    .spec-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:12px;margin-top:16px}
    .spec-item{background:#f5f5f5;border-radius:12px;padding:14px 10px;text-align:center}
    .spec-icon{font-size:22px;margin-bottom:4px}
    .spec-val{font-weight:700;font-size:16px;color:#222}
    .spec-lbl{font-size:11px;color:#717171;margin-top:2px}
    .info-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f0f0f0;font-size:13px}
    .info-row:last-child{border:none}
    .info-lbl{color:#717171}
    .info-val{font-weight:600;color:#222}
    .cta-card{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;position:sticky;top:80px}
    .btn-cta{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:14px;border-radius:12px;font-weight:700;font-size:15px;text-align:center;text-decoration:none;margin-bottom:10px;border:none;cursor:pointer;transition:opacity .2s}
    .btn-cta:hover{opacity:.88}
    .btn-wpp{background:#25D366;color:#fff}
    .btn-tel{background:#f0f0f0;color:#222}
    .btn-visita{background:#FF385C;color:#fff}
    /* Lightbox */
    #lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:9999;align-items:center;justify-content:center}
    #lightbox.open{display:flex}
    #lb-img{max-width:90vw;max-height:88vh;object-fit:contain;border-radius:8px}
    .lb-btn{position:absolute;background:rgba(255,255,255,.15);border:none;color:#fff;font-size:28px;width:48px;height:48px;border-radius:50%;cursor:pointer;transition:background .2s}
    .lb-btn:hover{background:rgba(255,255,255,.25)}
    @media(max-width:700px){.layout{grid-template-columns:1fr}.detalhe-hero{grid-template-columns:1fr;grid-template-rows:260px}.detalhe-hero img:not(:first-child){display:none}}
  </style>
</head>
<body>

<header>
  <div class="logo">MatchImóveis</div>
  <div style="font-size:13px;color:#717171">Ref. #<%= imovel.idExterno %></div>
</header>

<% if(imovel.fotos && imovel.fotos.length > 0) { %>
<div class="detalhe-hero" id="hero-fotos">
  <img src="<%= imovel.fotos[0] %>" onclick="abrirGaleria(0)">
  <% if(imovel.fotos[1]) { %><img src="<%= imovel.fotos[1] %>" onclick="abrirGaleria(1)"><% } %>
  <% if(imovel.fotos[2]) { %><img src="<%= imovel.fotos[2] %>" onclick="abrirGaleria(2)"><% } %>
  <% if(imovel.fotos[3]) { %><img src="<%= imovel.fotos[3] %>" onclick="abrirGaleria(3)"><% } %>
  <% if(imovel.fotos[4]) { %>
  <div class="hero-mais" onclick="abrirGaleria(4)" style="cursor:pointer">
    <img src="<%= imovel.fotos[4] %>">
    <% if(imovel.fotos.length > 5) { %>
    <div class="hero-mais-overlay">+<%= imovel.fotos.length - 5 %> fotos</div>
    <% } %>
  </div>
  <% } %>
</div>
<% } %>

<!-- LIGHTBOX -->
<div id="lightbox">
  <button class="lb-btn" onclick="fecharLightbox()" style="top:16px;right:20px;font-size:20px">✕</button>
  <button class="lb-btn" onclick="navFoto(-1)" style="left:16px">‹</button>
  <img id="lb-img">
  <button class="lb-btn" onclick="navFoto(1)" style="right:16px">›</button>
  <div id="lb-counter" style="position:absolute;bottom:16px;color:#fff;font-size:14px;opacity:.7"></div>
</div>

<div class="container">
  <div class="layout">

    <%# COLUNA PRINCIPAL %>
    <div>
      <div class="card">
        <span class="badge-tipo"><%= imovel.tipo %></span>
        <div style="display:flex;justify-content:space-between;align-items:start;gap:16px">
          <div>
            <h1 style="font-size:22px;font-weight:800;margin:0 0 6px;line-height:1.3"><%= imovel.titulo || (imovel.tipo + ' em ' + imovel.bairro) %></h1>
            <p style="color:#717171;font-size:14px;margin:0"><% if(imovel.endereco) { %><%= imovel.endereco %> · <% } %><%= imovel.bairro %><% if(imovel.cidade) { %>, <%= imovel.cidade %><% } %></p>
          </div>
          <div style="text-align:right;flex-shrink:0">
            <div style="font-size:26px;font-weight:800;color:#FF385C">R$ <%= Number(imovel.valor_imovel||0).toLocaleString('pt-BR') %></div>
          </div>
        </div>
      </div>

      <div class="card">
        <h3 style="margin:0 0 4px;font-size:15px;font-weight:700">Características</h3>
        <div class="spec-grid">
          <% if(imovel.area_m2) { %><div class="spec-item"><div class="spec-icon">📐</div><div class="spec-val"><%= imovel.area_m2 %>m²</div><div class="spec-lbl">Área</div></div><% } %>
          <% if(imovel.quartos) { %><div class="spec-item"><div class="spec-icon">🛏</div><div class="spec-val"><%= imovel.quartos %></div><div class="spec-lbl">Quartos</div></div><% } %>
          <% if(imovel.suites) { %><div class="spec-item"><div class="spec-icon">⭐</div><div class="spec-val"><%= imovel.suites %></div><div class="spec-lbl">Suítes</div></div><% } %>
          <% if(imovel.banheiros) { %><div class="spec-item"><div class="spec-icon">🚿</div><div class="spec-val"><%= imovel.banheiros %></div><div class="spec-lbl">Banheiros</div></div><% } %>
          <% if(imovel.vagas) { %><div class="spec-item"><div class="spec-icon">🚗</div><div class="spec-val"><%= imovel.vagas %></div><div class="spec-lbl">Vagas</div></div><% } %>
        </div>
      </div>

      <% if(imovel.descricao) { %>
      <div class="card">
        <h3 style="margin:0 0 12px;font-size:15px;font-weight:700">Descrição</h3>
        <p style="color:#444;line-height:1.8;font-size:14px;white-space:pre-line;margin:0"><%= imovel.descricao %></p>
      </div>
      <% } %>


    </div>

    <%# COLUNA LATERAL %>
    <div>
            <div class="card">
        <div style="font-size:11px;font-weight:700;color:#717171;text-transform:uppercase;letter-spacing:.8px;margin-bottom:12px">Informações</div>
        <div class="info-row"><span class="info-lbl">Valor</span><span class="info-val" style="color:#FF385C;font-size:15px">R$ <%= Number(imovel.valor_imovel||0).toLocaleString('pt-BR') %></span></div>
        <% if(imovel.condominio > 0) { %><div class="info-row"><span class="info-lbl">Condomínio</span><span class="info-val">R$ <%= Number(imovel.condominio).toLocaleString('pt-BR') %>/mês</span></div><% } %>
        <% if(imovel.transacao) { %><div class="info-row"><span class="info-lbl">Operação</span><span class="info-val"><%= imovel.transacao %></span></div><% } %>
        <% if(imovel.cep) { %><div class="info-row"><span class="info-lbl">CEP</span><span class="info-val"><%= imovel.cep %></span></div><% } %>
        <% if(imovel.iptu > 0) { %><div class="info-row"><span class="info-lbl">IPTU</span><span class="info-val">R$ <%= Number(imovel.iptu).toLocaleString('pt-BR') %>/ano</span></div><% } %>
        <% if(imovel.andar) { %><div class="info-row"><span class="info-lbl">Andar</span><span class="info-val"><%= imovel.andar %>º</span></div><% } %>
      </div>
      <div class="cta-card">
        <div style="font-size:15px;font-weight:700;margin-bottom:4px">Interessado neste imóvel?</div>
        <div style="font-size:13px;color:#717171;margin-bottom:20px">Fale com um de nossos consultores</div>
        <a href="#" onclick="abrirModal(this.dataset.href,'whatsapp');return false;" data-href="https://wa.me/55<%= corretor.celular %>?text=<%= encodeURIComponent('Olá! Tenho interesse no imóvel: ' + (imovel.titulo || imovel.tipo + ' em ' + imovel.bairro) + ' - R$ ' + Number(imovel.valor_imovel||0).toLocaleString('pt-BR')) %>" class="btn-cta btn-wpp">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Falar pelo WhatsApp
        </a>
        <a href="#" onclick="abrirModal(this.dataset.href);return false;" data-href="https://wa.me/55<%= corretor.celular %>?text=<%= encodeURIComponent('Olá! Gostaria de solicitar uma visita para o imóvel: ' + (imovel.titulo || imovel.tipo + ' em ' + imovel.bairro) + ' - R$ ' + Number(imovel.valor_imovel||0).toLocaleString('pt-BR')) %>" class="btn-cta btn-visita">
          📅 Solicitar visita
        </a>
        <a href="tel:+55<%= corretor.celular %>" class="btn-cta btn-tel">
          📞 Ligar agora
        </a>
        <div style="font-size:11px;color:#999;text-align:center;margin-top:8px">MatchImóveis · Consultoria Imobiliária</div>
      </div>
    </div>

  </div>
</div>


<!-- MODAL CONTATO -->
<div id="modal-contato" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9998;align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:20px;padding:32px;max-width:400px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.3)">

    <div id="modal-step-contato">
      <h3 style="font-size:20px;font-weight:800;margin-bottom:6px">Quase lá! 👋</h3>
      <p style="color:#717171;font-size:14px;margin-bottom:20px">Nos informe seus dados para continuar</p>

      <div style="margin-bottom:14px">
        <label style="font-size:13px;font-weight:600;color:#222;display:block;margin-bottom:6px">Seu nome</label>
        <input id="modal-nome" type="text" placeholder="Nome completo" style="width:100%;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;outline:none">
      </div>

      <div style="margin-bottom:20px">
        <label style="font-size:13px;font-weight:600;color:#222;display:block;margin-bottom:6px">Seu celular</label>
        <input id="modal-celular" type="tel" placeholder="(11) 99999-9999" style="width:100%;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;outline:none">
      </div>

      <button onclick="confirmarContato()" style="width:100%;padding:14px;background:#FF385C;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;margin-bottom:10px">Continuar →</button>
      <button onclick="fecharModal()" style="width:100%;padding:10px;background:#f5f5f5;color:#717171;border:none;border-radius:12px;font-size:14px;cursor:pointer">Cancelar</button>
    </div>

    <div id="modal-step-horario" style="display:none">
      <h3 style="font-size:20px;font-weight:800;margin-bottom:6px">Escolha sua visita 📅</h3>
      <p style="color:#717171;font-size:14px;margin-bottom:20px">Selecione a data e o horário que você pode visitar.</p>

      <div style="margin-bottom:14px">
        <label style="font-size:13px;font-weight:600;color:#222;display:block;margin-bottom:6px">Data da visita</label>
        <input id="modal-data" type="date" style="width:100%;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;outline:none">
      </div>

      <div style="margin-bottom:20px">
        <label style="font-size:13px;font-weight:600;color:#222;display:block;margin-bottom:6px">Horário</label>
        <input id="modal-hora" type="time" style="width:100%;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;outline:none">
      </div>

      <button onclick="confirmarVisita()" style="width:100%;padding:14px;background:#FF385C;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;margin-bottom:10px">Confirmar visita</button>
      <button onclick="voltarContato()" style="width:100%;padding:10px;background:#f5f5f5;color:#717171;border:none;border-radius:12px;font-size:14px;cursor:pointer">Voltar</button>
    </div>

  </div>
</div>

<script>
const fotos = <%- JSON.stringify(imovel.fotos || []) %>;
const imovelId = '<%= imovel.idExterno %>';
const imovelTitulo = '<%= (imovel.titulo || imovel.tipo + " em " + imovel.bairro).replace(/'/g, "") %>';
let linkDestino = '';
let modalTipo = 'visita';

function abrirModal(link, tipo = 'visita') {
  linkDestino = link;
  modalTipo = tipo;
  document.getElementById('modal-contato').style.display = 'flex';
  document.getElementById('modal-step-contato').style.display = 'block';
  document.getElementById('modal-step-horario').style.display = 'none';
  document.getElementById('modal-nome').focus();
}

function fecharModal() {
  document.getElementById('modal-contato').style.display = 'none';
}

function confirmarContato() {
  const nome = document.getElementById('modal-nome').value.trim();
  const celular = document.getElementById('modal-celular').value.trim();

  if (!nome || !celular) {
    alert('Preencha nome e celular para continuar');
    return;
  }

  if (modalTipo === 'whatsapp') {
    fetch('/api/lead-interesse', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nome, celular, imovelId, imovelTitulo, canal: 'WhatsApp' })
    }).catch(() => {});

    window.open(linkDestino, '_blank');
    fecharModal();
    return;
  }

  document.getElementById('modal-step-contato').style.display = 'none';
  document.getElementById('modal-step-horario').style.display = 'block';
}

function voltarContato(){
  document.getElementById('modal-step-contato').style.display = 'block';
  document.getElementById('modal-step-horario').style.display = 'none';
}

function confirmarVisita() {
  const nome = document.getElementById('modal-nome').value.trim();
  const celular = document.getElementById('modal-celular').value.trim();
  const data = document.getElementById('modal-data').value;
  const hora = document.getElementById('modal-hora').value;

  if (!data || !hora) {
    alert('Escolha a data e o horário da visita');
    return;
  }

  fetch('/api/lead-interesse', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ nome, celular, imovelId, imovelTitulo, dataVisita: data, horaVisita: hora, acao: 'solicitar_visita', visita: 'true' })
  }).catch(() => {});

  alert('Visita solicitada com sucesso!');
  fecharModal();
}
let fotoAtual = 0;
function abrirGaleria(idx) { fotoAtual=idx; document.getElementById('lightbox').classList.add('open'); atualizarLb(); }
function fecharLightbox() { document.getElementById('lightbox').classList.remove('open'); }
function navFoto(dir) { fotoAtual=(fotoAtual+dir+fotos.length)%fotos.length; atualizarLb(); }
function atualizarLb() { document.getElementById('lb-img').src=fotos[fotoAtual]; document.getElementById('lb-counter').textContent=(fotoAtual+1)+' / '+fotos.length; }
document.getElementById('lightbox').addEventListener('click',e=>{ if(e.target===document.getElementById('lightbox')) fecharLightbox(); });
document.addEventListener('keydown',e=>{ if(e.key==='Escape') fecharLightbox(); if(e.key==='ArrowLeft') navFoto(-1); if(e.key==='ArrowRight') navFoto(1); });
</script>
</body>
</html>
