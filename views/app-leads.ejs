<%- include('partials/app-shell',{active:'leads',title:'Leads',subtitle:'Leads importados e perfil do imóvel extraído da URL.',perfil:'corretor',user:user}) %>

<div class="grid-4">
  <div class="card">
    <p style="color:#717171;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.5px">Total</p>
    <div class="stat-num"><%= leads.length %></div>
    <p style="font-size:12px;color:#717171">Leads na conta</p>
  </div>
  <div class="card">
    <p style="color:#717171;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.5px">Extraídos</p>
    <div class="stat-num"><%= leads.filter(l => l.origin && (l.origin.extractionStatus === 'ok' || l.origin.extractionStatus === 'bairro_invalido')).length %></div>
    <p style="font-size:12px;color:#717171">Perfil capturado</p>
  </div>
  <div class="card">
    <p style="color:#717171;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.5px">Com match</p>
    <div class="stat-num"><%= leads.filter(l => l.matches && l.matches.length).length %></div>
    <p style="font-size:12px;color:#717171">Oportunidades</p>
  </div>
  <div class="card">
    <p style="color:#717171;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.5px">Pendentes</p>
    <div class="stat-num"><%= leads.filter(l => !l.origin).length %></div>
    <p style="font-size:12px;color:#717171">Aguardando extração</p>
  </div>
</div>

<div class="card">
  <h3>Importar leads</h3>
  <p style="margin:6px 0 16px">Suba Excel ou CSV para importar, remover duplicados e extrair o perfil dos imóveis pela URL.</p>
  <form method="POST" action="/process" enctype="multipart/form-data" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
    <input type="file" name="file" accept=".xlsx,.xls,.csv" required style="max-width:300px">
    <button class="btn btn-primary" type="submit">⬆️ Importar</button>
  </form>
</div>

<div class="card">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px">
    <h3 style="margin:0">Lista de leads</h3>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <input id="filtro" placeholder="Buscar cliente, bairro, ID..." style="width:240px">
      <select id="statusFiltro" style="width:160px">
        <option value="">Todos os status</option>
        <option value="extraído">Extraído</option>
        <option value="processando">Processando</option>
        <option value="erro">Erro</option>
      </select>
      <select id="scoreFiltro" style="width:130px">
        <option value="">Score Lead</option>
        <option value="50">50+</option>
        <option value="70">70+</option>
        <option value="90">90+</option>
      </select>
    </div>
  </div>

  <% if (!leads.length) { %>
    <div style="text-align:center;padding:48px;color:#717171">
      <div style="font-size:40px;margin-bottom:12px">👥</div>
      <p>Nenhum lead encontrado. Importe uma planilha para começar.</p>
    </div>
  <% } else { %>
  <div style="overflow-x:auto">
    <table>
      <thead>
        <tr>
          <th>Cliente</th>
          <th>Contato</th>
          <th>Status</th>
          <th>Score</th>
          <th>Tipo</th>
          <th>Bairro</th>
          <th>Cidade</th>
          <th>Valor</th>
          <th>Área</th>
          <th>Qtos</th>
          <th>Matches</th>
          <th>URL</th>
        </tr>
      </thead>
      <tbody>
        <% leads.forEach((item) => {
          const origin = item.origin || {};
          const status = origin.extractionStatus === 'ok' ? 'Extraído'
            : (origin.extractionStatus === 'bairro_invalido' ? 'Sem bairro'
            : (origin.extractionStatus || 'Pendente'));
          let leadScore = 0;
          if (item.matches && item.matches.length) {
            leadScore += 50;
            leadScore += Math.min(item.matches.length * 5, 25);
            leadScore += Math.min(((item.matches[0] && item.matches[0].score) || 0) / 2, 25);
          }
          const scoreVal = Math.round(leadScore);
          const badgeClass = scoreVal >= 70 ? 'badge-green' : scoreVal >= 40 ? 'badge-blue' : 'badge-gray';
          const statusClass = status === 'Extraído' ? 'badge-green' : status === 'Pendente' ? 'badge-gray' : 'badge-red';
        %>
        <tr>
          <td style="font-weight:600"><%= item.nome || item.clientName || '-' %></td>
          <td style="color:#717171"><%= item.contato || item.telefone || '-' %></td>
          <td><span class="badge <%= statusClass %>"><%= status %></span></td>
          <td><span class="badge <%= badgeClass %>"><%= scoreVal %></span></td>
          <td><%= origin.tipo || '-' %></td>
          <td><%= origin.bairro || item.bairro || '-' %></td>
          <td><%= origin.cidade || item.cidade || '-' %></td>
          <td><%= origin.valor_imovel ? 'R$ ' + Number(origin.valor_imovel).toLocaleString('pt-BR') : '-' %></td>
          <td><%= origin.area_m2 ? origin.area_m2 + ' m²' : '-' %></td>
          <td><%= origin.quartos || '-' %></td>
          <td>
            <% if(item.matches && item.matches.length) { %>
              <span class="badge badge-green"><%= item.matches.length %> match<%= item.matches.length > 1 ? 'es' : '' %></span>
            <% } else { %>
              <span style="color:#aaa">—</span>
            <% } %>
          </td>
          <td>
            <% if(item.url) { %>
              <a href="<%= item.url %>" target="_blank" class="btn btn-ghost" style="padding:4px 8px;font-size:11px">Abrir ↗</a>
            <% } else { %>
              <span style="color:#aaa">—</span>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<script>
const filtro = document.getElementById('filtro');
const statusFiltro = document.getElementById('statusFiltro');
const scoreFiltro = document.getElementById('scoreFiltro');
function filtrar(){
  const texto = (filtro.value||'').toLowerCase();
  const status = (statusFiltro.value||'').toLowerCase();
  const scoreMin = Number(scoreFiltro.value||0);
  document.querySelectorAll('tbody tr').forEach(tr=>{
    const t = tr.innerText.toLowerCase();
    const nums = tr.innerText.match(/\d+/g)||[];
    const score = Math.max(...nums.map(Number).filter(n=>n<=100));
    let show = true;
    if(texto && !t.includes(texto)) show=false;
    if(status && !t.includes(status)) show=false;
    if(scoreMin && score < scoreMin) show=false;
    tr.style.display = show?'':'none';
  });
}
if(filtro) filtro.oninput = filtrar;
if(statusFiltro) statusFiltro.onchange = filtrar;
if(scoreFiltro) scoreFiltro.onchange = filtrar;
</script>

<%- include('partials/app-end') %>
