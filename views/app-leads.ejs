<%- include('partials/app-shell', {active:'leads',title:'Leads',subtitle:'Gerencie e acompanhe seus clientes em busca de imóveis.',user:user}) %>
<style>main{overflow-x:hidden!important} .page-content{overflow-x:hidden!important}</style>

<style>
/* ── KPIs ── */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.kpi-sm{background:#fff;border:0.5px solid rgba(0,0,0,.08);border-radius:12px;padding:14px 16px;position:relative;overflow:hidden}
.kpi-bar{position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:12px 0 0 12px}
.kpi-label{font-size:10px;font-weight:500;color:#9ca3af;text-transform:uppercase;letter-spacing:.04em;margin-bottom:4px}
.kpi-val{font-size:24px;font-weight:600;color:#111827;letter-spacing:-1px}

/* ── Filtros ── */
.fi-bar{background:#fff;border:0.5px solid rgba(0,0,0,.08);border-radius:14px;padding:14px;margin-bottom:14px}
.fi-search-row{display:flex;gap:8px;margin-bottom:10px}
.fi-input{flex:1;padding:8px 12px;border:0.5px solid rgba(0,0,0,.12);border-radius:8px;font-size:13px;outline:none;color:#111827}
.fi-input:focus{border-color:rgba(0,0,0,.3)}
.fi-btn{padding:8px 14px;border:0.5px solid rgba(0,0,0,.12);border-radius:8px;font-size:12px;font-weight:500;cursor:pointer;background:#fff;color:#374151;white-space:nowrap}
.fi-btn:hover{background:#f9fafb}
.fi-btn-dark{background:#111827;color:#fff;border-color:#111827}
.fi-btn-dark:hover{background:#1f2937}
.chips-row{display:flex;gap:5px;flex-wrap:wrap;align-items:center;margin-bottom:6px}
.chips-lbl{font-size:10px;font-weight:500;color:#9ca3af;text-transform:uppercase;letter-spacing:.04em;white-space:nowrap;min-width:60px}
.fchip{padding:4px 12px;border-radius:999px;font-size:11px;font-weight:500;border:0.5px solid rgba(0,0,0,.1);background:#fff;cursor:pointer;color:#374151;transition:all .1s}
.fchip.on{background:#111827;color:#fff;border-color:#111827}

/* ── KANBAN ── */
.kanban-wrap{display:flex;gap:10px;overflow-x:auto;padding-bottom:16px;align-items:flex-start;-webkit-overflow-scrolling:touch}
.kanban-wrap::-webkit-scrollbar{height:5px}
.kanban-wrap::-webkit-scrollbar-thumb{background:#e5e7eb;border-radius:4px}
.kanban-col{flex:0 0 260px;min-width:260px;max-width:260px;background:#f9fafb;border:0.5px solid rgba(0,0,0,.06);border-radius:14px;padding:12px;min-height:300px;max-height:calc(100vh - 300px);overflow-y:auto}
.kanban-col-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;padding-bottom:8px;border-bottom:0.5px solid rgba(0,0,0,.06)}
.kanban-col-title{font-size:12px;font-weight:500;color:#374151}
.kanban-col-count{font-size:11px;font-weight:500;color:#9ca3af;background:#fff;border:0.5px solid rgba(0,0,0,.08);border-radius:999px;padding:2px 8px}
.kanban-col-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}

/* ── Cards ── */
@keyframes flagPulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.2);opacity:.7}}
.btn-classificar-flag{background:#fff8f0!important;color:#f97316!important;border-color:#fed7aa!important;animation:flagPulse 2s infinite;font-size:13px!important;padding:3px 7px!important}
.btn-classificar-flag:hover{animation:none;transform:scale(1.1)}
.lead-card{background:#fff;border:0.5px solid rgba(0,0,0,.08);border-radius:12px;padding:12px;margin-bottom:8px;cursor:pointer;transition:box-shadow .15s;position:relative}
.lead-card:hover{box-shadow:0 2px 12px rgba(0,0,0,.08)}
.lead-card.urg-alta{border-left:2px solid #ef4444}
.lead-card.urg-media{border-left:2px solid #f59e0b}
@keyframes pulso{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.2)}50%{box-shadow:0 0 0 6px rgba(239,68,68,0)}}
.lead-card.urg-alta{animation:pulso 2.5s infinite}

.acao-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:999px;font-size:10px;font-weight:500;margin-bottom:8px;border:0.5px solid transparent}
.lead-nome{font-size:13px;font-weight:500;color:#111827;text-decoration:none;display:block;margin-bottom:2px}
.lead-nome:hover{color:#6366f1}
.lead-tel{font-size:11px;color:#9ca3af;margin-bottom:6px}

.score-row{display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:6px}
.score-bar{width:40px;height:3px;background:#f3f4f6;border-radius:3px;overflow:hidden}
.score-fill{height:3px;border-radius:3px}
.temp-pill{padding:2px 8px;border-radius:999px;font-size:10px;font-weight:500}
.match-pill{font-size:10px;font-weight:500;color:#15803d;background:#f0fdf4;border-radius:5px;padding:2px 7px}

.perfil-row{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:6px}
.perfil-tag{font-size:10px;color:#6b7280;background:#f9fafb;border:0.5px solid rgba(0,0,0,.08);border-radius:5px;padding:1px 6px}

.lead-btns{display:flex;gap:5px;padding-top:8px;border-top:0.5px solid rgba(0,0,0,.06);flex-wrap:wrap}
.lb{font-size:11px;padding:5px 10px;border-radius:7px;text-decoration:none;font-weight:500;border:0.5px solid rgba(0,0,0,.1);color:#374151;background:#fff;cursor:pointer;transition:all .1s}
.lb:hover{background:#f9fafb}
.lb.wa{color:#15803d;border-color:#86efac}
.lb.wa:hover{background:#f0fdf4}
.lb.prim{color:#6366f1;border-color:#c7d2fe}
.lb.prim:hover{background:#eef2ff}
.lb.dark{background:#111827;color:#fff;border-color:#111827}
.lb.dark:hover{background:#1f2937}
.lb.danger{color:#dc2626;border-color:#fca5a5}
.confirm-box{display:none;padding:8px 10px;background:#fef2f2;border-radius:8px;border:0.5px solid #fca5a5;margin-top:6px}

.empty-col{text-align:center;padding:24px 12px;color:#d1d5db;font-size:12px}
</style>

<!-- KPIs -->
<div class="kpi-row">
  <div class="kpi-sm"><div class="kpi-bar" style="background:#6366f1"></div><div class="kpi-label">Total</div><div class="kpi-val"><%= stats.totalLeads %></div></div>
  <div class="kpi-sm"><div class="kpi-bar" style="background:#22c55e"></div><div class="kpi-label">Com match</div><div class="kpi-val" style="color:#15803d"><%= stats.comMatch %></div></div>
  <div class="kpi-sm"><div class="kpi-bar" style="background:#9ca3af"></div><div class="kpi-label">Sem match</div><div class="kpi-val"><%= stats.pendentes %></div></div>
  <div class="kpi-sm"><div class="kpi-bar" style="background:#7c3aed"></div><div class="kpi-label">Matches IA</div><div class="kpi-val" style="color:#7c3aed"><%= stats.totalMatches %></div></div>
</div>

<!-- Filtros -->
<div class="fi-bar">
  <div class="fi-search-row">
    <input class="fi-input" id="filter-search" placeholder="Buscar por nome, celular, bairro..." oninput="aplicarFiltros()">
    <button class="fi-btn" onclick="toggleFAdv()">Filtros</button>
    <button class="fi-btn fi-btn-dark" onclick="rodarMatchBase()" id="btn-match-base">Match IA</button>
    <button class="fi-btn fi-btn-dark" onclick="abrirModalImportarLeads()">+ Importar</button>
  </div>
  <div class="chips-row">
    <span class="chips-lbl">Temperatura</span>
    <button class="fchip on" onclick="setChip('temp','',this)">Todas</button>
    <button class="fchip" onclick="setChip('temp','quente',this)" style="color:#dc2626;border-color:#fca5a5">Quente</button>
    <button class="fchip" onclick="setChip('temp','morno',this)" style="color:#d97706;border-color:#fcd34d">Morno</button>
    <button class="fchip" onclick="setChip('temp','frio',this)" style="color:#2563eb;border-color:#bfdbfe">Frio</button>
  </div>
  <div class="chips-row">
    <span class="chips-lbl">Origem</span>
    <button class="fchip on" onclick="setChip('origem','',this)">Todas</button>
    <button class="fchip" onclick="setChip('origem','whatsapp',this)">WhatsApp</button>
    <button class="fchip" onclick="setChip('origem','pagina_externa_imovel',this)">Página</button>
    <button class="fchip" onclick="setChip('origem','manual',this)">Manual</button>
  </div>
  <div id="fadv" style="display:none;margin-top:10px;padding-top:10px;border-top:0.5px solid rgba(0,0,0,.06)">
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px">
      <div><label style="font-size:11px;color:#6b7280;display:block;margin-bottom:3px">Score mínimo</label><select id="filter-score" onchange="aplicarFiltros()" style="width:100%;padding:7px;border:0.5px solid rgba(0,0,0,.12);border-radius:7px;font-size:12px"><option value="0">Todos</option><option value="20">20+</option><option value="40">40+</option><option value="60">60+</option><option value="80">80+</option></select></div>
      <div><label style="font-size:11px;color:#6b7280;display:block;margin-bottom:3px">Tipo buscado</label><select id="filter-tipo-lead" onchange="aplicarFiltros()" style="width:100%;padding:7px;border:0.5px solid rgba(0,0,0,.12);border-radius:7px;font-size:12px"><option value="">Todos</option><option value="apartamento">Apartamento</option><option value="casa">Casa</option><option value="studio">Studio</option><option value="kitnet">Kitnet</option></select></div>
      <div><label style="font-size:11px;color:#6b7280;display:block;margin-bottom:3px">Intenção</label><select id="filter-intencao" onchange="aplicarFiltros()" style="width:100%;padding:7px;border:0.5px solid rgba(0,0,0,.12);border-radius:7px;font-size:12px"><option value="">Todas</option><option value="comprar">Comprar</option><option value="alugar">Alugar</option></select></div>
    </div>
    <button onclick="limparFiltros()" class="fi-btn" style="margin-top:10px;font-size:12px">Limpar filtros</button>
  </div>
  <div id="filter-counter" style="font-size:11px;color:#9ca3af;margin-top:8px"></div>
</div>

<!-- KANBAN -->
<%
const colunas = [
  { key:'novo',      label:'Novo',           cor:'#9ca3af', dot:'#e5e7eb' },
  { key:'qualificando', label:'Qualificando', cor:'#f59e0b', dot:'#fcd34d' },
  { key:'match',     label:'Com Match',      cor:'#22c55e', dot:'#86efac' },
  { key:'vitrine',   label:'Vitrine Enviada',cor:'#6366f1', dot:'#c7d2fe' },

  { key:'visita',    label:'Visita Solicitada', cor:'#0ea5e9', dot:'#bae6fd' },
  { key:'visitou',   label:'Visitou',         cor:'#8b5cf6', dot:'#c4b5fd' },
  { key:'proposta',  label:'Proposta',        cor:'#f97316', dot:'#fed7aa' },
  { key:'fechado',   label:'Fechado',         cor:'#16a34a', dot:'#86efac' }
];

function getColuna(item) {
  const fase = item.faseFunil || 'novo';
  const mat = (item.matchesAuto||item.matches||[]).length;
  const vitrine = !!item.vitrineEnviada;
  const temVisita = false; // será setado via visitas se necessário
  if (fase === 'decidido') return 'fechado';
  if (item.visitaAgendada) return 'visita';
  if (vitrine) return 'vitrine';
  if (mat > 0) return 'match';
  if (fase === 'qualificado' || (item.perfilIA && item.perfilIA.tipo)) return 'qualificando';
  return 'novo';
}

const leadsPorColuna = {};
colunas.forEach(c => { leadsPorColuna[c.key] = []; });
leads.forEach(item => {
  const col = getColuna(item);
  if (leadsPorColuna[col]) leadsPorColuna[col].push(item);
});
%>

<!-- Hint scroll lateral -->
<div id="kanban-hint" style="display:flex;align-items:center;gap:8px;margin-bottom:10px;padding:8px 14px;background:#f9fafb;border:0.5px solid rgba(0,0,0,.08);border-radius:8px;font-size:12px;color:#6b7280">
  <span style="font-size:16px">👆</span>
  <span>Deslize para os lados para ver todas as etapas</span>
  <div style="display:flex;gap:4px;margin-left:auto;align-items:center">
    <button onclick="scrollKanban(-1)" style="width:28px;height:28px;border:0.5px solid rgba(0,0,0,.1);border-radius:6px;background:#fff;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center">‹</button>
    <button onclick="scrollKanban(1)" style="width:28px;height:28px;border:0.5px solid rgba(0,0,0,.1);border-radius:6px;background:#fff;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center">›</button>
  </div>
</div>

<div class="kanban-wrap" id="kanban-board">
<% colunas.forEach(col => { %>
<div class="kanban-col" data-col="<%= col.key %>">
  <div class="kanban-col-header">
    <div style="display:flex;align-items:center;gap:6px">
      <div class="kanban-col-dot" style="background:<%= col.cor %>"></div>
      <span class="kanban-col-title"><%= col.label %></span>
    </div>
    <span class="kanban-col-count" id="count-<%= col.key %>"><%= leadsPorColuna[col.key].length %></span>
  </div>

  <% if(leadsPorColuna[col.key].length === 0){ %>
  <div class="empty-col">Nenhuma lead</div>
  <% } %>

  <% leadsPorColuna[col.key].forEach(item => {
    const _mat = (item.matchesAuto||item.matches||[]).length;
    const _perfil = item.perfilIA || {};
    const telefone = String(item.contato||item.telefone||'').replace(/\D/g,'');
    const _sj = item.score || 0;
    const _sjCor = _sj>=70?'#16a34a':_sj>=40?'#d97706':'#9ca3af';
    const _vitrine = !!item.vitrineEnviada;

    let _acao='',_acaoCor='',_urg='';
    if(col.key==='fechado'){_acao='Fechar negócio';_acaoCor='background:#f0fdf4;color:#166534;border-color:#86efac';_urg='alta';}
    else if(col.key==='visita'){_acao='Agendar visita';_acaoCor='background:#eff6ff;color:#1e40af;border-color:#bfdbfe';_urg='alta';}
    else if(col.key==='vitrine'&&!_vitrine){_acao='Enviar vitrine';_acaoCor='background:#eef2ff;color:#4338ca;border-color:#c7d2fe';_urg='alta';}
    else if(col.key==='match'){_acao='Ver matches';_acaoCor='background:#f0fdf4;color:#15803d;border-color:#86efac';_urg='media';}
    else if(col.key==='qualificando'){_acao='Qualificar';_acaoCor='background:#fffbeb;color:#92400e;border-color:#fcd34d';_urg='media';}
    else if(col.key==='novo'){_acao='Iniciar contato';_acaoCor='background:#f9fafb;color:#6b7280;border-color:#e5e7eb';_urg='';}
  %>
  <div class="lead-card <%= _urg==='alta'?'urg-alta':_urg==='media'?'urg-media':'' %>"
    data-id="<%= item.id %>"
    data-col="<%= col.key %>"
    data-temperatura="<%= item.temperatura||'frio' %>"
    data-origem="<%= item.origem||'' %>"
    data-score="<%= _sj %>"
    data-tipo-lead="<%= (_perfil.tipo||'').toLowerCase() %>"
    data-intencao="<%= (_perfil.intencao||'').toLowerCase() %>"
    data-search="<%= [item.nome,item.contato,item.telefone,item.bairro,_perfil.bairro].filter(Boolean).join(' ').toLowerCase() %>">

    <% if(_acao){ %>
    <div class="acao-badge" style="<%= _acaoCor %>"><%= _acao %></div>
    <% } %>

    <a href="/app/lead/<%= item.id %>" class="lead-nome"><%= item.nome||telefone||'Lead' %></a>
    <div class="lead-tel"><%= telefone||'—' %></div>
    <% if(item.tipoLead && item.tipoLead !== 'cliente'){ %>
    <div class="tipo-lead-tag" style="display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;margin-bottom:4px;<%=item.tipoLead==='corretor'?'background:#ede9fe;color:#6d28d9':item.tipoLead==='vendedor'?'background:#dcfce7;color:#166534':''%>">
      <%=item.tipoLead==='corretor'?'🤝 Corretor Parceiro':item.tipoLead==='vendedor'?'🏠 Tem Imóvel':'👤 Cliente'%>
    </div>
    <% } %>

    <div class="score-row">
      <div class="score-bar"><div class="score-fill" style="width:<%= _sj %>%;background:<%= _sjCor %>"></div></div>
      <span style="font-size:10px;font-weight:500;color:<%= _sjCor %>"><%= _sj %></span>
      <% if(item.temperatura){ %>
      <span class="temp-pill" style="background:<%= item.temperatura==='quente'?'#fee2e2':item.temperatura==='morno'?'#fef3c7':'#eff6ff' %>;color:<%= item.temperatura==='quente'?'#991b1b':item.temperatura==='morno'?'#92400e':'#1e40af' %>"><%= item.temperatura==='quente'?'🔥':item.temperatura==='morno'?'🌡':'❄️' %> <%= item.temperatura %></span>
      <% } %>
      <% if(_mat>0){ %><span class="match-pill"><%= _mat %> match<%= _mat>1?'es':'' %></span><% } %>
    </div>

    <% if(_perfil && Object.keys(_perfil).length){ %>
    <div class="perfil-row">
      <% if(_perfil.tipo){%><span class="perfil-tag"><%= _perfil.tipo %></span><%}%>
      <% if(_perfil.quartos){%><span class="perfil-tag"><%= _perfil.quartos %>q</span><%}%>
      <% if(_perfil.bairro){%><span class="perfil-tag"><%= _perfil.bairro %></span><%}%>
      <% if(_perfil.valorMax){%><span class="perfil-tag">R$<%= Math.round(Number(_perfil.valorMax)/1000) %>k</span><%}%>
    </div>
    <% } %>

    <% if(item.ultimaMensagem){ %>
    <div style="font-size:11px;color:#9ca3af;border-left:2px solid #f3f4f6;padding-left:6px;font-style:italic;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:4px"><%= item.ultimaMensagem.substring(0,60) %></div>
    <% } %>
    <div style="font-size:10px;color:#d1d5db;display:flex;gap:8px;margin-bottom:4px">
      <% if(item.criadoEm||item.data_cadastro){ %><span>📅 <%= new Date(item.criadoEm||item.data_cadastro).toLocaleDateString('pt-BR') %></span><% } %>
      <% if(item.ultimaMensagemEm){ %><span>💬 <%= new Date(item.ultimaMensagemEm).toLocaleDateString('pt-BR') %></span><% } %>
    </div>

    <div class="lead-btns">
      <% if(telefone){ %>
      <a href="https://wa.me/55<%= telefone %>" target="_blank" class="lb wa">WhatsApp</a>
      <% } %>
      <% if(_mat>0){ %>
      <% if(item.vitrineEnviada && item.vitrineEnviadaEm){ %>
      <a href="/cliente/oferta/<%= item.leadId||item.id %>?userId=<%= encodeURIComponent(item.userId||item.usuarioId||item.corretorId||'') %>"
         class="lb" style="background:#f9fafb;color:#6b7280;border-color:rgba(0,0,0,.1)"
         title="Vitrine enviada pelo sistema — clique para abrir">
        ✓ Vitrine <%= new Date(item.vitrineEnviadaEm).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}) %>
      </a>
      <% } else { %>
      <a href="/cliente/oferta/<%= item.leadId||item.id %>?userId=<%= encodeURIComponent(item.userId||item.usuarioId||item.corretorId||'') %>" class="lb prim">Vitrine</a>
      <% } %>
      <% } %>
      <a href="/app/lead/<%= item.id %>" class="lb dark">Ver →</a>
      <% if(!item.tipoLead || item.tipoLead==='cliente'){ %>
      <button onclick="abrirClassificar('<%= item.id %>')" class="lb btn-classificar-flag" title="Classificar esta lead">🚩</button>
      <% } %>
      <button onclick="confirmarExcluir('<%= item.id %>')" class="lb danger">×</button>
    </div>
    <div class="confirm-box" id="confirm-<%= item.id %>">
      <div style="font-size:11px;color:#991b1b;margin-bottom:6px;font-weight:500">Excluir esta lead?</div>
      <div style="display:flex;gap:5px">
        <button onclick="excluirLead('<%= item.id %>')" class="lb danger" style="font-size:10px">Só excluir</button>
        <button onclick="bloquearLead('<%= item.id %>')" class="lb dark" style="font-size:10px">Excluir e bloquear</button>
        <button onclick="document.getElementById('confirm-<%= item.id %>').style.display='none'" class="lb" style="font-size:10px">Cancelar</button>
      </div>
    </div>
    <div class="confirm-box" id="classificar-<%= item.id %>" style="display:none">
      <div style="font-size:11px;color:#374151;margin-bottom:6px;font-weight:500">Classificar lead:</div>
      <div style="display:flex;gap:5px;flex-wrap:wrap">
        <button onclick="classificarLead('<%= item.id %>','cliente')" class="lb" style="font-size:10px;background:#eff6ff;color:#1e40af">👤 Buscando</button>
        <button onclick="classificarLead('<%= item.id %>','vendedor')" class="lb" style="font-size:10px;background:#dcfce7;color:#166534">🏠 Tem Imóvel</button>
        <button onclick="classificarLead('<%= item.id %>','corretor')" class="lb" style="font-size:10px;background:#ede9fe;color:#6d28d9">🤝 Corretor</button>
        <button onclick="document.getElementById('classificar-<%= item.id %>').style.display='none'" class="lb" style="font-size:10px">Cancelar</button>
      </div>
    </div>
  </div>
  <% }) %>
</div>
<% }) %>
</div>

<!-- Modal importar -->
<div id="modal-importar-leads" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:9999;align-items:center;justify-content:center;padding:20px">
  <div style="background:#fff;border-radius:16px;max-width:480px;width:100%;padding:24px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
      <div><div style="font-size:15px;font-weight:500;color:#111827">Importar leads</div><div style="font-size:12px;color:#9ca3af;margin-top:2px">CSV ou Excel com cabeçalhos na primeira linha</div></div>
      <button onclick="fecharModalImportarLeads()" style="background:#f9fafb;border:0.5px solid rgba(0,0,0,.1);border-radius:7px;width:30px;height:30px;cursor:pointer;font-size:16px">×</button>
    </div>
    <div style="background:#f0fdf4;border:1px solid #86efac;border-radius:8px;padding:10px;margin-bottom:12px;font-size:12px;color:#166534">
      <strong>✅ Obrigatório:</strong> Nome + Telefone<br>
      <strong>💡 Opcional:</strong> Email, Origem, Tipo, Transacao, Condicao, Bairro, Cidade, Estado, Quartos, Suites, Vagas, Banheiros, Area_min, Area_max, Valor_min, Valor_max, Observacoes
    </div>
    <a href="/app/modelo-leads.xlsx" style="display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:600;color:#374151;text-decoration:none;margin-bottom:10px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:7px;padding:6px 12px">📥 Baixar modelo</a>
    <form method="POST" action="/process" enctype="multipart/form-data">
      <input type="file" name="file" accept=".xlsx,.xls,.csv" required style="width:100%;border:0.5px solid rgba(0,0,0,.12);border-radius:8px;padding:10px;margin-bottom:12px;font-size:13px">
      <button type="submit" style="width:100%;padding:11px;background:#111827;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer">Importar planilha</button>
    </form>
  </div>
</div>

<script>
const _fl = { temp:'', origem:'' };

function scrollKanban(dir) {
  const board = document.getElementById('kanban-board');
  board.scrollBy({ left: dir * 280, behavior: 'smooth' });
}

// Esconde hint após primeiro scroll
document.addEventListener('DOMContentLoaded', () => {
  const board = document.getElementById('kanban-board');
  const hint = document.getElementById('kanban-hint');
  if (board) {
    board.addEventListener('scroll', () => {
      if (hint) hint.style.opacity = '0.4';
    }, { once: true });
  }
});

function setChip(campo, valor, btn) {
  _fl[campo] = valor;
  btn.parentElement.querySelectorAll('.fchip').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  aplicarFiltros();
}

function toggleFAdv() {
  const el = document.getElementById('fadv');
  el.style.display = el.style.display==='none'?'block':'none';
}

function limparFiltros() {
  _fl.temp=''; _fl.origem='';
  document.getElementById('filter-search').value='';
  ['filter-score','filter-tipo-lead','filter-intencao'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.querySelectorAll('.fchip').forEach(b=>{b.classList.remove('on');if(b.textContent.trim()==='Todas'||b.textContent.trim()==='Todos')b.classList.add('on');});
  aplicarFiltros();
}

function aplicarFiltros() {
  const busca = (document.getElementById('filter-search')?.value||'').toLowerCase();
  const scoreMin = parseInt(document.getElementById('filter-score')?.value||'0');
  const tipoLead = (document.getElementById('filter-tipo-lead')?.value||'').toLowerCase();
  const intencao = (document.getElementById('filter-intencao')?.value||'').toLowerCase();

  const cards = document.querySelectorAll('.lead-card');
  let total = 0;

  // Conta por coluna
  const counts = {};

  cards.forEach(card => {
    let ok = true;
    if(_fl.temp && card.dataset.temperatura !== _fl.temp) ok=false;
    if(_fl.origem && !(card.dataset.origem||'').includes(_fl.origem)) ok=false;
    if(parseInt(card.dataset.score||'0') < scoreMin) ok=false;
    if(busca && !(card.dataset.search||'').includes(busca)) ok=false;
    if(tipoLead && !(card.dataset.tipoLead||'').includes(tipoLead)) ok=false;
    if(intencao && !(card.dataset.intencao||'').includes(intencao)) ok=false;

    card.style.display = ok ? '' : 'none';
    if(ok) {
      total++;
      const col = card.dataset.col;
      counts[col] = (counts[col]||0)+1;
    }
  });

  // Atualiza contadores das colunas
  Object.keys(counts).forEach(col => {
    const el = document.getElementById('count-'+col);
    if(el) el.textContent = counts[col]||0;
  });
  // Zera colunas sem resultado
  document.querySelectorAll('.kanban-col-count').forEach(el => {
    const col = el.id.replace('count-','');
    if(!counts[col]) el.textContent = '0';
  });

  // Empty state por coluna
  document.querySelectorAll('.kanban-col').forEach(col => {
    const colKey = col.dataset.col;
    const visCards = Array.from(col.querySelectorAll('.lead-card')).filter(c=>c.style.display!=='none');
    let empty = col.querySelector('.empty-col');
    if(!empty){ empty=document.createElement('div'); empty.className='empty-col'; empty.textContent='Nenhuma lead'; col.appendChild(empty); }
    empty.style.display = visCards.length===0?'block':'none';
  });

  const counter = document.getElementById('filter-counter');
  if(counter) counter.textContent = total+' leads exibidas';
}

function rodarMatchBase() {
  const btn = document.getElementById('btn-match-base');
  btn.disabled=true; btn.textContent='Rodando...';
  fetch('/admin/rodar-match/<%= userId %>')
    .then(r=>r.json())
    .then(d=>{
      btn.textContent='Match IA'; btn.disabled=false;
      if(d.ok){alert('Match concluído!\nCom match: '+d.comMatch+'\nSem match: '+d.semMatch);location.reload();}
      else alert('Erro: '+d.error);
    })
    .catch(()=>{btn.textContent='Match IA';btn.disabled=false;});
}

function abrirModalImportarLeads(){document.getElementById('modal-importar-leads').style.display='flex';}
function fecharModalImportarLeads(){document.getElementById('modal-importar-leads').style.display='none';}

function confirmarExcluir(id) {
  document.querySelectorAll('.confirm-box').forEach(el=>el.style.display='none');
  document.getElementById('confirm-'+id).style.display='block';
}
async function excluirLead(id){const r=await fetch('/app/lead/'+id,{method:'DELETE'});const d=await r.json();if(d.ok)location.reload();else alert('Erro: '+d.erro);}
function abrirClassificar(id){document.querySelectorAll('.confirm-box').forEach(el=>el.style.display='none');document.getElementById('classificar-'+id).style.display='block';}
async function classificarLead(id,tipo){const r=await fetch('/app/lead/'+id+'/classificar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({tipoLead:tipo})});const d=await r.json();if(d.ok)location.reload();else alert('Erro: '+d.erro);}
async function bloquearLead(id){const r=await fetch('/app/lead/'+id+'/bloquear',{method:'POST'});const d=await r.json();if(d.ok)location.reload();else alert('Erro: '+d.erro);}

window.addEventListener('DOMContentLoaded', aplicarFiltros);
</script>

<%- include('partials/app-end') %>
