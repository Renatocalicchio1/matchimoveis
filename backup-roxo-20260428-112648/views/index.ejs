<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MatchImoveis</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
<div id="match-live-total" style="position:fixed;top:12px;right:12px;z-index:9999;background:#111;color:#fff;padding:10px 14px;border-radius:12px;font-weight:700;box-shadow:0 4px 18px rgba(0,0,0,.25)">
  Total matches: <span id="match-total-num">0</span>
</div>

<script>
function atualizarTotalMatches(){
  let total = 0;
  document.querySelectorAll('.chip').forEach(function(c){
    const txt = c.innerText || '';
    const m = txt.match(/(\d+)\s*matches/i);
    if (m) total += Number(m[1]);
  });
  const el = document.getElementById('match-total-num');
  if (el) el.innerText = total;
}
setInterval(atualizarTotalMatches, 1000);
document.addEventListener('DOMContentLoaded', atualizarTotalMatches);
</script>

  <header class="topbar">
    <div class="brand-wrap">
      <div class="brand">MatchImoveis</div>

      <div class="subbrand">MVP local para matching imobiliário</div>

    </div>

    <div class="actions-top">
      <div class="badge">Localhost</div>

      <form action="/reset" method="post">
        <button class="ghost" type="submit">Zerar base local</button>
      </form>
    </div>

  </header>

  <main class="container">
    <% if (flash) { %>
      <section class="card flash"><%= flash %></section>
    <% } %>

    <section class="hero card">
      <div>
        <p class="eyebrow">Matching imobiliário</p>
        <h1>Suba a planilha, limpe duplicados e encontre os 5 melhores matches por imóvel.</h1>
        <p class="muted">O sistema considera apenas nome do cliente, telefone/contato, email, ID do anúncio e URL do anúncio. Todo o resto é ignorado. No Mac, se a planilha estiver em Numbers, exporte para Excel (.xlsx) ou CSV para processar com segurança neste MVP.</p>
        <div class="hero-points">
          <span>Somente São Paulo/SP</span>
          <span>Mesmo bairro e quartos</span>
          <span>Valor e área em ±10%</span>
          <span>Suítes, banheiros e vagas em ±1</span>
        </div>

      </div>

      <form class="upload-box" action="/process" method="post" enctype="multipart/form-data">
        <label class="file-label">
          <span>Escolher planilha</span>
          <input id="spreadsheet-file" type="file" name="spreadsheet" accept=".xlsx,.xls,.csv,.numbers" required />
          <small id="file-name">Nenhum arquivo escolhido</small>
        </label>
        <button type="submit" class="primary">Processar planilha</button>
        <p class="tiny">Fluxo: importa → remove duplicados → extrai origem → busca top 5 na base local do QuintoAndar. Aceita upload de Excel/CSV e identifica Numbers para orientar a exportação no Mac.</p>
      </form>
    </section>

    <section class="grid three">
      <article class="card info-card">
        <h2>Entrada aceita</h2>
        <ul>
          <li>Nome do cliente</li>
          <li>Telefone / contato</li>
          <li>Email</li>
          <li>ID do anúncio</li>
          <li>URL do anúncio</li>
        </ul>
      </article>
      <article class="card info-card">
        <h2>Filtros do match</h2>
        <ul>
          <li>Tipo, bairro, cidade, estado e quartos iguais</li>
          <li>Valor e área útil com ±10%</li>
          <li>Suítes, banheiros e vagas com ±1</li>
        </ul>
      </article>
      <article class="card info-card">
        <h2>Melhorias do MVP</h2>
        <ul>
          <li>Zerar base local</li>
          <li>Filtro por cidade</li>
          <li>Filtro por bairro</li>
          <li>Filtro por status de match</li>
        </ul>
      </article>
    </section>

    <% if (result && result.error) { %>
      <section class="card error"><%= result.error %></section>
    <% } %>

    <% if (result && result.stats) { %>
      <section class="stats seven">
        <div class="stat card"><strong><%= result.stats.original %></strong><span>linhas válidas</span></div>

        <div class="stat card"><strong><%= result.stats.unique %></strong><span>únicas</span></div>

        <div class="stat card"><strong><%= result.stats.duplicates %></strong><span>duplicadas</span></div>

        <div class="stat card"><strong><%= result.stats.processed %></strong><span>processadas</span></div>

        <div class="stat card"><strong><%= result.stats.withMatches %></strong><span>com match</span></div>

        <div class="stat card"><strong><%= result.stats.pending %></strong><span>pendentes</span></div>

        <div class="stat card"><strong><%= result.stats.ignored %></strong><span>ignoradas</span></div>

      </section>

      


      <section class="card filter-card">
        <div class="section-head compact">
          <h2>Filtros rápidos</h2>
          <p class="muted">Filtre por cidade, bairro, status, score e busca.</p>
        </div>

        <div class="filters-row">
          <label>
            <span>Cidade</span>
            <select id="filter-city">
              <option value="all">Todas</option>
              <% result.filters.cities.forEach((city) => { %>
                <option value="<%= city %>"><%= city %></option>
              <% }) %>
            </select>
          </label>

          <label>
            <span>Bairro</span>
            <select id="filter-bairro">
              <option value="all">Todos</option>
              <% result.filters.neighborhoods.forEach((neighborhood) => { %>
                <option value="<%= neighborhood %>"><%= neighborhood %></option>
              <% }) %>
            </select>
          </label>

          <label>
            <span>Status</span>
            <select id="filter-status">
              <% result.filters.matchStatuses.forEach((status) => { %>
                <option value="<%= status.value %>"><%= status.label %></option>
              <% }) %>
            </select>
          </label>

          <label>
            <span>Score mínimo</span>
            <select id="filter-score">
              <option value="0">Todos</option>
              <option value="30">30+</option>
              <option value="50">50+</option>
              <option value="70">70+</option>
              <option value="90">90+</option>
            </select>
          </label>

          <label>
            <span>Data Match</span>
            <select id="filter-date">
              <option value="all">Todas</option>
              <option value="today">Hoje</option>
              <option value="7d">Últimos 7 dias</option>
              <option value="30d">Últimos 30 dias</option>
            </select>
          </label>

          <label>
            <span>Busca</span>
            <input id="filter-search" type="text" placeholder="Cliente, email, ID..." />
          </label>
        </div>
      </section>

      
      <section class="card">
        <form action="/match-pending" method="post">
          <button type="submit" class="primary">Fazer match com QuintoAndar</button>
        </form>
        <p class="tiny">Este botão busca matches apenas para imóveis que ainda não têm match.</p>
      </section>

      <section class="card results-card">
        <div class="section-head">
          <h2>Resultados</h2>
          <p class="muted">Cada card representa um cliente + imóvel de origem + top 5 matches.</p>
        </div>


        
        <div id="results-list" class="excel-results">
          <% result.processed.forEach((item, idx) => { 
            const status = item.ignored ? 'ignored' : item.origin.extractionStatus !== 'ok' ? 'pending' : (item.matches || []).length ? 'with_matches' : 'without_matches';
          %>
            <div class="excel-card" data-matched="<%= item.matchedAt || '' %>" data-city="<%= item.origin.cidade || '' %>" data-bairro="<%= item.origin.bairro || '' %>" data-status="<%= status %>" data-score="<%= item.bestScore || 0 %>" data-search="<%= [item.clientName, item.contact, item.email, item.origin.listingId, item.origin.bairro, item.origin.cidade].filter(Boolean).join(' ').toLowerCase() %>">
              
              <div class="excel-client">
<div style="font-size:12px;color:#667085;margin-bottom:6px;">
Processado: <%= item.processedAt ? new Date(item.processedAt).toLocaleString('pt-BR') : '-' %><br>
Match: <%= item.matchedAt ? new Date(item.matchedAt).toLocaleString('pt-BR') : '-' %>
</div>
                <strong><%= item.clientName || 'Cliente sem nome' %></strong>
                <span style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;"><%= item.contact || 'Sem contato' %><% if (item.email) { %> · <%= item.email %><% } %>
<% if (item.matches && (item.matches || []).length) { %>
<style>
.badge-fonte{display:inline-block;padding:2px 6px;border-radius:6px;font-size:10px;font-weight:700;margin-left:6px}
.badge-q{background:#111;color:#fff}
.badge-r{background:#e30613;color:#fff}
</style>
<a target="_blank" href="https://wa.me/5511999999999?text=Teste" style="background:#f2f4f7;color:#25D366;padding:6px 10px;border-radius:8px;text-decoration:none;font-weight:600;font-size:13px;">WhatsApp</a>
<% } %>
</span>
              </div>

              <div class="excel-status">
                <% if (item.origin.extractionStatus === 'ok') { %><span class="chip success">ImovelWeb extraído</span><% } %>
                <% if (item.origin.extractionStatus !== 'ok') { %><span class="chip warning">Pendente / incompleto</span><% } %>
                <% if (item.ignored) { %><span class="chip warning">Ignorado</span><% } %>
                <% if (item.matchCount) { %><span class="chip dark"><%= item.matchCount %> matches</span><% } %>
                <% if (!item.matchCount && item.origin.extractionStatus === 'ok' && !item.ignored) { %><span class="chip">Sem match</span><% } %>
                <% if (item.bestScore) { %><span class="chip dark">Score <%= item.bestScore %></span><% } %>
                <% if (item.leadScore) { %><span class="chip"><%= item.leadScore %></span><% } %>
              </div>

              <div class="excel-status">
                <% if (item.origin.extractionStatus === 'ok') { %><span class="chip success">ImovelWeb extraído</span><% } %>
                <% if (item.origin.extractionStatus !== 'ok') { %><span class="chip warning">Pendente / incompleto</span><% } %>
                <% if (item.ignored) { %><span class="chip warning">Ignorado</span><% } %>
                <% if (item.matchCount) { %><span class="chip dark"><%= item.matchCount %> matches</span><% } %>
                <% if (!item.matchCount && item.origin.extractionStatus === 'ok' && !item.ignored) { %><span class="chip">Sem match</span><% } %>
                <% if (item.bestScore) { %><span class="chip dark">Score <%= item.bestScore %></span><% } %>
                <% if (item.leadScore) { %><span class="chip"><%= item.leadScore %></span><% } %>
              </div>
<% if (item.matches && (item.matches || []).length) { %>
<a target="_blank" href="/oferta/<%= idx %>" style="display:block;margin:10px 0;background:#f2f4f7;color:#111;padding:10px;text-align:center;border-radius:10px;text-decoration:none;font-weight:700;">Ver espelho do cliente</a>
<% } %>
<div class="excel-table-wrap">
                <table class="excel-table">
                  <thead>
                    <tr>
                      <th>Fonte</th>
                      <th>Rank</th>
                      <th>Score</th>
                      <th>ID</th>
                      <th>Tipo</th>
                      <th>Bairro</th>
                      <th>Cidade/UF</th>
                      <th>Valor</th>
                      <th>Área</th>
                      <th>Quartos</th>
                      <th>Suítes</th>
                      <th>Banheiros</th>
                      <th>Vagas</th>
                      <th>URL</th>
                    </tr>
                  </thead>

                  <tbody>
                    <tr class="origin-row">
                      <td>ImovelWeb</td>
                      <td>Origem</td>
                      <td>-</td>
                      <td><%= item.origin.listingId || item.listingId || '-' %></td>
                      <td><%= item.origin.tipo || '-' %></td>
                      <td><%= item.origin.bairro || '-' %></td>
                      <td><%= item.origin.cidade || '-' %> / <%= item.origin.estado || '-' %></td>
                      <td><%= item.origin.valor_imovel ? `R$ ${Number(item.origin.valor_imovel).toLocaleString('pt-BR')}` : '-' %></td>
                      <td><%= item.origin.area_m2 || '-' %> m²</td>
                      <td><%= item.origin.quartos || '-' %></td>
                      <td><%= item.origin.suites ?? '-' %></td>
                      <td><%= item.origin.banheiros ?? '-' %></td>
                      <td><%= item.origin.vagas ?? '-' %></td>
                      <td class="url-cell"><%= item.origin.url || item.listingUrl || '-' %></td>
                    </tr>

                    <% if (item.matches && (item.matches || []).length) { %>
                      <% item.matches.forEach((match) => { %>
                        <tr class="match-row">
                          <td><%= match.fonte || (match.id_anuncio_remax ? 'REMAX' : 'QuintoAndar') %></td>
                          <td>#<%= match.rank %></td>
                          <td><%= match.score %></td>
                          <td><%= match.id_anuncio_quintoandar || match.id_anuncio_remax || match.id_anuncio || '-' %></td>
                          <td><%= match.tipo || '-' %></td>
                          <td><%= match.bairro || item.origin.bairro || '-' %></td>
                          <td><%= match.cidade || '-' %> / <%= match.estado || '-' %></td>
                          <td><%= (match.valor_imovel || match.valor) ? `R$ ${Number(match.valor_imovel || match.valor).toLocaleString('pt-BR')}` : '-' %></td>
                          <td><%= match.area_m2 || match.area || '-' %> m²</td>
                          <td><%= match.quartos ?? '-' %></td>
                          <td><%= match.suites ?? '-' %></td>
                          <td><%= match.banheiros ?? '-' %></td>
                          <td><%= match.vagas ?? '-' %></td>
                          <td class="url-cell"><%= match.url || '-' %></td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr class="empty-match-row">
                        <td colspan="14">
                          <% if (item.origin.extractionStatus !== 'ok') { %>
                            Aguardando extração / dados incompletos.
                          <% } else if (item.ignored) { %>
                            Ignorado porque não está em São Paulo/SP.
                          <% } else { %>
                            Nenhum match encontrado ainda.
                          <% } %>
                        </td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          <% }) %>
        </div>

      </section>
    <% } %>
  </main>

  <script>
  (() => {
    const fileInput = document.getElementById('spreadsheet-file');
    const fileName = document.getElementById('file-name');

    if (fileInput && fileName) {
      fileInput.addEventListener('change', () => {
        fileName.textContent = fileInput.files.length ? fileInput.files[0].name : 'Nenhum arquivo escolhido';
      });
    }

    const city = document.getElementById('filter-city');
    const bairro = document.getElementById('filter-bairro');
    const status = document.getElementById('filter-status');
    const score = document.getElementById('filter-score');
    const search = document.getElementById('filter-search');
    const date = document.getElementById('filter-date');
    const cards = Array.from(document.querySelectorAll('.excel-card'));

    if (!cards.length) return;

    let counter = document.getElementById('filter-counter');
    if (!counter) {
      counter = document.createElement('div');
      counter.id = 'filter-counter';
      counter.style.margin = '12px 0';
      counter.style.fontWeight = '700';
      const results = document.querySelector('.results-card');
      if (results) results.prepend(counter);
    }

    function normalize(value) {
      return String(value || '').trim().toLowerCase();
    }

    function isSameDay(a, b) {
      return a.getFullYear() === b.getFullYear() &&
        a.getMonth() === b.getMonth() &&
        a.getDate() === b.getDate();
    }

    function matchesDate(card) {
      if (!date || date.value === 'all') return true;
      const raw = card.dataset.matched || '';
      if (!raw) return false;

      const d = new Date(raw);
      if (isNaN(d.getTime())) return false;

      const now = new Date();
      const diffDays = (now - d) / (1000 * 60 * 60 * 24);

      if (date.value === 'today') return isSameDay(d, now);
      if (date.value === '7d') return diffDays <= 7;
      if (date.value === '30d') return diffDays <= 30;

      return true;
    }

    function matchesFilter(card) {
      const cityOk = !city || city.value === 'all' || card.dataset.city === city.value;
      const bairroOk = !bairro || bairro.value === 'all' || card.dataset.bairro === bairro.value;
      const statusOk = !status || status.value === 'all' || card.dataset.status === status.value;

      const minScore = parseInt(score?.value || '0', 10);
      const cardScore = parseInt(card.dataset.score || '0', 10);
      const scoreOk = cardScore >= minScore;

      const query = normalize(search?.value || '');
      const searchOk = !query || normalize(card.dataset.search).includes(query);

      const dateOk = matchesDate(card);

      return cityOk && bairroOk && statusOk && scoreOk && searchOk && dateOk;
    }

    function applyFilters() {
      let visible = 0;

      cards.forEach(card => {
        const ok = matchesFilter(card);
        card.style.display = ok ? '' : 'none';
        if (ok) visible++;
      });

      counter.textContent = visible + ' de ' + cards.length + ' cards aparecendo';
    }

    [city, bairro, status, score, search, date].forEach(el => {
      if (!el) return;
      el.addEventListener(el.tagName === 'INPUT' ? 'input' : 'change', applyFilters);
    });

    applyFilters();
  })();
</script>
</body>
</html>
