<%- include('partials/app-shell',{active:'whatsapp',title:'Inbox WhatsApp',subtitle:'Mensagens dos seus leads.',user:user}) %>

<style>
.conv-card{
  background:#fff;
  border:0.5px solid rgba(0,0,0,.08);
  border-radius:14px;
  padding:14px 18px;
  margin-bottom:8px;
  display:flex;
  align-items:center;
  gap:14px;
  cursor:pointer;
  text-decoration:none;
  color:inherit;
  transition:box-shadow .15s;
}
.conv-card:hover{box-shadow:0 2px 12px rgba(0,0,0,.07)}
.conv-card.nao-lida{border-left:2px solid #22c55e}

.conv-avatar{
  width:42px;height:42px;
  border-radius:50%;
  background:#eef2ff;
  display:flex;align-items:center;justify-content:center;
  color:#4338ca;font-weight:500;font-size:16px;
  flex-shrink:0;
}

.conv-nome{font-weight:500;font-size:14px;color:#111827}
.conv-preview{font-size:13px;color:#9ca3af;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:380px}

.conv-meta{margin-left:auto;text-align:right;flex-shrink:0}
.conv-hora{font-size:11px;color:#d1d5db}
.conv-temp{font-size:11px;padding:3px 9px;border-radius:999px;font-weight:500;margin-top:5px;display:inline-block}
.temp-quente{background:#fee2e2;color:#b91c1c}
.temp-morno{background:#fff7ed;color:#c2410c}
.temp-frio{background:#f9fafb;color:#9ca3af}

.fi-chip{
  padding:5px 14px;
  border-radius:999px;
  font-size:12px;
  font-weight:500;
  border:0.5px solid rgba(0,0,0,.12);
  background:#fff;
  cursor:pointer;
  color:#374151;
  transition:all .12s;
}
.fi-chip.on{background:#111827;color:#fff;border-color:#111827}

.vi-empty{
  padding:56px 24px;
  text-align:center;
  background:#f9fafb;
  border:0.5px solid rgba(0,0,0,.06);
  border-radius:16px;
}
</style>

<!-- Header -->
<div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap">
  <div style="display:flex;align-items:center;gap:8px">
    <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#22c55e"></span>
    <span id="badge-total" style="font-size:13px;color:#6b7280"></span>
  </div>
  <button onclick="location.reload()" style="margin-left:auto;padding:8px 16px;background:#f9fafb;border:0.5px solid rgba(0,0,0,.1);border-radius:8px;cursor:pointer;font-size:13px;color:#374151;font-weight:500">Atualizar</button>
</div>

<!-- Filtros -->
<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px">
  <button class="fi-chip on" onclick="filtrar('todos',this)">Todos</button>
  <button class="fi-chip" onclick="filtrar('nao_lida',this)">Não lidas</button>
  <button class="fi-chip" onclick="filtrar('quente',this)">Quentes</button>
  <button class="fi-chip" onclick="filtrar('morno',this)">Mornos</button>
  <button class="fi-chip" onclick="filtrar('frio',this)">Frios</button>
</div>

<!-- Lista -->
<div id="lista-convs">
<%
  const leadsComMsg = leads.filter(l => l.mensagens && l.mensagens.length > 0)
    .sort((a,b) => new Date(b.ultimaMensagemEm||0) - new Date(a.ultimaMensagemEm||0));
%>

<% if(!leadsComMsg.length){ %>
<div class="vi-empty">
  <div style="font-size:32px;margin-bottom:12px;opacity:.4">💬</div>
  <div style="font-weight:500;font-size:15px;color:#374151">Nenhuma mensagem ainda</div>
  <div style="font-size:13px;color:#9ca3af;margin-top:6px">As mensagens WhatsApp dos seus leads aparecerão aqui.</div>
</div>
<% } %>

<% leadsComMsg.forEach(lead => {
  const naoLidas = (lead.mensagens||[]).filter(m => !m.lida && m.de==='cliente').length;
  const ultimaMsg = lead.mensagens[lead.mensagens.length-1];
  const temp = lead.temperatura || 'frio';
  const inicial = (lead.nome||lead.contato||'?')[0].toUpperCase();
  const tempLabel = temp==='quente'?'Quente':temp==='morno'?'Morno':'Frio';
%>
<a href="/app/lead/<%= lead.id %>"
   class="conv-card <%= naoLidas>0?'nao-lida':'' %>"
   data-temp="<%= temp %>"
   data-lida="<%= naoLidas>0?'nao_lida':'lida' %>">

  <div class="conv-avatar"><%= inicial %></div>

  <div style="flex:1;min-width:0">
    <div style="display:flex;align-items:center;gap:8px">
      <span class="conv-nome"><%= lead.nome||lead.contato||'Sem nome' %></span>
      <% if(naoLidas>0){ %>
      <span style="background:#22c55e;color:#fff;border-radius:50%;width:18px;height:18px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;flex-shrink:0"><%= naoLidas %></span>
      <% } %>
    </div>
    <div class="conv-preview"><%= ultimaMsg?ultimaMsg.texto:'' %></div>
  </div>

  <div class="conv-meta">
    <div class="conv-hora">
      <%= ultimaMsg&&ultimaMsg.timestamp ? new Date(ultimaMsg.timestamp).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) : '' %>
    </div>
    <span class="conv-temp temp-<%= temp %>"><%= tempLabel %></span>
  </div>
</a>
<% }) %>
</div>

<script>
const total = document.querySelectorAll('.conv-card').length;
document.getElementById('badge-total').textContent = total + ' conversa' + (total!==1?'s':'');

function filtrar(tipo, btn) {
  document.querySelectorAll('.fi-chip').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  document.querySelectorAll('.conv-card').forEach(card => {
    if(tipo==='todos'){ card.style.display=''; return; }
    if(tipo==='nao_lida'){ card.style.display = card.dataset.lida==='nao_lida'?'':'none'; return; }
    card.style.display = card.dataset.temp===tipo?'':'none';
  });
}

setTimeout(() => location.reload(), 30000);
</script>

<%- include('partials/app-end') %>
