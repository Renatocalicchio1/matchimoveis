<%- include("partials/app-shell",{active:"coins",user:user,title:"Créditos"}) %>

<%
  const saldo = user.matchCoins || 0;
  const total = Math.max(user.matchCoinsTotal || 200, saldo, 1);
  const pct   = Math.min(100, Math.round((saldo / total) * 100));
  const cor   = pct > 40 ? '#22c55e' : pct > 15 ? '#f59e0b' : '#ef4444';
  const msg   = pct > 40 ? null : pct > 15 ? 'Seus créditos estão acabando. Considere recarregar.' : saldo === 0 ? 'Sua conta está pausada. Adicione créditos para continuar.' : 'Créditos baixos. Recarregue para não pausar sua conta.';
%>

<!-- SALDO -->
<div class="card" style="margin-bottom:16px;text-align:center;padding:32px 24px">
  <div style="font-size:12px;color:#888;margin-bottom:6px;text-transform:uppercase;letter-spacing:.08em">Seus créditos</div>
  <div style="font-size:52px;font-weight:800;color:#111;margin-bottom:4px"><%= saldo %></div>
  <div style="font-size:13px;color:#888;margin-bottom:20px">créditos disponíveis</div>

  <div style="background:#f3f4f6;border-radius:99px;height:12px;overflow:hidden;margin-bottom:8px">
    <div style="height:100%;width:<%= pct %>%;background:<%= cor %>;border-radius:99px;transition:width .6s"></div>
  </div>

  <% if(msg) { %>
    <div style="font-size:13px;color:<%= cor %>;font-weight:600;margin-top:10px"><%= msg %></div>
  <% } %>
</div>

<!-- ONDE OS CRÉDITOS SÃO USADOS -->
<div class="card" style="margin-bottom:16px">
  <h2 style="font-size:15px;font-weight:700;margin-bottom:4px">Como seus créditos são usados</h2>
  <p style="color:#888;font-size:13px;margin-bottom:20px">Toda atividade da plataforma consome créditos automaticamente.</p>

  <div style="display:flex;flex-direction:column;gap:12px">
    <div style="display:flex;align-items:center;gap:14px;padding:12px;background:#f9fafb;border-radius:12px">
      <div style="font-size:22px">🏠</div>
      <div>
        <div style="font-size:14px;font-weight:600;color:#111">Imóveis</div>
        <div style="font-size:12px;color:#888">Cadastro, edição, geração de XML e envio para portais</div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:14px;padding:12px;background:#f9fafb;border-radius:12px">
      <div style="font-size:22px">👤</div>
      <div>
        <div style="font-size:14px;font-weight:600;color:#111">Leads</div>
        <div style="font-size:12px;color:#888">Leads ativos, qualificação automática e matches encontrados</div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:14px;padding:12px;background:#f9fafb;border-radius:12px">
      <div style="font-size:22px">🤖</div>
      <div>
        <div style="font-size:14px;font-weight:600;color:#111">Inteligência Artificial</div>
        <div style="font-size:12px;color:#888">Respostas automáticas, follow-ups e sugestões pelo WhatsApp</div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:14px;padding:12px;background:#f9fafb;border-radius:12px">
      <div style="font-size:22px">📅</div>
      <div>
        <div style="font-size:14px;font-weight:600;color:#111">Visitas</div>
        <div style="font-size:12px;color:#888">Agendamento, confirmações automáticas e notificações</div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:14px;padding:12px;background:#f9fafb;border-radius:12px">
      <div style="font-size:22px">📲</div>
      <div>
        <div style="font-size:14px;font-weight:600;color:#111">WhatsApp</div>
        <div style="font-size:12px;color:#888">Mensagens enviadas, vitrines e confirmações via WhatsApp</div>
      </div>
    </div>
  </div>
</div>

<!-- ADICIONAR CRÉDITOS -->
<div class="card" style="margin-bottom:16px">
  <h2 style="font-size:15px;font-weight:700;margin-bottom:4px">Adicionar créditos</h2>
  <p style="color:#888;font-size:13px;margin-bottom:20px">Mínimo R$5 · R$1 = 10 créditos</p>

  <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap">
    <% [5,10,20,50,100].forEach(v => { %>
      <button onclick="selecionarValor(<%= v %>)" data-val="<%= v %>" style="flex:1;min-width:55px;padding:12px 6px;border:2px solid #e5e7eb;border-radius:12px;background:#fff;font-size:13px;font-weight:700;cursor:pointer;transition:all .15s">
        R$<%= v %>
      </button>
    <% }) %>
  </div>

  <div style="margin-bottom:16px">
    <label style="font-size:13px;color:#888;display:block;margin-bottom:6px">Ou digite outro valor</label>
    <div style="display:flex;align-items:center;gap:12px">
      <input type="number" id="valorInput" min="5" step="1" placeholder="R$ 0" style="flex:1;padding:12px;border:2px solid #e5e7eb;border-radius:10px;font-size:16px;font-weight:700">
      <div style="text-align:right;min-width:110px">
        <div style="font-size:12px;color:#888">você recebe</div>
        <div id="creditosPreview" style="font-size:20px;font-weight:800;color:#111">0 créditos</div>
      </div>
    </div>
  </div>

  <button onclick="iniciarCompra()" style="width:100%;background:#FF385C;color:#fff;border:none;padding:16px;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer">
    Adicionar créditos
  </button>
</div>

<!-- HISTÓRICO -->
<% if(user.matchCoinsTransacoes && user.matchCoinsTransacoes.length > 0) { %>
<div class="card">
  <h2 style="font-size:15px;font-weight:700;margin-bottom:16px">Histórico</h2>
  <% user.matchCoinsTransacoes.slice().reverse().slice(0,15).forEach(t=>{ %>
  <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid #f3f4f6">
    <div>
      <div style="font-size:13px;font-weight:600;color:#111"><%= t.motivo || 'Movimentação' %></div>
      <div style="font-size:12px;color:#888"><%= t.data ? new Date(t.data).toLocaleString('pt-BR') : '' %></div>
    </div>
    <div style="font-weight:700;font-size:15px;color:<%= t.quantidade>0?'#16a34a':'#ef4444' %>">
      <%= t.quantidade>0?'+':'' %><%= t.quantidade %>
    </div>
  </div>
  <% }) %>
</div>
<% } %>

<script>
let valorSelecionado = 0;

function selecionarValor(v) {
  valorSelecionado = v;
  document.getElementById('valorInput').value = v;
  document.getElementById('creditosPreview').innerText = (v * 10) + ' créditos';
  document.querySelectorAll('[data-val]').forEach(b => {
    const sel = parseInt(b.dataset.val) === v;
    b.style.border = sel ? '2px solid #FF385C' : '2px solid #e5e7eb';
    b.style.background = sel ? '#fff1f3' : '#fff';
    b.style.color = sel ? '#FF385C' : '#111';
  });
}

document.getElementById('valorInput').addEventListener('input', function() {
  const v = parseFloat(this.value) || 0;
  valorSelecionado = v;
  document.getElementById('creditosPreview').innerText = Math.floor(v * 10) + ' créditos';
  document.querySelectorAll('[data-val]').forEach(b => {
    b.style.border = '2px solid #e5e7eb';
    b.style.background = '#fff';
    b.style.color = '#111';
  });
});

function iniciarCompra() {
  if (!valorSelecionado || valorSelecionado < 5) {
    alert('Valor mínimo é R$5.');
    return;
  }
  alert('Em breve! Integração com pagamento chegando.\nVocê receberá ' + Math.floor(valorSelecionado * 10) + ' créditos por R$' + valorSelecionado.toFixed(2).replace('.', ','));
}
</script>

<%- include('partials/app-end') %>
