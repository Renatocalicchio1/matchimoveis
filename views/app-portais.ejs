<%- include("partials/app-shell",{active:"portais",title:"Portais & XML",subtitle:"Copie o link XML de cada portal e envie para integração.",user:user}) %>

<div class="card">
  <h3 style="margin-bottom:8px">📡 Links XML dos portais</h3>
  <p style="color:#666;margin-bottom:20px">
    Escolha os portais dentro do imóvel. Ao salvar, o sistema gera automaticamente o XML no padrão VivaReal/VRSync.
  </p>

  <% const base = 'http://localhost:3000'; %>

  <div class="xml-list">
    <% [
      ['OLX', 'olx'],
      ['ZAP Imóveis', 'zap'],
      ['VivaReal', 'vivareal'],
      ['Chaves na Mão', 'chaves'],
      ['ImovelWeb', 'imovelweb'],
      ['123i', '123i']
    ].forEach(([nome, slug]) => { %>

      <div class="xml-item">
        <div>
          <strong><%= nome %></strong>
          <p>Copie este link e envie para o portal <%= nome %>:</p>
          <a href="<%= base %>/feed-<%= slug %>.xml" target="_blank"><%= base %>/feed-<%= slug %>.xml</a>
        </div>

        <button class="btn btn-primary" type="button" onclick="copiarXML('<%= base %>/feed-<%= slug %>.xml')">
          Copiar link
        </button>
      </div>

    <% }) %>
  </div>
</div>

<script>
function copiarXML(link){
  navigator.clipboard.writeText(link).then(()=>{
    alert('Link XML copiado: ' + link);
  });
}
</script>

<style>
.xml-list{
  display:flex;
  flex-direction:column;
  gap:14px;
}
.xml-item{
  display:flex;
  justify-content:space-between;
  gap:16px;
  align-items:center;
  padding:16px;
  border:1px solid #eee;
  border-radius:14px;
  background:#fafafa;
}
.xml-item strong{
  font-size:16px;
}
.xml-item p{
  margin:6px 0;
  font-size:13px;
  color:#666;
}
.xml-item a{
  font-size:13px;
  color:#2563eb;
  text-decoration:none;
  word-break:break-all;
}
.xml-item a:hover{
  text-decoration:underline;
}
@media(max-width:700px){
  .xml-item{
    flex-direction:column;
    align-items:flex-start;
  }
}
</style>
