<%- include('partials/app-shell',{active:'leads',title:'Detalhe da Lead',subtitle:'',user:user}) %>

<style>
.ld-layout{display:grid;grid-template-columns:1fr 320px;gap:24px;max-width:980px;margin:0 auto}
.ld-card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:24px;margin-bottom:16px}
.ld-title{font-size:11px;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:.8px;margin-bottom:14px}
.info-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px}
.info-row:last-child{border:none}
.info-lbl{color:var(--gray)}
.info-val{font-weight:600;color:var(--dark)}
.match-card{background:var(--light);border-radius:12px;padding:14px;margin-bottom:10px;display:grid;grid-template-columns:72px 1fr auto;gap:12px;align-items:center}
.match-foto{width:72px;height:54px;object-fit:cover;border-radius:8px}
.match-placeholder{width:72px;height:54px;border-radius:8px;background:#e5e7eb;display:flex;align-items:center;justify-content:center;font-size:22px}
.chip-spec{display:inline-block;background:var(--white);border:1px solid var(--border);border-radius:20px;padding:2px 10px;font-size:12px;font-weight:600;margin:2px}
.btn-acao{display:flex;align-items:center;gap:8px;padding:12px 14px;border-radius:10px;font-weight:600;font-size:14px;text-decoration:none;margin-bottom:10px;transition:opacity .2s}
.btn-acao:hover{opacity:.85}
</style>

<div style="max-width:980px;margin:0 auto">
  <div style="margin-bottom:20px">
    <a href="/app/leads" style="color:var(--gray);font-size:13px;text-decoration:none">← Voltar para Leads</a>
  </div>

  <div class="ld-layout">

    <div>
      <%# DADOS DA LEAD %>
      <div class="ld-card">
        <div class="ld-title">👤 Dados da Lead</div>
        <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px">
          <div style="width:52px;height:52px;border-radius:50%;background:var(--brand);display:flex;align-items:center;justify-content:center;color:#fff;font-size:20px;font-weight:800;flex-shrink:0">
            <%= (lead.nome||'?')[0].toUpperCase() %>
          </div>
          <div>
            <div style="font-size:19px;font-weight:800;color:var(--dark)"><%= lead.nome || 'Sem nome' %></div>
            <div style="font-size:12px;color:var(--gray);margin-top:3px">
              <% if(lead.fonte) { %><span style="background:#eff6ff;color:#2563eb;font-size:11px;font-weight:700;padding:2px 8px;border-radius:20px;margin-right:4px"><%= lead.fonte %></span><% } %>
              <% if(lead.canal) { %><span style="background:#f0fdf4;color:#16a34a;font-size:11px;font-weight:700;padding:2px 8px;border-radius:20px"><%= lead.canal %></span><% } %>
            </div>
          </div>
        </div>
        <% if(lead.contato||lead.telefone) { %><div class="info-row"><span class="info-lbl">Celular</span><span class="info-val"><a href="tel:<%= lead.contato||lead.telefone %>" style="color:var(--dark)"><%= lead.contato||lead.telefone %></a></span></div><% } %>
        <% if(lead.email) { %><div class="info-row"><span class="info-lbl">Email</span><span class="info-val"><%= lead.email %></span></div><% } %>
        <% if(lead.data_cadastro_br) { %><div class="info-row"><span class="info-lbl">Cadastro</span><span class="info-val"><%= lead.data_cadastro_br %></span></div><% } %>
        <% if(lead.origem) { %><div class="info-row"><span class="info-lbl">Origem</span><span class="info-val"><%= lead.origem.replace(/_/g,' ') %></span></div><% } %>
      </div>

      <%# IMÓVEL QUE GEROU A LEAD %>
      <% if(lead.imovel_interesse) { %>
      <div class="ld-card">
        <div class="ld-title">🏠 Imóvel que Gerou a Lead</div>
        <div class="info-row"><span class="info-lbl">Referência</span><span class="info-val">#<%= lead.imovel_interesse %></span></div>
        <% if(lead.titulo_interesse) { %><div class="info-row"><span class="info-lbl">Título</span><span class="info-val" style="font-size:12px;text-align:right;max-width:200px"><%= lead.titulo_interesse %></span></div><% } %>
        <% if(lead.tipo) { %><div class="info-row"><span class="info-lbl">Tipo</span><span class="info-val"><%= lead.tipo %></span></div><% } %>
        <% if(lead.bairro) { %><div class="info-row"><span class="info-lbl">Bairro</span><span class="info-val"><%= lead.bairro %></span></div><% } %>
        <% if(lead.valor_imovel) { %><div class="info-row"><span class="info-lbl">Valor</span><span class="info-val" style="color:var(--brand)">R$ <%= Number(lead.valor_imovel).toLocaleString('pt-BR') %></span></div><% } %>
        <div style="margin-top:14px">
          <a href="/imovel/<%= lead.imovel_interesse %>" target="_blank" style="display:inline-flex;align-items:center;gap:6px;padding:10px 16px;background:var(--brand);color:#fff;border-radius:10px;font-size:13px;font-weight:700;text-decoration:none">
            🔗 Ver imóvel completo
          </a>
        </div>
      </div>
      <% } %>

      <%# PERFIL DE BUSCA %>
      <div class="ld-card">
        <div class="ld-title">🔍 Perfil de Busca</div>
        <% if(lead.tipo) { %><div class="info-row"><span class="info-lbl">Tipo</span><span class="info-val"><%= lead.tipo %></span></div><% } %>
        <% if(lead.bairro) { %><div class="info-row"><span class="info-lbl">Bairro</span><span class="info-val"><%= lead.bairro %></span></div><% } %>
        <% if(lead.cidade) { %><div class="info-row"><span class="info-lbl">Cidade</span><span class="info-val"><%= lead.cidade %></span></div><% } %>
        <% if(lead.valor_imovel) { %><div class="info-row"><span class="info-lbl">Valor</span><span class="info-val">R$ <%= Number(lead.valor_imovel).toLocaleString('pt-BR') %></span></div><% } %>
        <% if(lead.area_m2) { %><div class="info-row"><span class="info-lbl">Área</span><span class="info-val"><%= lead.area_m2 %>m²</span></div><% } %>
        <div style="margin-top:12px;display:flex;flex-wrap:wrap">
          <% if(lead.quartos) { %><span class="chip-spec">🛏 <%= lead.quartos %> quartos</span><% } %>
          <% if(lead.suites) { %><span class="chip-spec">⭐ <%= lead.suites %> suítes</span><% } %>
          <% if(lead.vagas) { %><span class="chip-spec">🚗 <%= lead.vagas %> vagas</span><% } %>
          <% if(lead.banheiros) { %><span class="chip-spec">🚿 <%= lead.banheiros %> banheiros</span><% } %>
        </div>

<div class="ld-card">
  <div class="ld-title">📊 Comportamento da Lead</div>
  <% if (lead.historico && lead.historico.length) { %>
    <% lead.historico.slice().reverse().forEach(h => { %>
      <div class="info-row">
        <span class="info-lbl"><%= h.acao %></span>
        <span class="info-val"><%= new Date(h.data).toLocaleString('pt-BR') %></span>
      </div>
    <% }) %>
  <% } else { %>
    <div style="color:var(--gray);font-size:13px">Nenhuma ação registrada</div>
  <% } %>
</div>


      <div class="ld-card">
        <div class="ld-title">✅ Imóveis Compatíveis (<%= (lead.matches||[]).length %>)</div>
        <% if(!(lead.matches||[]).length) { %>
          <div style="text-align:center;padding:20px;color:var(--gray);font-size:14px">Nenhum match encontrado ainda.</div>
        <% } else { %>
          <% (lead.matches||[]).forEach(m => { %>
          <div class="match-card">
            <% if(m.fotos && m.fotos[0]) { %>
              <img class="match-foto" src="<%= m.fotos[0] %>">
            <% } else { %>
              <div class="match-placeholder">🏠</div>
            <% } %>
            <div>
              <div style="font-size:13px;font-weight:700;color:var(--dark);margin-bottom:2px"><%= m.tipo %> · <%= m.bairro %></div>
              <div style="font-size:12px;color:var(--gray)"><%= m.area_m2 %>m² · <%= m.quartos %> qtos<% if(m.suites) { %> · <%= m.suites %> suítes<% } %> · <%= m.vagas %> vaga(s)</div>
              <a href="/imovel/<%= m.idExterno %>" target="_blank" style="font-size:12px;color:var(--brand);font-weight:600;text-decoration:none">Ver imóvel →</a>
            </div>
            <div style="font-size:14px;font-weight:800;color:var(--brand);text-align:right;white-space:nowrap">R$ <%= Number(m.valor_imovel||0).toLocaleString('pt-BR') %></div>
          </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <%# COLUNA LATERAL %>
    <div>
      <div class="ld-card">
        <div class="ld-title">⚡ Ações</div>
        <% if(lead.contato||lead.telefone) { %>
        <a href="https://wa.me/55<%= (lead.contato||lead.telefone||'').replace(/\D/g,'') %>?text=<%= encodeURIComponent('Olá ' + (lead.nome||'') + '! Temos imóveis compatíveis com seu perfil no MatchImóveis.') %>" target="_blank" class="btn-acao" style="background:#25D366;color:#fff">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <a href="tel:<%= (lead.contato||lead.telefone||'').replace(/\D/g,'') %>" class="btn-acao" style="background:#f0f0f0;color:var(--dark)">
          📞 Ligar
        </a>
        <% } %>
        <% if((lead.matches||[]).length) { %>
        <a href="https://wa.me/55<%= (lead.contato||lead.telefone||'').replace(/\D/g,'') %>?text=<%= encodeURIComponent('Olá ' + (lead.nome||'') + '! Separamos algumas oportunidades semelhantes ao que você buscou. Veja sua vitrine: http://localhost:3000/cliente/oferta/' + lead.id + ' e agende sua visita!') %>" target="_blank" class="btn-acao" style="background:var(--brand);color:#fff">
          🔗 Enviar vitrine de oportunidades
        </a>
        <% } %>
      </div>

      <div class="ld-card">
        <div class="ld-title">📋 Resumo</div>
        <div class="info-row"><span class="info-lbl">ID</span><span class="info-val" style="font-size:11px"><%= lead.id %></span></div>
        <div class="info-row"><span class="info-lbl">Matches</span><span class="info-val"><%= (lead.matches||[]).length %></span></div>
        <% if(lead.data_cadastro_br) { %><div class="info-row"><span class="info-lbl">Cadastrado em</span><span class="info-val" style="font-size:11px"><%= lead.data_cadastro_br %></span></div><% } %>
      </div>
    </div>

  </div>
</div>

<%- include('partials/app-end') %>
