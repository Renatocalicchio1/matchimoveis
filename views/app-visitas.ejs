<%- include("partials/app-shell",{active:"visitas",user:user}) %>

<main style="padding:30px">
  <div class="card" style="background:white;border-radius:16px;padding:24px;box-shadow:0 6px 20px rgba(0,0,0,.08)">
    <h1>Visitas solicitadas</h1>

    <% if (!visitas || visitas.length === 0) { %>
      <div style="padding:30px;text-align:center;color:#666">Nenhuma visita solicitada ainda.</div>
    <% } else { %>

      <table style="width:100%;border-collapse:collapse;margin-top:20px">
        <thead>
          <tr>
            <th style="text-align:left;padding:10px;border-bottom:1px solid #eee">Cliente</th>
            <th style="text-align:left;padding:10px;border-bottom:1px solid #eee">Telefone</th>
            <th style="text-align:left;padding:10px;border-bottom:1px solid #eee">Imóvel</th>
            <th style="text-align:left;padding:10px;border-bottom:1px solid #eee">Data</th>
            <th style="text-align:left;padding:10px;border-bottom:1px solid #eee">Horário</th>
            <th style="text-align:left;padding:10px;border-bottom:1px solid #eee">Status</th>
            <th style="text-align:left;padding:10px;border-bottom:1px solid #eee">Ação</th>
          </tr>
        </thead>

        <tbody>
          <% visitas.forEach((v, idx) => {
            const clienteNome = v.nome || v.cliente?.nome || v.leadNome || '-';
            const clienteTelefone = v.telefone || v.contato || v.cliente?.telefone || v.cliente?.celular || '-';

            const imovelId = v.imovelId || v.imovel_id || v.idImovel || v.imovel?.idExterno || v.imovel?.id || '';
            const imovelTitulo = v.imovelTitulo || v.titulo_interesse || v.imovel?.titulo || v.imovel?.tipo || 'Imóvel';
            const imovelBairro = v.imovelBairro || v.bairro || v.imovel?.bairro || '-';
            const imovelCidade = v.imovelCidade || v.cidade || v.imovel?.cidade || '-';
            const imovelEstado = v.imovelEstado || v.estado || v.imovel?.estado || '-';

            const dataBr = v.data_br || (v.data ? new Date(v.data).toLocaleString('pt-BR') : '');
            const dataVisita = v.dataVisita || v.dataPreferida || v.data_agendada || (dataBr ? dataBr.split(',')[0] : '-');
            const horaVisita = v.horaVisita || v.horarioPreferido || v.hora_agendada || (dataBr && dataBr.includes(',') ? dataBr.split(',')[1].trim() : '-');

            const linkImovel = v.imovelUrl || v.url || v.imovel?.url || (imovelId ? '/imovel/' + imovelId : '');
          %>
            <tr>
              <td style="padding:10px;border-bottom:1px solid #eee"><%= clienteNome %></td>
              <td style="padding:10px;border-bottom:1px solid #eee"><%= clienteTelefone %></td>
              <td style="padding:10px;border-bottom:1px solid #eee">
                <strong><%= imovelTitulo %></strong><br>
                <%= imovelBairro %> - <%= imovelCidade %>/<%= imovelEstado %><br>
                <% if (linkImovel) { %>
                  <a href="<%= linkImovel %>" target="_blank">Ver imóvel</a>
                <% } %>
              </td>
              <td style="padding:10px;border-bottom:1px solid #eee"><%= dataVisita %></td>
              <td style="padding:10px;border-bottom:1px solid #eee"><%= horaVisita %></td>
              <td style="padding:10px;border-bottom:1px solid #eee"><%= v.status || 'solicitada' %></td>
              <td style="padding:10px;border-bottom:1px solid #eee">
                <div style="display:flex;flex-direction:column;gap:8px">

                <%
                  const propTel = (v.proprietarioTelefone || v.proprietario_telefone || '').replace(/D/g,'');
                  const propNome = v.proprietarioNome || v.proprietario_nome || '';
                  const corretorNome = user.nome || user.name || 'Corretor';
                  const imovelDonoId = v.imovelUsuarioId || '';
                  const ehImovelParceiro = imovelDonoId && imovelDonoId !== (user.id || user.userId || '');
                  const parceirTel = (v.imovelUsuarioTelefone || '').replace(/D/g,'');
                  const parceiroNome = v.imovelUsuarioNome || 'Corretor parceiro';
                  const msgProp = 'Olá ' + propNome + '! Sou ' + corretorNome + ', corretor parceiro. Tenho um cliente interessado no seu imóvel ' + (v.imovelTitulo || v.imovelBairro || '') + ' e gostaria de agendar uma visita para o dia ' + (v.dataVisita || dataVisita) + ' às ' + (v.horaVisita || horaVisita) + '. Confirme sua disponibilidade aqui: https://matchimoveis.onrender.com/proprietario/visita/' + v.id;
                  const msgParceiro = 'Olá ' + parceiroNome + '! Sou ' + corretorNome + ' da MatchImóveis. Tenho um cliente interessado no seu imóvel ' + (v.imovelTitulo || v.imovelBairro || '') + ' e gostaria de agendar uma visita para o dia ' + (v.dataVisita || dataVisita) + ' às ' + (v.horaVisita || horaVisita) + '. Confirme sua disponibilidade aqui: https://matchimoveis.onrender.com/proprietario/visita/' + v.id;
                  const telCliente = (v.telefone || v.contato || '').replace(/\D/g,'');
                  const msgCliente = 'Olá ' + (v.nome || 'cliente') + '! Sua visita ao imóvel ' + (v.imovelTitulo || v.imovelBairro || '') + ' foi confirmada para ' + (v.dataVisita || dataVisita) + (v.horaVisita ? ' às ' + v.horaVisita : '') + '. Confirme sua presença aqui: https://matchimoveis.onrender.com/cliente/visita/' + v.id + '/confirmar';
                %>

                <% if (v.status === 'lead_confirmou') { %>
                  <strong style='color:green'>✅ Lead confirmou presença</strong>
                <% } else if (v.status === 'lead_recusou') { %>
                  <strong style='color:red'>❌ Lead não comparecerá</strong>
                <% } else if (v.status === 'confirmada') { %>
                  <strong style="color:green">✅ Confirmada</strong>
                  <% if (telCliente) { %>
                    <a href="https://wa.me/55<%= telCliente %>?text=<%= encodeURIComponent(msgCliente) %>" target="_blank" style="background:#25D366;color:white;padding:8px 12px;border-radius:8px;text-decoration:none;text-align:center;font-size:13px">
                      📲 Notificar Cliente
                    </a>
                  <% } %>
                <% } else if (v.status === 'cancelada') { %>
                  <strong style="color:red">❌ Cancelada</strong>
                <% } else if (v.status === 'pendente_remarcar') { %>
                  <strong style="color:orange">📅 Remarcar</strong>
                <% } else { %>
                  <strong style="color:#888">⏳ Aguardando</strong>
                  <% if (ehImovelParceiro && parceirTel) { %>
                    <a href="https://wa.me/55<%= parceirTel %>?text=<%= encodeURIComponent(msgParceiro) %>" target="_blank" style="background:#FF385C;color:white;padding:8px 12px;border-radius:8px;text-decoration:none;text-align:center;font-size:13px">
                      📲 Falar com Corretor Parceiro
                    </a>
                  <% } else if (propTel) { %>
                    <a href="https://wa.me/55<%= propTel %>?text=<%= encodeURIComponent(msgProp) %>" target="_blank" style="background:#25D366;color:white;padding:8px 12px;border-radius:8px;text-decoration:none;text-align:center;font-size:13px">
                      📲 Notificar Proprietário
                    </a>
                  <% } else { %>
                    <form method="POST" action="/app/visitas/confirmar/<%= v.id %>" style="margin:0">
                      <button type="submit" style="background:#f59e0b;color:white;border:none;padding:8px 12px;border-radius:8px;cursor:pointer;font-size:13px;width:100%">
                        ✅ Confirmar Visita
                      </button>
                    </form>
                  <% } %>
                <% } %>

                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>

    <% } %>
  </div>
</main>

<%- include('partials/app-end') %>
