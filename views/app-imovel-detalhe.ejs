<%- include('partials/app-shell',{active:'imoveis',title:'Detalhes do Imóvel',subtitle:'',user:user}) %>

<style>
.hero{display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:220px 220px;gap:4px;border-radius:16px;overflow:hidden;margin-bottom:24px}
.hero img{width:100%;height:100%;object-fit:cover;cursor:pointer;transition:opacity .15s}
.hero img:hover{opacity:.92}
.hero img:first-child{grid-row:1/3}

.layout{display:grid;grid-template-columns:1fr 300px;gap:20px;max-width:960px;margin:0 auto}
@media(max-width:720px){.layout{grid-template-columns:1fr}}

.dc{background:#fff;border:0.5px solid rgba(0,0,0,.08);border-radius:16px;padding:20px;margin-bottom:12px}
.dc-label{font-size:11px;font-weight:500;color:#9ca3af;text-transform:uppercase;letter-spacing:.05em;margin-bottom:12px}

.spec-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:10px;margin-top:14px}
.spec-item{background:#f9fafb;border:0.5px solid rgba(0,0,0,.06);border-radius:10px;padding:12px 8px;text-align:center}
.spec-val{font-weight:500;font-size:15px;color:#111827;margin-bottom:2px}
.spec-lbl{font-size:11px;color:#9ca3af}

.info-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:0.5px solid rgba(0,0,0,.06);font-size:13px}
.info-row:last-child{border:none}
.info-lbl{color:#9ca3af}
.info-val{font-weight:500;color:#111827}

.prop-card{background:#fff;border:0.5px solid rgba(0,0,0,.08);border-radius:16px;padding:20px;margin-bottom:12px}
.prop-btn{display:flex;align-items:center;gap:8px;padding:9px 14px;border-radius:8px;font-size:13px;font-weight:500;text-decoration:none;margin-bottom:8px;transition:opacity .15s}
.prop-btn:hover{opacity:.85}
.prop-wpp{background:#22c55e;color:#fff}
.prop-tel{background:#f9fafb;color:#374151;border:0.5px solid rgba(0,0,0,.1)}
.prop-email{background:#eff6ff;color:#2563eb;border:0.5px solid #bfdbfe}

.badge-tipo{display:inline-block;background:#eef2ff;color:#4338ca;font-size:11px;font-weight:500;padding:3px 10px;border-radius:999px;margin-bottom:10px}

.lb{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:9999;align-items:center;justify-content:center}
.lb-close{position:absolute;top:16px;right:20px;background:none;border:none;color:#fff;font-size:28px;cursor:pointer;opacity:.7}
.lb-close:hover{opacity:1}
.lb-nav{position:absolute;background:rgba(255,255,255,.1);border:none;color:#fff;font-size:26px;width:44px;height:44px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center}
.lb-nav:hover{background:rgba(255,255,255,.2)}
.lb-nav.prev{left:16px}
.lb-nav.next{right:16px}
</style>

<div style="max-width:960px;margin:0 auto">

<% if(imovel.fotos && imovel.fotos.length > 0){ %>
<div class="hero">
  <img src="<%= imovel.fotos[0] %>" onclick="abrirGaleria(0)">
  <% if(imovel.fotos[1]){ %><img src="<%= imovel.fotos[1] %>" onclick="abrirGaleria(1)"><% } %>
  <% if(imovel.fotos[2]){ %><img src="<%= imovel.fotos[2] %>" onclick="abrirGaleria(2)"><% } %>
  <% if(imovel.fotos[3]){ %><img src="<%= imovel.fotos[3] %>" onclick="abrirGaleria(3)"><% } %>
  <% if(imovel.fotos[4]){ %>
    <div style="position:relative;cursor:pointer;overflow:hidden" onclick="abrirGaleria(4)">
      <img src="<%= imovel.fotos[4] %>" style="width:100%;height:100%;object-fit:cover">
      <% if(imovel.fotos.length > 5){ %>
      <div style="position:absolute;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;color:#fff;font-size:20px;font-weight:500">+<%= imovel.fotos.length-5 %> fotos</div>
      <% } %>
    </div>
  <% } %>
</div>

<div id="lightbox" class="lb">
  <button class="lb-close" onclick="fecharLightbox()">✕</button>
  <button class="lb-nav prev" onclick="navFoto(-1)">‹</button>
  <img id="lb-img" style="max-width:90vw;max-height:88vh;object-fit:contain;border-radius:8px">
  <button class="lb-nav next" onclick="navFoto(1)">›</button>
  <div id="lb-counter" style="position:absolute;bottom:16px;color:#fff;font-size:13px;opacity:.6"></div>
</div>

<script>
const fotos=<%- JSON.stringify(imovel.fotos||[]) %>;
let fotoAtual=0;
function abrirGaleria(idx){fotoAtual=idx;document.getElementById('lightbox').style.display='flex';atualizarLb();}
function fecharLightbox(){document.getElementById('lightbox').style.display='none';}
function navFoto(dir){fotoAtual=(fotoAtual+dir+fotos.length)%fotos.length;atualizarLb();}
function atualizarLb(){document.getElementById('lb-img').src=fotos[fotoAtual];document.getElementById('lb-counter').textContent=(fotoAtual+1)+' / '+fotos.length;}
document.getElementById('lightbox').addEventListener('click',function(e){if(e.target===this)fecharLightbox();});
document.addEventListener('keydown',e=>{if(e.key==='Escape')fecharLightbox();if(e.key==='ArrowLeft')navFoto(-1);if(e.key==='ArrowRight')navFoto(1);});
</script>
<% } %>

<div class="layout">

  <!-- Coluna principal -->
  <div>

    <!-- Título e valor -->
    <div class="dc">
      <span class="badge-tipo"><%= imovel.tipo %></span>
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap">
        <div>
          <h1 style="font-size:20px;font-weight:600;margin:0 0 6px;line-height:1.3;color:#111827"><%= imovel.titulo||(imovel.tipo+' em '+imovel.bairro) %></h1>
          <p style="color:#9ca3af;font-size:13px;margin:0">
            <% if(imovel.endereco){ %><%= imovel.endereco %> · <% } %>
            <%= imovel.bairro %><% if(imovel.cidade){ %>, <%= imovel.cidade %><% } %>
          </p>
        </div>
        <div style="text-align:right;flex-shrink:0">
          <div style="font-size:24px;font-weight:600;color:#111827">R$ <%= Number(imovel.valor_imovel||0).toLocaleString('pt-BR') %></div>
          <% if(imovel.condominio && imovel.condominio>0){ %>
          <div style="font-size:12px;color:#9ca3af;margin-top:2px">+ R$ <%= Number(imovel.condominio).toLocaleString('pt-BR') %>/mês cond.</div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Características -->
    <div class="dc">
      <p class="dc-label">Características</p>
      <div class="spec-grid">
        <% if(imovel.area_m2){ %>
        <div class="spec-item"><div class="spec-val"><%= imovel.area_m2 %>m²</div><div class="spec-lbl">Área</div></div>
        <% } %>
        <% if(imovel.quartos){ %>
        <div class="spec-item"><div class="spec-val"><%= imovel.quartos %></div><div class="spec-lbl">Quartos</div></div>
        <% } %>
        <% if(imovel.suites){ %>
        <div class="spec-item"><div class="spec-val"><%= imovel.suites %></div><div class="spec-lbl">Suítes</div></div>
        <% } %>
        <% if(imovel.banheiros){ %>
        <div class="spec-item"><div class="spec-val"><%= imovel.banheiros %></div><div class="spec-lbl">Banheiros</div></div>
        <% } %>
        <% if(imovel.vagas){ %>
        <div class="spec-item"><div class="spec-val"><%= imovel.vagas %></div><div class="spec-lbl">Vagas</div></div>
        <% } %>
        <% if(imovel.andar){ %>
        <div class="spec-item"><div class="spec-val"><%= imovel.andar %>º</div><div class="spec-lbl">Andar</div></div>
        <% } %>
      </div>
    </div>

    <!-- Descrição -->
    <% if(imovel.descricao){ %>
    <div class="dc">
      <p class="dc-label">Descrição</p>
      <p style="color:#374151;line-height:1.8;font-size:14px;white-space:pre-line;margin:0"><%= imovel.descricao %></p>
    </div>
    <% } %>

    <!-- Diferenciais -->
    <% const _difs=imovel.diferenciais||{}; const _dKeys=Object.keys(_difs).filter(k=>_difs[k]); %>
    <% if(_dKeys.length>0){ %>
    <div class="dc">
      <p class="dc-label">Diferenciais</p>
      <div style="display:flex;flex-wrap:wrap;gap:6px">
        <% _dKeys.forEach(k=>{ %>
        <span style="background:#f9fafb;border:0.5px solid rgba(0,0,0,.08);border-radius:999px;padding:5px 12px;font-size:12px;color:#374151"><%= k.replace(/_/g,' ') %></span>
        <% }) %>
      </div>
    </div>
    <% } %>

  </div>

  <!-- Coluna lateral -->
  <div>

    <!-- Proprietário -->
    <% if(imovel.proprietario && (user.tipo==='admin'||user.tipo==='corretor'||user.tipo==='imobiliaria'||user.tipo==='construtora')){ %>
    <div class="prop-card">
      <p class="dc-label">Proprietário</p>
      <div style="font-size:15px;font-weight:500;color:#111827;margin-bottom:12px"><%= imovel.proprietario?.nome||'-' %></div>
      <% if(imovel.proprietario?.celular||imovel.proprietario?.telefone){ %>
      <a href="https://wa.me/55<%= ((imovel.proprietario?.celular||imovel.proprietario?.telefone||'').replace(/\D/g,'')) %>" target="_blank" class="prop-btn prop-wpp">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
      <a href="tel:<%= imovel.proprietario?.celular||imovel.proprietario?.telefone %>" class="prop-btn prop-tel">
        <%= imovel.proprietario?.celular||imovel.proprietario?.telefone %>
      </a>
      <% } %>
      <% if(imovel.proprietario?.email){ %>
      <a href="mailto:<%= imovel.proprietario?.email %>" class="prop-btn prop-email"><%= imovel.proprietario?.email %></a>
      <% } %>
    </div>
    <% } %>

    <!-- Corretor -->
    <% if(imovel.corretor_nome){ %>
    <div class="dc">
      <p class="dc-label">Corretor</p>
      <div style="font-size:14px;font-weight:500;color:#111827;margin-bottom:6px"><%= imovel.corretor_nome %></div>
      <% if(imovel.corretor_telefone){ %><div style="font-size:13px;color:#9ca3af"><%= imovel.corretor_telefone %></div><% } %>
      <% if(imovel.corretor_email){ %><div style="font-size:13px;color:#9ca3af"><%= imovel.corretor_email %></div><% } %>
    </div>
    <% } %>

    <!-- Informações -->
    <div class="dc">
      <p class="dc-label">Informações</p>
      <div class="info-row"><span class="info-lbl">ID</span><span class="info-val" style="font-family:monospace;font-size:12px"><%= imovel.codigoImovel||imovel.id||'-' %></span></div>
      <% if(imovel.fonte){ %><div class="info-row"><span class="info-lbl">Fonte</span><span class="info-val"><%= imovel.fonte %></span></div><% } %>
      <% if(imovel.transacao){ %><div class="info-row"><span class="info-lbl">Operação</span><span class="info-val"><%= imovel.transacao %></span></div><% } %>
      <% if(imovel.cep){ %><div class="info-row"><span class="info-lbl">CEP</span><span class="info-val"><%= imovel.cep %></span></div><% } %>
      <% if(imovel.iptu && imovel.iptu>0){ %><div class="info-row"><span class="info-lbl">IPTU</span><span class="info-val">R$ <%= Number(imovel.iptu).toLocaleString('pt-BR') %>/ano</span></div><% } %>
      <% const _dataCad=imovel.createdAt||imovel.dataCadastro||imovel.data_cadastro||imovel.importedAt; %>
      <% if(_dataCad){ %><div class="info-row"><span class="info-lbl">Cadastrado em</span><span class="info-val"><%= new Date(_dataCad).toLocaleDateString('pt-BR') %></span></div><% } %>
    </div>

    <!-- Ações -->
    <div style="display:flex;flex-direction:column;gap:8px">
      <a href="/app/imovel/<%= imovel.idExterno||imovel.id %>/editar" style="display:block;text-align:center;padding:10px;border-radius:8px;background:#111827;color:#fff;font-size:13px;font-weight:500;text-decoration:none">Editar imóvel</a>
      <a href="/app/imoveis" style="display:block;text-align:center;padding:10px;border-radius:8px;border:0.5px solid rgba(0,0,0,.1);color:#6b7280;font-size:13px;text-decoration:none">← Voltar</a>
    </div>

  </div>
</div>
</div>

<%- include('partials/app-end') %>
