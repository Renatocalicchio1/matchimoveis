<%- include("partials/app-shell",{active:"assistente",user:user}) %>

<main style="height:calc(100vh - 80px);display:flex;flex-direction:column;padding:24px">
  <div style="background:white;border-radius:20px;box-shadow:0 6px 20px rgba(0,0,0,.08);display:flex;flex-direction:column;height:100%;overflow:hidden">
    <div style="padding:20px 24px;border-bottom:1px solid #f3f4f6;display:flex;align-items:center;gap:12px">
      <div style="width:42px;height:42px;background:linear-gradient(135deg,#ff385c,#ff6b35);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px">🤖</div>
      <div><div style="font-weight:800;font-size:16px">Assistente MatchImóveis</div><div style="font-size:12px;color:#22c55e;font-weight:600">● Online</div></div>
    </div>
    <div id="chat-messages" style="flex:1;overflow-y:auto;padding:24px;display:flex;flex-direction:column;gap:16px">
      <div class="msg bot"><div class="bubble bot-bubble">Olá, <strong><%= user.nome || user.name || 'corretor' %></strong>! 👋<br>Sou o assistente do MatchImóveis. O que você precisa?</div></div>
    </div>
    <div style="padding:0 24px 12px;display:flex;gap:8px;flex-wrap:wrap">
      <button onclick="enviarMsg('quantas leads tenho')" class="sug-btn">📊 Stats</button>
      <button onclick="enviarMsg('importar leads')" class="sug-btn">📋 Leads</button>
      <button onclick="enviarMsg('leads com match')" class="sug-btn">🎯 Match</button>
      <button onclick="enviarMsg('visitas hoje')" class="sug-btn">📅 Visitas</button>
      <button onclick="enviarMsg('ajuda')" class="sug-btn">❓ Ajuda</button>
    </div>
    <div style="padding:16px 24px;border-top:1px solid #f3f4f6;display:flex;gap:12px;align-items:center">
      <input type="file" id="file-input" accept=".xml,.xlsx,.xls,.csv" style="display:none" onchange="uploadArquivo(this)">
      <button onclick="document.getElementById('file-input').click()" style="background:#f3f4f6;border:none;border-radius:12px;padding:12px;cursor:pointer;font-size:18px">📎</button>
      <input id="chat-input" type="text" placeholder="Digite sua mensagem..." style="flex:1;padding:12px 16px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;outline:none" onkeydown="if(event.key==='Enter') enviarMsg()">
      <button onclick="enviarMsg()" style="background:#ff385c;color:white;border:none;border-radius:12px;padding:12px 20px;font-weight:700;cursor:pointer;font-size:16px">➤</button>
    </div>
  </div>
</main>
<style>
.msg{display:flex}.bubble{max-width:80%;padding:12px 16px;border-radius:16px;font-size:14px;line-height:1.7}
.bot-bubble{background:#f3f4f6;color:#111;border-bottom-left-radius:4px}
.user-bubble{background:#ff385c;color:white;border-bottom-right-radius:4px;margin-left:auto}
.msg.user{justify-content:flex-end}
.sug-btn{background:#f3f4f6;border:none;border-radius:20px;padding:8px 14px;font-size:12px;cursor:pointer;font-weight:600;color:#333}
</style>
<script>
const stats = <%- JSON.stringify(stats) %>;
function addMsg(t,tipo){const d=document.createElement('div');d.className='msg '+tipo;d.innerHTML='<div class="bubble '+tipo+'-bubble">'+t+'</div>';document.getElementById('chat-messages').appendChild(d);document.getElementById('chat-messages').scrollTop=99999;}
function typing(){const d=document.createElement('div');d.className='msg bot';d.id='typing';d.innerHTML='<div class="bubble bot-bubble" style="color:#999">⏳ pensando...</div>';document.getElementById('chat-messages').appendChild(d);document.getElementById('chat-messages').scrollTop=99999;}
function removeTyping(){const t=document.getElementById('typing');if(t)t.remove();}
async function enviarFeedback(util, btn){
  const container = btn.closest('[data-pergunta]');
  const pergunta  = container?.dataset.pergunta || '';
  const resposta  = container?.dataset.resposta || '';
  try{
    await fetch('/app/assistente/feedback',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({util, pergunta, resposta})
    });
    container.innerHTML = '<span style="font-size:12px;color:'+( util ? '#4caf50' : '#e91e63')+'">'+(util ? '✅ Ótimo! Obrigado pelo feedback.' : '📝 Entendido! Vou melhorar.')+' </span>';
  } catch(e){ console.error(e); }
}

async function enviarMsg(texto){
  const input=document.getElementById('chat-input');
  const msg=texto||input.value.trim();
  input.value='';
  addMsg(msg,'user');
  typing();
  try{
    const res=await fetch('/app/assistente/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mensagem:msg})});
    const data=await res.json();
    removeTyping();
    addMsg(data.resposta,'bot');
    // Sempre mostrar botão de feedback
    const feedDiv=document.createElement('div');
    feedDiv.className='msg bot';
    feedDiv.dataset.pergunta=msg;
    feedDiv.dataset.resposta=data.resposta;
    feedDiv.innerHTML='<div style="display:flex;align-items:center;gap:8px;margin-top:4px;flex-wrap:wrap">'+
      '<span style="font-size:11px;color:#aaa">Era isso que esperava?</span>'+
      '<button onclick="enviarFeedback(true,this)" style="background:#f0fdf4;border:1px solid #86efac;border-radius:20px;padding:2px 12px;font-size:11px;cursor:pointer;color:#166534">👍 Sim</button>'+
      '<button onclick="enviarFeedback(false,this)" style="background:#fff1f2;border:1px solid #fda4af;border-radius:20px;padding:2px 12px;font-size:11px;cursor:pointer;color:#9f1239">👎 Não</button>'+
      '</div>';
    document.getElementById('chat-messages').appendChild(feedDiv);
    document.getElementById('chat-messages').scrollTop=99999;
    if(data.precisaConfirmar){
      const feedDiv=document.createElement('div');
      feedDiv.className='msg bot';
      feedDiv.style.cssText='padding:4px 12px';
      feedDiv.innerHTML='<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:4px 0">' +
        '<span style="font-size:12px;color:#999">Era isso que você queria?</span>' +
        '<button onclick="enviarFeedback(true,this)" style="background:#e8f5e9;border:1px solid #4caf50;border-radius:20px;padding:3px 12px;font-size:12px;cursor:pointer;color:#2e7d32">👍 Sim</button>' +
        '<button onclick="enviarFeedback(false,this)" style="background:#fce4ec;border:1px solid #e91e63;border-radius:20px;padding:3px 12px;font-size:12px;cursor:pointer;color:#880e4f">👎 Não</button>' +
        '</div>';
      feedDiv.dataset.pergunta = msg;
      feedDiv.dataset.resposta = data.resposta;
      document.getElementById('chat-messages').appendChild(feedDiv);
    }
  }catch(e){removeTyping();addMsg('Erro ao conectar.','bot');}
}
async function uploadArquivo(input){
  addMsg('📎 '+file.name,'user');
  const nome=file.name.toLowerCase();
  const rota=nome.endsWith('.xml')?'/app/importar':'/app/leads';
  const label=nome.endsWith('.xml')?'XML de imóveis':'Planilha de leads';
  addMsg('⏳ Enviando '+label+'...','bot');
  const form=new FormData();
  form.append(nome.endsWith('.xml')?'xml':'leads',file);
  try{const res=await fetch(rota,{method:'POST',body:form});const txt=await res.text();const num=(txt.match(/d+/)||['?'])[0];addMsg('✅ '+label+' importado! '+num+' registros.','bot');}
  catch(e){addMsg('⚠️ Erro ao importar.','bot');}
  input.value='';
}
window.onload=async function(){
  try{const res=await fetch('/app/assistente/historico');const data=await res.json();
  if(data.historico&&data.historico.length>0){document.getElementById('chat-messages').innerHTML='';data.historico.forEach(function(h){addMsg(h.pergunta,'user');addMsg(h.resposta,'bot');});}}
  catch(e){}
};
</script>
<%- include('partials/app-end') %>