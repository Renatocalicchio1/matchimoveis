<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>Confirmar Presença • MatchImóveis</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <style>
    * { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; background:#f5f5f5; color:#222; display:flex; align-items:center; justify-content:center; min-height:100vh; }
    .card { background:#fff; border-radius:20px; padding:40px 32px; box-shadow:0 8px 30px rgba(0,0,0,.10); max-width:420px; width:90%; }
    .logo { color:#ff385c; font-size:18px; font-weight:800; margin-bottom:28px; display:block; }
    h1 { font-size:22px; font-weight:800; margin-bottom:8px; }
    .sub { color:#666; font-size:14px; margin-bottom:28px; }
    .info-row { display:flex; justify-content:space-between; padding:12px 0; border-bottom:1px solid #f3f4f6; font-size:15px; }
    .info-label { color:#888; }
    .info-val { font-weight:600; }
    .btns { display:flex; flex-direction:column; gap:12px; margin-top:28px; }
    .btn { padding:16px; border-radius:12px; border:none; font-size:16px; font-weight:700; cursor:pointer; width:100%; }
    .btn-confirmar { background:#22c55e; color:#fff; }
    .btn-recusar { background:#ef4444; color:#fff; }
  </style>
</head>
<body>
  <div class="card">
    <span class="logo">MatchImóveis</span>
    <h1>Sua visita foi confirmada!</h1>
    <p class="sub">Confirme sua presença para finalizar o agendamento.</p>

    <div class="info-row"><span class="info-label">Imóvel</span><span class="info-val"><%= visita.imovelTitulo || visita.imovelBairro %></span></div>
    <div class="info-row"><span class="info-label">Bairro</span><span class="info-val"><%= visita.imovelBairro %> - <%= visita.imovelCidade %></span></div>
    <div class="info-row"><span class="info-label">Data</span><span class="info-val"><%= visita.dataVisita || 'A confirmar' %></span></div>
    <div class="info-row"><span class="info-label">Horário</span><span class="info-val"><%= visita.horaVisita || 'A confirmar' %></span></div>

    <% if (visita.status === 'lead_confirmou') { %>
      <div style="margin-top:28px;text-align:center;">
        <div style="font-size:56px">✅</div>
        <p style="font-weight:700;font-size:18px;margin-top:12px">Presença confirmada!</p>
        <p style="color:#666;margin-top:8px">Até lá!</p>
      </div>
    <% } else if (visita.status === 'lead_recusou') { %>
      <div style="margin-top:28px;text-align:center;">
        <div style="font-size:56px">❌</div>
        <p style="font-weight:700;font-size:18px;margin-top:12px">Visita cancelada.</p>
        <p style="color:#666;margin-top:8px">O corretor será informado.</p>
      </div>
    <% } else { %>
      <div class="btns">
        <form method="POST" action="/cliente/visita/<%= visita.id %>/responder">
          <button class="btn btn-confirmar" name="resposta" value="confirmar">✅ Confirmo minha presença</button>
        </form>
        <form method="POST" action="/cliente/visita/<%= visita.id %>/responder">
          <button class="btn btn-recusar" name="resposta" value="recusar">❌ Não poderei comparecer</button>
        </form>
      </div>
    <% } %>
  </div>
</body>
</html>