<%- include("partials/app-shell",{active:"mapa",user:user,title:"Mapa de Imóveis"}) %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div style="position:relative;margin:-20px;height:calc(100vh - 60px)">
  <div style="position:absolute;top:12px;left:12px;z-index:1000;background:#fff;border-radius:10px;padding:10px 14px;box-shadow:0 2px 10px rgba(0,0,0,.12);font-size:13px;color:#111">
    <strong id="qtd">0</strong> bairros no mapa
  </div>
  <div style="position:absolute;top:12px;right:12px;z-index:1000;background:#fff;border-radius:10px;padding:10px 14px;box-shadow:0 2px 10px rgba(0,0,0,.12);font-size:12px">
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px"><div style="width:12px;height:12px;border-radius:50%;background:#FF385C"></div>Meus</div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px"><div style="width:12px;height:12px;border-radius:50%;background:#6366f1"></div>Parceiros</div>
    <div style="display:flex;align-items:center;gap:8px"><div style="width:12px;height:12px;border-radius:50%;background:#f59e0b"></div>Ambos</div>
  </div>
  <div id="mapa" style="width:100%;height:100%"></div>
</div>

<script>
const _grupos = <%- gruposJSON %>;
const _uLat = <%= user.lat || -26.9543 %>;
const _uLng = <%= user.lng || -48.6419 %>;

// Coordenadas hardcoded das principais cidades
const _cidadeCoords = {
  'itajai':{lat:-26.9078,lng:-48.6619},'itajaí':{lat:-26.9078,lng:-48.6619},
  'balneario camboriu':{lat:-26.9906,lng:-48.6348},'balneário camboriú':{lat:-26.9906,lng:-48.6348},
  'florianopolis':{lat:-27.5954,lng:-48.5480},'florianópolis':{lat:-27.5954,lng:-48.5480},
  'blumenau':{lat:-26.9194,lng:-49.0661},
  'joinville':{lat:-26.3044,lng:-48.8487},
  'navegantes':{lat:-26.8986,lng:-48.6539},
  'camboriu':{lat:-27.0239,lng:-48.6508},'camboriú':{lat:-27.0239,lng:-48.6508},
  'itapema':{lat:-27.0906,lng:-48.6119},
  'porto belo':{lat:-27.1578,lng:-48.5508},
  'sao paulo':{lat:-23.5505,lng:-46.6333},'são paulo':{lat:-23.5505,lng:-46.6333},
  'rio de janeiro':{lat:-22.9068,lng:-43.1729},
  'curitiba':{lat:-25.4290,lng:-49.2671},
  'belo horizonte':{lat:-19.9167,lng:-43.9345},
  'brasilia':{lat:-15.7797,lng:-47.9297},'brasília':{lat:-15.7797,lng:-47.9297},
};

// Offset por bairro para não sobrepor pins na mesma cidade
const _offsets = {};
function _offset(cidade) {
  _offsets[cidade] = (_offsets[cidade]||0) + 1;
  const n = _offsets[cidade];
  const ang = (n * 137.5) * Math.PI/180;
  const r = 0.005 * Math.ceil(n/8);
  return {dlat: r*Math.sin(ang), dlng: r*Math.cos(ang)};
}

const _map = L.map('mapa').setView([_uLat,_uLng],11);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap'}).addTo(_map);

// Pin usuário
L.marker([_uLat,_uLng],{icon:L.divIcon({className:'',html:'<div style="background:#FF385C;color:#fff;border-radius:50%;width:34px;height:34px;display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:0 2px 8px rgba(0,0,0,.3);border:2px solid #fff">📍</div>',iconSize:[34,34],iconAnchor:[17,17]})}).addTo(_map).bindPopup('<b>Você está aqui</b>');

function _icone(cor,n){
  return L.divIcon({className:'',html:'<div style="background:'+cor+';color:#fff;border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;box-shadow:0 2px 8px rgba(0,0,0,.25);border:2px solid #fff">'+n+'</div>',iconSize:[36,36],iconAnchor:[18,18]});
}

let ok=0;
_grupos.forEach(g => {
  const cidNorm = (g.cidade||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
  const base = _cidadeCoords[cidNorm] || _cidadeCoords[(g.cidade||'').toLowerCase()];
  if(!base) return;
  const off = _offset(cidNorm);
  const lat = base.lat + off.dlat;
  const lng = base.lng + off.dlng;
  const tot = g.meus.length + g.parceiros.length;
  const cor = g.meus.length>0&&g.parceiros.length===0?'#FF385C':g.meus.length===0?'#6366f1':'#f59e0b';
  const mk = L.marker([lat,lng],{icon:_icone(cor,tot)}).addTo(_map);
  // Monta lista de imóveis do bairro
  const todos = [...g.meus.map(i=>({...i,_meu:true})),...g.parceiros.map(i=>({...i,_meu:false}))].slice(0,5);
  const lista = todos.map(i=>
    '<div style="padding:8px 0;border-bottom:1px solid #f3f4f6">'+
    '<div style="font-size:13px;font-weight:600;color:#111">'+(i.titulo||i.tipo||'Imóvel')+'</div>'+
    '<div style="font-size:12px;color:#666;margin-top:2px">'+
      (i.quartos?i.quartos+'q ':'')+
      (i.area_m2?i.area_m2+'m² ':'')+ 
      (i.vagas?i.vagas+' vaga(s) ':'')+
    '</div>'+
    '<div style="font-size:13px;font-weight:700;color:'+(i._meu?'#FF385C':'#6366f1')+';margin-top:2px">'+
      (i.valor_imovel?'R$'+Number(i.valor_imovel).toLocaleString('pt-BR'):'Consultar')+
    '</div>'+
    '</div>'
  ).join('');
  mk.bindPopup(
    '<div style="padding:10px;min-width:220px;max-width:280px">'+
    '<b style="font-size:14px">'+(g.bairro||g.cidade)+'</b>'+
    '<div style="font-size:11px;color:#888;margin-bottom:8px">'+g.cidade+' · '+tot+' imóvel(is)</div>'+
    lista+
    (tot>5?'<div style="font-size:11px;color:#888;margin-top:6px">+mais '+(tot-5)+' imóveis</div>':'')+
    '</div>',
    {maxWidth:300}
  );
  ok++;
});
document.getElementById('qtd').textContent = ok;
</script>

<%- include('partials/app-end') %>
