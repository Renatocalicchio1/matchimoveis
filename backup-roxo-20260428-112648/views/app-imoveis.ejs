<%- include('partials/app-shell',{active:'imoveis',title:'Meus imóveis',subtitle:'Relação completa dos imóveis do corretor em formato de planilha.',perfil:'corretor'}) %>

<div class="card">
  <button class="btn light" type="button" onclick="toggleFiltros()">🔎 Filtrar imóveis</button>

  <div id="box-filtros" style="display:none;margin-top:18px">
    <h3>Filtro avançado</h3>
    <div class="form">
      <div><label>Estado<input id="f-estado" placeholder="SP"></label></div>
      <div><label>Cidade<input id="f-cidade" placeholder="São Paulo"></label></div>
      <div><label>Bairro<input id="f-bairro" placeholder="Vila Mariana"></label></div>
      <div><label>CEP<input id="f-cep" placeholder="00000-000"></label></div>
      <div><label>Código / ID<input id="f-id" placeholder="ID"></label></div>
      <div><label>Tipo imóvel<input id="f-tipo" placeholder="Apartamento, casa, sala"></label></div>
      <div><label>Negociação<input id="f-negociacao" placeholder="Venda, locação"></label></div>
      <div><label>Valor mín.<input id="f-valor-min" placeholder="500000"></label></div>
      <div><label>Valor máx.<input id="f-valor-max" placeholder="1000000"></label></div>
      <div><label>M² mín.<input id="f-area-min" placeholder="50"></label></div>
      <div><label>M² máx.<input id="f-area-max" placeholder="120"></label></div>
      <div><label>Quartos<input id="f-quartos" placeholder="2"></label></div>
      <div><label>Suítes<input id="f-suites" placeholder="1"></label></div>
      <div><label>Banheiros<input id="f-banheiros" placeholder="2"></label></div>
      <div><label>Vagas<input id="f-vagas" placeholder="1"></label></div>
      <div style="display:flex;gap:10px;align-items:end">
        <button class="btn red" type="button" onclick="filtrarTabela()">Aplicar filtro</button>
        <button class="btn light" type="button" onclick="limparFiltro()">Limpar</button>
      </div>
    </div>
  </div>
</div>

<br>

<div class="card">
  <form method="POST" action="/app-xml-gerar">
    <div style="display:flex;gap:12px;align-items:center;justify-content:space-between;flex-wrap:wrap">
      <h3 style="margin:0">Planilha de imóveis</h3>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <select name="portal">
          <option value="canalpro">Canal Pro — OLX / Zap / Viva Real</option>
          <option value="chaves-na-mao">Chaves na Mão</option>
          <option value="imovelweb">Imovelweb</option>
          <option value="123i">123i</option>
          <option value="quintoandar">QuintoAndar</option>
          <option value="remax">RE/MAX</option>
        </select>
        <button class="btn red" type="submit">Gerar XML selecionados</button>
      </div>
    </div>

    <br>

    <div style="overflow:auto">
      <table class="table" id="tabela-imoveis">
        <tr>
          <th><input type="checkbox" onclick="document.querySelectorAll('.chk').forEach(c=>c.checked=this.checked)"></th>
          <th>Ver</th>
          <th>ID</th>
          <th>Categoria</th>
          <th>Tipo</th>
          <th>Negociação</th>
          <th>CEP</th>
          <th>Endereço</th>
          <th>Bairro</th>
          <th>Cidade</th>
          <th>UF</th>
          <th>Valor</th>
          <th>Condomínio</th>
          <th>IPTU</th>
          <th>Área útil</th>
          <th>Área total</th>
          <th>Quartos</th>
          <th>Suítes</th>
          <th>Banheiros</th>
          <th>Vagas</th>
          <th>Status</th>
        </tr>

        <% (typeof imoveis !== 'undefined' ? imoveis : []).forEach((item,idx)=>{ 
          const o = item.origin || item;
          const id = o.listingId || o.id || o.id_anuncio || o.codigo || idx;
        %>
        <tr>
          <td><input class="chk" type="checkbox" name="ids" value="<%= idx %>"></td>
          <td><a class="btn light" href="/imovel/<%= idx %>" target="_blank">Abrir</a></td>
          <td><%= id || '-' %></td>
          <td><%= o.categoria || o.tipo_categoria || '-' %></td>
          <td><%= o.tipo || o.tipo_residencial || o.tipo_comercial || '-' %></td>
          <td><%= o.negociacao || o.tipo_negociacao || 'Venda' %></td>
          <td><%= o.cep || '-' %></td>
          <td><%= o.endereco || o.logradouro || '-' %></td>
          <td><%= o.bairro || '-' %></td>
          <td><%= o.cidade || 'São Paulo' %></td>
          <td><%= o.estado || 'SP' %></td>
          <td>R$ <%= o.valor_imovel || o.valor || '-' %></td>
          <td>R$ <%= o.condominio || '-' %></td>
          <td>R$ <%= o.iptu || '-' %></td>
          <td><%= o.area_m2 || o.area_util || o.area || '-' %> m²</td>
          <td><%= o.area_total || '-' %> m²</td>
          <td><%= o.quartos || '-' %></td>
          <td><%= o.suites || '-' %></td>
          <td><%= o.banheiros || '-' %></td>
          <td><%= o.vagas || '-' %></td>
          <td><span class="status ok">Ativo</span></td>
        </tr>
        <% }) %>
      </table>
    </div>
  </form>
</div>

<script>
function toggleFiltros(){
  const box = document.getElementById('box-filtros');
  box.style.display = box.style.display === 'none' ? 'block' : 'none';
}
function normaliza(v){return (v||'').toString().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'')}
function numero(v){return Number((v||'').toString().replace(/\D/g,''))||0}
function filtrarTabela(){
  const campos = ['estado','cidade','bairro','cep','id','tipo','negociacao','quartos','suites','banheiros','vagas'];
  const valores = {};
  campos.forEach(c=>valores[c]=normaliza(document.getElementById('f-'+c)?.value));
  const valorMin = numero(document.getElementById('f-valor-min')?.value);
  const valorMax = numero(document.getElementById('f-valor-max')?.value);
  const areaMin = numero(document.getElementById('f-area-min')?.value);
  const areaMax = numero(document.getElementById('f-area-max')?.value);

  document.querySelectorAll('#tabela-imoveis tr').forEach((tr,i)=>{
    if(i===0) return;
    const text = normaliza(tr.innerText);
    let ok = true;
    Object.values(valores).forEach(v=>{ if(v && !text.includes(v)) ok=false; });

    const valor = numero(text.match(/r\$\s*[\d\.]+/i)?.[0] || '');
    const area = numero(text.match(/\d+\s*m²/i)?.[0] || '');

    if(valorMin && valor < valorMin) ok=false;
    if(valorMax && valor > valorMax) ok=false;
    if(areaMin && area < areaMin) ok=false;
    if(areaMax && area > areaMax) ok=false;

    tr.style.display = ok ? '' : 'none';
  });
}
function limparFiltro(){
  document.querySelectorAll('[id^="f-"]').forEach(el=>el.value='');
  document.querySelectorAll('#tabela-imoveis tr').forEach(tr=>tr.style.display='');
}
</script>

<%- include('partials/app-end') %>
