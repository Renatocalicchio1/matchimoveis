<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title><%= (typeof title !== 'undefined' && title) ? title + ' · MatchImóveis' : 'MatchImóveis' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{
      --brand:#FF385C;
      --brand-dark:#e0314f;
      --brand-light:#fff1f3;
      --dark:#111111;
      --text:#1a1a1a;
      --text-sec:#6b7280;
      --text-ter:#9ca3af;
      --bg:#f8f8f7;
      --white:#ffffff;
      --border:#e5e5e3;
      --border-light:#f0f0ee;
      --sidebar:248px;
      --radius:12px;
      --radius-lg:16px;
      --shadow:0 1px 4px rgba(0,0,0,.06);
      --shadow-md:0 4px 16px rgba(0,0,0,.08);
    }
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);font-size:13px;line-height:1.6;-webkit-font-smoothing:antialiased}
    
    /* LAYOUT */
    .app{display:flex;min-height:100vh}
    
    /* SIDEBAR */
    .sidebar{
      width:var(--sidebar);
      background:var(--white);
      border-right:1px solid var(--border);
      position:fixed;top:0;left:0;bottom:0;
      display:flex;flex-direction:column;
      z-index:100;
      overflow-y:auto;
      overflow-x:hidden;
    }

    /* LOGO */
    .sidebar-logo{
      padding:20px 18px 16px;
      border-bottom:1px solid var(--border-light);
    }
    .logo-text{
      font-size:17px;font-weight:700;letter-spacing:-.4px;
      color:var(--dark);line-height:1;
    }
    .logo-text span{color:var(--brand)}

    /* USER */
    .sidebar-user{
      padding:12px 14px;
      border-bottom:1px solid var(--border-light);
    }
    .user-row{
      display:flex;align-items:center;gap:10px;
      padding:8px 10px;border-radius:10px;
      background:var(--bg);
    }
    .user-av{
      width:32px;height:32px;border-radius:50%;
      background:var(--dark);
      display:flex;align-items:center;justify-content:center;
      color:#fff;font-size:13px;font-weight:600;
      flex-shrink:0;
    }
    .user-info{overflow:hidden;flex:1}
    .user-name{font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .user-code{font-size:11px;color:var(--text-ter);margin-top:1px}

    /* NAV */
    nav.menu{padding:8px 10px;flex:1}
    .menu-sec{
      font-size:10px;font-weight:600;
      color:var(--text-ter);
      text-transform:uppercase;letter-spacing:.6px;
      padding:14px 8px 5px;
    }
    .menu a{
      display:flex;align-items:center;gap:9px;
      padding:7px 10px;border-radius:8px;
      color:var(--text-sec);text-decoration:none;
      font-size:13px;font-weight:400;
      transition:all .1s;margin-bottom:1px;
      white-space:nowrap;
    }
    .menu a:hover{background:var(--bg);color:var(--text)}
    .menu a.active{background:var(--brand-light);color:var(--brand);font-weight:500}
    .menu-ic{
      width:20px;height:20px;
      display:flex;align-items:center;justify-content:center;
      flex-shrink:0;opacity:.7;
    }
    .menu a.active .menu-ic{opacity:1}
    .menu a:hover .menu-ic{opacity:1}
    .menu-div{height:1px;background:var(--border-light);margin:6px 0}

    /* BADGES NAV */
    .nav-badge{
      margin-left:auto;
      background:var(--brand);color:#fff;
      font-size:10px;font-weight:700;
      padding:1px 6px;border-radius:20px;
      min-width:18px;text-align:center;
    }
    .nav-badge.green{background:#22c55e}

    /* SIDEBAR FOOTER */
    .sidebar-footer{
      padding:12px 14px;
      border-top:1px solid var(--border-light);
    }
    .sidebar-footer a{
      display:flex;align-items:center;gap:8px;
      color:var(--text-ter);text-decoration:none;
      font-size:12px;padding:7px 10px;border-radius:8px;
      transition:all .1s;
    }
    .sidebar-footer a:hover{color:var(--text-sec);background:var(--bg)}

    /* CONTENT */
    .content{
      margin-left:var(--sidebar);
      width:calc(100% - var(--sidebar));
      min-height:100vh;
      padding:28px 36px;
      max-width:calc(1280px + var(--sidebar));
    }

    /* PAGE HEAD */
    .page-head{margin-bottom:24px}
    .page-head h1{
      font-size:20px;font-weight:600;
      color:var(--dark);letter-spacing:-.3px;
      margin-bottom:2px;line-height:1.3;
    }
    .page-head p{color:var(--text-sec);font-size:13px;font-weight:400}

    /* CARDS */
    .card{
      background:var(--white);
      border:1px solid var(--border);
      border-radius:var(--radius-lg);
      padding:20px;
    }

    /* BUTTONS */
    .btn{
      display:inline-flex;align-items:center;justify-content:center;gap:6px;
      padding:8px 16px;border-radius:8px;
      font-size:13px;font-weight:500;
      cursor:pointer;text-decoration:none;border:none;
      transition:all .1s;font-family:'Inter',sans-serif;
      white-space:nowrap;
    }
    .btn-primary{background:var(--brand);color:#fff}
    .btn-primary:hover{background:var(--brand-dark)}
    .btn-outline{background:transparent;color:var(--text);border:1px solid var(--border)}
    .btn-outline:hover{background:var(--bg)}
    .btn-ghost{background:transparent;color:var(--text-sec)}
    .btn-ghost:hover{color:var(--text);background:var(--bg)}
    .btn-dark{background:var(--dark);color:#fff}
    .btn-dark:hover{background:#333}
    .btn-sm{padding:6px 12px;font-size:12px;border-radius:7px}
    .btn-lg{padding:11px 22px;font-size:14px}
    .light{background:var(--bg);color:var(--text);border:1px solid var(--border)}
    .light:hover{background:#f0f0ee}

    /* FORMS */
    input,select,textarea{
      width:100%;
      border:1px solid var(--border);
      border-radius:8px;
      padding:9px 12px;
      font-size:13px;
      font-family:'Inter',sans-serif;
      color:var(--text);
      background:var(--white);
      outline:none;
      transition:border .1s;
    }
    input:focus,select:focus,textarea:focus{border-color:var(--dark)}
    label{display:block;font-size:12px;font-weight:500;color:var(--text-sec);margin-bottom:5px}
    .field{display:flex;flex-direction:column;gap:4px}

    /* TABLES */
    table{width:100%;border-collapse:collapse;font-size:13px}
    th{text-align:left;padding:9px 14px;font-size:11px;font-weight:600;color:var(--text-ter);text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border-light)}
    td{padding:12px 14px;border-bottom:1px solid var(--border-light);color:var(--text);vertical-align:middle}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:var(--bg)}

    /* BADGES */
    .badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:500}
    .badge-red{background:var(--brand-light);color:var(--brand)}
    .badge-green{background:#f0fdf4;color:#16a34a}
    .badge-gray{background:var(--bg);color:var(--text-sec)}
    .badge-blue{background:#eff6ff;color:#2563eb}
    .badge-amber{background:#fffbeb;color:#d97706}
    .badge-purple{background:#f5f3ff;color:#7c3aed}

    /* KPI */
    .kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
    .kpi{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:18px;position:relative;overflow:hidden}
    .kpi-label{font-size:11px;font-weight:500;color:var(--text-ter);margin-bottom:6px;text-transform:uppercase;letter-spacing:.4px}
    .kpi-val{font-size:30px;font-weight:700;letter-spacing:-1px;line-height:1;color:var(--dark)}
    .kpi-sub{font-size:11px;color:var(--text-ter);margin-top:4px}
    .kpi-bar{position:absolute;left:0;top:0;bottom:0;width:3px}
    .kpi.red .kpi-bar{background:var(--brand)}.kpi.red .kpi-val{color:var(--brand)}
    .kpi.green .kpi-bar{background:#22c55e}.kpi.green .kpi-val{color:#16a34a}
    .kpi.blue .kpi-bar{background:#3b82f6}.kpi.blue .kpi-val{color:#2563eb}
    .kpi.amber .kpi-bar{background:#f59e0b}.kpi.amber .kpi-val{color:#d97706}

    /* GRIDS */
    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    .grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}

    /* EMPTY */
    .empty{text-align:center;padding:60px 20px;color:var(--text-ter)}
    .empty-icon{font-size:40px;margin-bottom:12px;opacity:.3}
    .empty h3{font-size:15px;font-weight:500;color:var(--text-sec);margin-bottom:6px}

    /* MISC */
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
    .live{display:inline-block;width:6px;height:6px;background:#22c55e;border-radius:50%;animation:pulse 2s infinite;margin-right:4px}

    /* RESPONSIVE */
    @media(max-width:900px){
      .sidebar{transform:translateX(-100%)}
      .content{margin-left:0;width:100%;padding:16px}
      .kpi-grid{grid-template-columns:repeat(2,1fr)}
      .grid-2,.grid-3,.grid-4{grid-template-columns:1fr}
    }
  </style>
</head>
<body>
<div class="app">

<aside class="sidebar">
  <!-- Logo -->
  <div class="sidebar-logo">
    <div class="logo-text">Match<span>Imóveis</span></div>
  </div>

  <!-- User -->
  <div class="sidebar-user">
    <div class="user-row">
      <div class="user-av"><%= ((typeof user!=='undefined'&&user&&user.nome)?user.nome:'U').charAt(0).toUpperCase() %></div>
      <div class="user-info">
        <div class="user-name"><%= (typeof user!=='undefined'&&user&&user.nome)?user.nome:'Usuário' %></div>
        <div class="user-code">ID: <%= (typeof user!=='undefined'&&user&&(user.codigoUsuario||user.codigo))?(user.codigoUsuario||user.codigo):'-' %></div>
      </div>
    </div>
  </div>

  <!-- Nav -->
  <nav class="menu">
    <div class="menu-sec">Principal</div>

    <a class="<%= active==='home'?'active':'' %>" href="/app-home">
      <span class="menu-ic">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      </span>
      Dashboard
    </a>

    <a class="<%= active==='imoveis'?'active':'' %>" href="/app/imoveis">
      <span class="menu-ic">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </span>
      Meus Imóveis
    </a>

    <a class="<%= active==='leads'?'active':'' %>" href="/app/leads">
      <span class="menu-ic">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      </span>
      Leads
    </a>

    <a class="<%= active==='visitas'?'active':'' %>" href="/app/visitas">
      <span class="menu-ic">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      </span>
      Visitas
      <% if(typeof visitasPendentes !== 'undefined' && visitasPendentes > 0) { %>
        <span class="nav-badge"><%= visitasPendentes %></span>
      <% } %>
    </a>

    <a class="<%= active==='parceiros'?'active':'' %>" href="/app/parceiros">
      <span class="menu-ic">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      </span>
      Parceiros
    </a>
    <a class="<%= active==='whatsapp'?'active':'' %>" href="/app/whatsapp">
      <span class="menu-ic">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      </span>
      WhatsApp
      <% if (typeof mensagensNaoLidas !== 'undefined' && mensagensNaoLidas > 0) { %>
        <span class="nav-badge green"><%= mensagensNaoLidas %></span>
      <% } %>
    </a>

    <a class="<%= active==='notificacoes'?'active':'' %>" href="/app/notificacoes">
      <span class="menu-ic">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
      </span>
      Notificações
      <% if (typeof notificacoesNaoLidas !== 'undefined' && notificacoesNaoLidas > 0) { %>
        <span class="nav-badge"><%= notificacoesNaoLidas %></span>
      <% } %>
    </a>

    <div class="menu-div"></div>
    <div class="menu-sec">Configurar</div>

    <a class="<%= active==='cadastro'?'active':'' %>" href="/app/cadastro">
      <span class="menu-ic">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </span>
      Cadastrar Imóvel
    </a>

    <a class="<%= active==='portais'?'active':'' %>" href="/app/portais">
      <span class="menu-ic">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
      </span>
      Portais / XML
    </a>

    <a class="<%= active==='perfil'?'active':'' %>" href="/app/perfil">
      <span class="menu-ic">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </span>
      Perfil
    </a>

    <a class="<%= active==='mapa'?'active':'' %>" href="/app/mapa">
      <span class="menu-ic">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 13l4.553 2.276A1 1 0 0021 21.382V10.618a1 1 0 00-1.447-.894L15 12m0 8V12m0 0L9 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
      Mapa
    </a>
    <a class="<%= active==='coins'?'active':'' %>" href="/app/coins">
      <span class="menu-ic">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v2m0 8v2M9 12h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </span>
      Créditos
    </a>
    </a>
  </nav>

  <!-- Footer -->
  <div class="sidebar-footer">
    <a href="/logout">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Sair
    </a>
  </div>
</aside>

<main class="content">

<%
const _temPerfil = !!(user && user.nome && (user.celular || user.telefone));
const _temWA = !!(user && user.whatsappStatus === 'open');
const _temImoveis = typeof totalImoveis !== 'undefined' ? totalImoveis > 0 : false;
const _onboardingCompleto = _temPerfil && _temWA && _temImoveis;
const _passos = [
  { key:'perfil', label:'Perfil', feito:_temPerfil, titulo:'Complete seu perfil', motivo:'Sem isso o sistema não sabe quem você é e não consegue personalizar as mensagens para seus clientes.', acao:'Completar perfil', link:'/app/perfil' },
  { key:'whatsapp', label:'WhatsApp', feito:_temWA, titulo:'Conecte seu WhatsApp', motivo:'Sem isso leads não são capturadas, a vitrine não é enviada e as visitas não são confirmadas automaticamente.', acao:'Conectar agora', link:'/app/perfil#secao-whatsapp' },
  { key:'imoveis', label:'Imóveis', feito:_temImoveis, titulo:'Adicione seus imóveis', motivo:'Sem imóveis o sistema não faz match e não tem o que mostrar na vitrine para seus clientes.', acao:'Adicionar imóveis', link:'/app/imoveis' }
];
const _prox = _passos.find(p => !p.feito);
%>


  <% if(typeof title!=='undefined'&&title){ %>
  <div class="page-head">
    <h1><%= title %></h1>
    <% if(typeof subtitle!=='undefined'&&subtitle){ %><p><%= subtitle %></p><% } %>
  </div>
  <% } %>

  <% if(!_onboardingCompleto){ %>
  <div style="margin:0 0 20px;background:#fff;border:1px solid #e5e5e3;border-radius:12px;padding:16px 20px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
      <div style="font-size:13px;font-weight:600;color:#111">Configure sua conta <span style="font-size:11px;font-weight:400;color:#9ca3af;margin-left:6px"><%= _passos.filter(p=>p.feito).length %> de <%= _passos.length %> concluídos</span></div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <% _passos.forEach((p,i) => { %>
      <a href="<%= p.feito ? '#' : p.link %>" style="display:flex;align-items:center;gap:8px;padding:8px 14px;border-radius:8px;border:1px solid <%= p.feito ? '#d1fae5' : p===_prox ? '#111' : '#e5e5e3' %>;background:<%= p.feito ? '#f0fdf4' : p===_prox ? '#111' : '#f9fafb' %>;text-decoration:none;flex:1;min-width:160px">
        <div style="width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:<%= p.feito ? '#16a34a' : p===_prox ? '#fff' : '#e5e7eb' %>;flex-shrink:0;font-size:11px;font-weight:700;color:<%= p.feito ? '#fff' : p===_prox ? '#111' : '#9ca3af' %>"><%= p.feito ? '✓' : i+1 %></div>
        <div>
          <div style="font-size:12px;font-weight:600;color:<%= p.feito ? '#16a34a' : p===_prox ? '#fff' : '#6b7280' %>"><%= p.label %></div>
          <div style="font-size:10px;color:<%= p.feito ? '#16a34a' : p===_prox ? '#d1d5db' : '#9ca3af' %>"><%= p.feito ? 'Concluído' : p===_prox ? p.acao : 'Pendente' %></div>
        </div>
      </a>
      <% }) %>
    </div>
    <% if(_prox){ %>
    <div style="margin-top:12px;padding:10px 14px;background:#fffbeb;border-radius:8px;border:1px solid #fcd34d;font-size:12px;color:#92400e">
      <strong><%= _prox.titulo %>:</strong> <%= _prox.motivo %>
    </div>
    <% } %>
  </div>
  <% } %>
