<%- include('partials/app-shell',{active:'imoveis',title:'Detalhes do Imóvel',subtitle:'',user:user}) %>

<style>
.detalhe-hero{display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:240px 240px;gap:4px;border-radius:16px;overflow:hidden;margin-bottom:28px}
.detalhe-hero img{width:100%;height:100%;object-fit:cover}
.detalhe-hero img:first-child{grid-row:1/3}
.detalhe-layout{display:grid;grid-template-columns:1fr 320px;gap:24px;max-width:980px;margin:0 auto}
.detalhe-card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:24px;margin-bottom:16px}
.spec-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:12px;margin-top:16px}
.spec-item{background:var(--light);border-radius:12px;padding:14px 10px;text-align:center}
.spec-icon{font-size:22px;margin-bottom:4px}
.spec-val{font-weight:700;font-size:16px;color:var(--dark)}
.spec-lbl{font-size:11px;color:var(--gray);margin-top:2px}
.prop-card{background:var(--white);border:2px solid var(--brand);border-radius:16px;padding:20px;margin-bottom:16px}
.prop-nome{font-weight:700;font-size:17px;color:var(--dark);margin-bottom:12px}
.prop-btn{display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;margin-bottom:8px;transition:opacity .2s}
.prop-btn:hover{opacity:.85}
.prop-wpp{background:#25D366;color:#fff}
.prop-tel{background:#f0f0f0;color:var(--dark)}
.prop-email{background:#eff6ff;color:#2563eb}
.info-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px}
.info-row:last-child{border:none}
.info-lbl{color:var(--gray)}
.info-val{font-weight:600;color:var(--dark)}
.foto-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:8px;margin-top:16px}
.foto-grid img{width:100%;height:110px;object-fit:cover;border-radius:8px;cursor:pointer;transition:transform .2s}
.foto-grid img:hover{transform:scale(1.03)}
.badge-tipo{display:inline-block;background:#fee2e2;color:#dc2626;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:10px}
</style>

<div style="max-width:980px;margin:0 auto">

<%# FOTOS %>
<% if(imovel.fotos && imovel.fotos.length > 0) { %>
<div class="detalhe-hero" id="hero-fotos">
  <img src="<%= imovel.fotos[0] %>" onclick="abrirGaleria(0)" style="cursor:pointer">
  <% if(imovel.fotos[1]) { %><img src="<%= imovel.fotos[1] %>" onclick="abrirGaleria(1)" style="cursor:pointer"><% } %>
  <% if(imovel.fotos[2]) { %><img src="<%= imovel.fotos[2] %>" onclick="abrirGaleria(2)" style="cursor:pointer"><% } %>
  <% if(imovel.fotos[3]) { %><img src="<%= imovel.fotos[3] %>" onclick="abrirGaleria(3)" style="cursor:pointer"><% } %>
  <% if(imovel.fotos[4]) { %>
    <div style="position:relative;cursor:pointer" onclick="abrirGaleria(4)">
      <img src="<%= imovel.fotos[4] %>" style="width:100%;height:100%;object-fit:cover">
      <% if(imovel.fotos.length > 5) { %>
      <div style="position:absolute;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;color:#fff;font-size:22px;font-weight:700">+<%= imovel.fotos.length - 5 %> fotos</div>
      <% } %>
    </div>
  <% } %>
</div>

<!-- LIGHTBOX -->
<div id="lightbox" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:9999;align-items:center;justify-content:center">
  <button onclick="fecharLightbox()" style="position:absolute;top:16px;right:20px;background:none;border:none;color:#fff;font-size:32px;cursor:pointer">✕</button>
  <button onclick="navFoto(-1)" style="position:absolute;left:16px;background:rgba(255,255,255,.15);border:none;color:#fff;font-size:28px;width:48px;height:48px;border-radius:50%;cursor:pointer">‹</button>
  <img id="lb-img" style="max-width:90vw;max-height:90vh;object-fit:contain;border-radius:8px">
  <button onclick="navFoto(1)" style="position:absolute;right:16px;background:rgba(255,255,255,.15);border:none;color:#fff;font-size:28px;width:48px;height:48px;border-radius:50%;cursor:pointer">›</button>
  <div id="lb-counter" style="position:absolute;bottom:16px;color:#fff;font-size:14px;opacity:.7"></div>
</div>

<script>
const fotos = <%- JSON.stringify(imovel.fotos || []) %>;
let fotoAtual = 0;
function abrirGaleria(idx) {
  fotoAtual = idx;
  document.getElementById('lightbox').style.display = 'flex';
  atualizarLb();
}
function fecharLightbox() { document.getElementById('lightbox').style.display = 'none'; }
function navFoto(dir) { fotoAtual = (fotoAtual + dir + fotos.length) % fotos.length; atualizarLb(); }
function atualizarLb() {
  document.getElementById('lb-img').src = fotos[fotoAtual];
  document.getElementById('lb-counter').textContent = (fotoAtual+1) + ' / ' + fotos.length;
}
document.getElementById('lightbox').addEventListener('click', function(e){ if(e.target===this) fecharLightbox(); });
document.addEventListener('keydown', e => { if(e.key==='Escape') fecharLightbox(); if(e.key==='ArrowLeft') navFoto(-1); if(e.key==='ArrowRight') navFoto(1); });
</script>
<% } %>

<div class="detalhe-layout">

  <%# COLUNA PRINCIPAL %>
  <div>

    <%# TÍTULO E VALOR %>
    <div class="detalhe-card">
      <span class="badge-tipo"><%= imovel.tipo %></span>
      <div style="display:flex;justify-content:space-between;align-items:start;gap:16px">
        <div>
          <h1 style="font-size:22px;font-weight:800;margin:0 0 6px;line-height:1.3"><%= imovel.titulo || (imovel.tipo + ' em ' + imovel.bairro) %></h1>
          <p style="color:var(--gray);font-size:14px;margin:0">
            <% if(imovel.endereco) { %><%= imovel.endereco %> · <% } %>
            <%= imovel.bairro %><% if(imovel.cidade) { %>, <%= imovel.cidade %><% } %>
          </p>
        </div>
        <div style="text-align:right;flex-shrink:0">
          <div style="font-size:26px;font-weight:800;color:var(--brand)">R$ <%= Number(imovel.valor_imovel||0).toLocaleString('pt-BR') %></div>

          <div style="font-size:13px;color:#667085;margin-top:8px;line-height:1.6">
            <div>📅 Cadastrado em: <%= imovel.createdAt || imovel.dataCadastro || imovel.data_cadastro || imovel.importedAt || imovel.lastUpdate ? new Date(imovel.createdAt || imovel.dataCadastro || imovel.data_cadastro || imovel.importedAt || imovel.lastUpdate).toLocaleDateString('pt-BR') : '-' %></div>
            <div>🔄 Última atualização: <%= imovel.updatedAt || imovel.lastUpdate || imovel.lastCheckedAt || imovel.createdAt || imovel.importedAt ? new Date(imovel.updatedAt || imovel.lastUpdate || imovel.lastCheckedAt || imovel.createdAt || imovel.importedAt).toLocaleDateString('pt-BR') : '-' %></div>
          </div>

        </div>
      </div>
    </div>

    <%# CARACTERÍSTICAS %>
    <div class="detalhe-card">
      <h3 style="margin:0 0 4px;font-size:15px;font-weight:700">Características</h3>
      <div class="spec-grid">
        <% if(imovel.area_m2) { %>
        <div class="spec-item"><div class="spec-icon">📐</div><div class="spec-val"><%= imovel.area_m2 %>m²</div><div class="spec-lbl">Área</div></div>
        <% } %>
        <% if(imovel.quartos) { %>
        <div class="spec-item"><div class="spec-icon">🛏</div><div class="spec-val"><%= imovel.quartos %></div><div class="spec-lbl">Quartos</div></div>
        <% } %>
        <% if(imovel.suites) { %>
        <div class="spec-item"><div class="spec-icon">⭐</div><div class="spec-val"><%= imovel.suites %></div><div class="spec-lbl">Suítes</div></div>
        <% } %>
        <% if(imovel.banheiros) { %>
        <div class="spec-item"><div class="spec-icon">🚿</div><div class="spec-val"><%= imovel.banheiros %></div><div class="spec-lbl">Banheiros</div></div>
        <% } %>
        <% if(imovel.vagas) { %>
        <div class="spec-item"><div class="spec-icon">🚗</div><div class="spec-val"><%= imovel.vagas %></div><div class="spec-lbl">Vagas</div></div>
        <% } %>
      </div>
    </div>

    <%# DESCRIÇÃO %>
    <% if(imovel.descricao) { %>
    <div class="detalhe-card">
      <h3 style="margin:0 0 12px;font-size:15px;font-weight:700">Descrição</h3>
      <p style="color:#444;line-height:1.8;font-size:14px;white-space:pre-line;margin:0"><%= imovel.descricao %></p>
    </div>
    <% } %>



  </div>

  <%# COLUNA LATERAL %>
  <div>

    <%# PROPRIETÁRIO — só admin ou corretor dono %>
    <% if(imovel.proprietario && (user.tipo === 'admin' || user.tipo === 'corretor' || user.tipo === 'imobiliaria' || user.tipo === 'construtora')) { %>
    <div class="prop-card">
      <div style="font-size:11px;font-weight:700;color:var(--brand);text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px">👤 Proprietário</div>
      <div class="prop-nome"><%= imovel.proprietario?.nome || '-' %></div>
      <% if(imovel.proprietario?.celular) { %>
      <a href="https://wa.me/55<%= ((imovel.proprietario?.celular||imovel.proprietario?.telefone||'').replace(/\D/g,'')) %>" target="_blank" class="prop-btn prop-wpp">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
      <a href="tel:<%= imovel.proprietario?.celular %>" class="prop-btn prop-tel">
        📞 <%= imovel.proprietario?.celular %>
      </a>
      <% } %>
      <% if(imovel.proprietario?.email) { %>
      <a href="mailto:<%= imovel.proprietario?.email %>" class="prop-btn prop-email">
        ✉️ <%= imovel.proprietario?.email %>
      </a>
      <% } %>
    </div>
    <% } %>

    <%# CORRETOR %>
    <% if(imovel.corretor_nome) { %>
    <div class="detalhe-card" style="margin-bottom:16px">
      <div style="font-size:11px;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px">🏢 Corretor</div>
      <div style="font-weight:600;margin-bottom:4px"><%= imovel.corretor_nome %></div>
      <% if(imovel.corretor_telefone) { %><div style="color:var(--gray);font-size:13px">📞 <%= imovel.corretor_telefone %></div><% } %>
      <% if(imovel.corretor_email) { %><div style="color:var(--gray);font-size:13px">✉️ <%= imovel.corretor_email %></div><% } %>
    </div>
    <% } %>

    <%# INFORMAÇÕES %>
    <div class="detalhe-card">
      <div style="font-size:11px;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:.8px;margin-bottom:12px">Informações</div>
      <div class="info-row"><span class="info-lbl">ID</span><span class="info-val"><%= imovel.idExterno || imovel.id %></span></div>
      <% if(imovel.fonte) { %><div class="info-row"><span class="info-lbl">Fonte</span><span class="info-val"><%= imovel.fonte %></span></div><% } %>
      <% if(imovel.transacao) { %><div class="info-row"><span class="info-lbl">Operação</span><span class="info-val"><%= imovel.transacao %></span></div><% } %>
      <% if(imovel.cep) { %><div class="info-row"><span class="info-lbl">CEP</span><span class="info-val"><%= imovel.cep %></span></div><% } %>
      <% if(imovel.condominio && imovel.condominio > 0) { %><div class="info-row"><span class="info-lbl">Condomínio</span><span class="info-val">R$ <%= Number(imovel.condominio).toLocaleString('pt-BR') %>/mês</span></div><% } %>
      <% if(imovel.iptu && imovel.iptu > 0) { %><div class="info-row"><span class="info-lbl">IPTU</span><span class="info-val">R$ <%= Number(imovel.iptu).toLocaleString('pt-BR') %>/ano</span></div><% } %>
      <% if(imovel.andar) { %><div class="info-row"><span class="info-lbl">Andar</span><span class="info-val"><%= imovel.andar %>º</span></div><% } %>
    </div>

    <a href="/app/imoveis" style="display:block;text-align:center;color:var(--gray);font-size:13px;margin-top:8px">← Voltar para imóveis</a>

  </div>
</div>
</div>

<%- include('partials/app-end') %>