<%- include('partials/app-shell',{active:'imoveis',title:'Meus imóveis',subtitle:'Relação completa dos imóveis da carteira.',perfil:'corretor'}) %>

<div class="card">
  <div style="display:flex;gap:10px;align-items:center;justify-content:space-between;flex-wrap:wrap">
    <span><strong><%= typeof imoveis !== 'undefined' ? imoveis.length : 0 %></strong> imóveis na carteira</span>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <input id="busca" placeholder="🔎 Buscar..." oninput="filtrar()" style="padding:8px 12px;border:1px solid #ddd;border-radius:8px;min-width:220px">
      <button class="btn light" type="button" onclick="toggleFiltros()">⚙️ Filtros avançados</button>
    </div>
  </div>

  <div id="box-filtros" style="display:none;margin-top:14px;padding-top:14px;border-top:1px solid #ebebeb">
    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end">
      <div style="flex:1;min-width:120px"><label>Tipo</label>
      <select id="f-tipo">
        <option value="">Todos</option>
        <option value="apartamento">🏢 Apartamento</option>
        <option value="casa">🏠 Casa</option>
        <option value="cobertura">🏙️ Cobertura</option>
        <option value="loft">🏗️ Loft</option>
        <option value="studio">🛋️ Studio / Flat</option>
        <option value="kitnet">🏡 Kitnet / Conjugado</option>
        <option value="terreno">🟩 Terreno / Lote</option>
        <option value="comercial">🏪 Comercial</option>
        <option value="sala comercial">🖥️ Sala Comercial</option>
        <option value="loja">🛍️ Loja</option>
        <option value="galpão">🏭 Galpão</option>
      </select>
    </div>
      <div style="flex:1;min-width:120px"><label>Bairro</label><input id="f-bairro" placeholder="Vila Mariana"></div>
      <div style="flex:1;min-width:120px"><label>Cidade</label><input id="f-cidade" placeholder="São Paulo"></div>
      <div style="flex:1;min-width:100px"><label>Valor mín.</label><input id="f-valor-min" type="number" placeholder="500000"></div>
      <div style="flex:1;min-width:100px"><label>Valor máx.</label><input id="f-valor-max" type="number" placeholder="2000000"></div>
      <div style="flex:0 0 80px"><label>Área m²</label><input id="f-area-min" type="number" placeholder="50"></div>
      <div style="flex:0 0 70px"><label>Quartos</label><input id="f-quartos" type="number" placeholder="2"></div>
      <div style="flex:0 0 70px"><label>Vagas</label><input id="f-vagas" type="number" placeholder="1"></div>
      <div style="display:flex;gap:6px;align-items:flex-end;padding-bottom:1px">
        <button class="btn btn-primary" type="button" onclick="filtrar()" style="white-space:nowrap">Aplicar</button>
        <button class="btn btn-outline" type="button" onclick="limpar()">Limpar</button>
      </div>
    </div>
  </div>
</div>

<br>

<div id="grid-imoveis" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px">
<% (typeof imoveis !== 'undefined' ? imoveis : []).forEach((item, idx) => { %>
  <div class="card imovel-card"
    data-tipo="<%= (item.tipo||'').toLowerCase() %>"
    data-bairro="<%= (item.bairro||'').toLowerCase() %>"
    data-cidade="<%= (item.cidade||'').toLowerCase() %>"
    data-valor="<%= item.valor_imovel || 0 %>"
    data-area="<%= item.area_m2 || 0 %>"
    data-quartos="<%= item.quartos || 0 %>"
    data-vagas="<%= item.vagas || 0 %>"
    data-texto="<%= ((item.tipo||'')+(item.bairro||'')+(item.cidade||'')+(item.titulo||'')).toLowerCase() %>"
    style="padding:0;overflow:hidden;border-radius:12px;border:1px solid #eee">

    <% if(item.fotos && item.fotos.length > 0) { %>
      <img src="<%= item.fotos[0] %>" alt="foto" style="width:100%;height:180px;object-fit:cover">
    <% } else { %>
      <div style="width:100%;height:180px;background:#f5f5f5;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:32px">🏠</div>
    <% } %>

    <div style="padding:16px">
      <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:8px">
        <span style="background:#fee2e2;color:#dc2626;font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px"><%= item.tipo || 'Imóvel' %></span>
        <span style="font-size:11px;color:#999"><%= item.idExterno || idx %></span>
      </div>

      <div style="font-weight:700;font-size:18px;color:#111;margin-bottom:4px">
        R$ <%= item.valor_imovel ? Number(item.valor_imovel).toLocaleString('pt-BR') : '-' %>
      </div>

      <div style="color:#666;font-size:13px;margin-bottom:12px">
        <%= item.bairro || '-' %>, <%= item.cidade || '-' %>
      </div>

      <div style="display:flex;gap:12px;font-size:13px;color:#444;margin-bottom:14px;flex-wrap:wrap">
        <% if(item.area_m2) { %><span>📐 <%= item.area_m2 %>m²</span><% } %>
        <% if(item.quartos) { %><span>🛏 <%= item.quartos %> qtos</span><% } %>
        <% if(item.suites) { %><span>🛁 <%= item.suites %> suítes</span><% } %>
        <% if(item.vagas) { %><span>🚗 <%= item.vagas %> vagas</span><% } %>
      </div>

      <div style="display:flex;gap:8px">
        <a href="/app/imovel/<%= item.idExterno %>" target="_blank" class="btn light" style="flex:1;text-align:center;font-size:12px">Ver detalhes</a>
        <% if(item.corretor && item.corretor.telefone) { %>
          <a href="https://wa.me/55<%= item.corretor.telefone.replace(/\D/g,'') %>" target="_blank" class="btn red" style="flex:1;text-align:center;font-size:12px">WhatsApp</a>
        <% } %>
      </div>
    </div>
  </div>
<% }) %>
</div>

<div id="sem-resultados" style="display:none;text-align:center;padding:60px;color:#999">
  <div style="font-size:48px">🔍</div>
  <p>Nenhum imóvel encontrado com esses filtros.</p>
</div>

<script>
function toggleFiltros(){
  const box = document.getElementById('box-filtros');
  box.style.display = box.style.display === 'none' ? 'block' : 'none';
}

function norm(v){ return (v||'').toString().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'') }

function filtrar(){
  const busca = norm(document.getElementById('busca').value);
  const tipo = norm(document.getElementById('f-tipo')?.value);
  const bairro = norm(document.getElementById('f-bairro')?.value);
  const cidade = norm(document.getElementById('f-cidade')?.value);
  const valorMin = Number(document.getElementById('f-valor-min')?.value) || 0;
  const valorMax = Number(document.getElementById('f-valor-max')?.value) || 0;
  const areaMin = Number(document.getElementById('f-area-min')?.value) || 0;
  const quartos = Number(document.getElementById('f-quartos')?.value) || 0;
  const vagas = Number(document.getElementById('f-vagas')?.value) || 0;

  let visiveis = 0;
  document.querySelectorAll('.imovel-card').forEach(card => {
    const texto = card.dataset.texto;
    const valor = Number(card.dataset.valor);
    const area = Number(card.dataset.area);

    let ok = true;
    if(busca && !norm(card.outerText).includes(busca)) ok = false;
    if(tipo && !card.dataset.tipo.includes(tipo)) ok = false;
    if(bairro && !card.dataset.bairro.includes(bairro)) ok = false;
    if(cidade && !card.dataset.cidade.includes(cidade)) ok = false;
    if(valorMin && valor < valorMin) ok = false;
    if(valorMax && valor > valorMax) ok = false;
    if(areaMin && area < areaMin) ok = false;
    if(quartos && Number(card.dataset.quartos) < quartos) ok = false;
    if(vagas && Number(card.dataset.vagas) < vagas) ok = false;

    card.style.display = ok ? '' : 'none';
    if(ok) visiveis++;
  });

  document.getElementById('sem-resultados').style.display = visiveis === 0 ? 'block' : 'none';
}

function limpar(){
  ['f-tipo','f-bairro','f-cidade','f-valor-min','f-valor-max','f-area-min','f-quartos','f-vagas'].forEach(id=>{
    const el = document.getElementById(id);
    if(el) el.value = '';
  });
  document.getElementById('busca').value = '';
  filtrar();
}
</script>

<%- include('partials/app-end') %>

<script>
async function mudarStatus(id, status){
  await fetch('/imovel/'+id+'/status',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({status})
  });
}
</script>

