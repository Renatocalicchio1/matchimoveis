<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>Remarcar Visita • MatchImóveis</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f4;color:#1a1a1a}
    .topbar{background:#fff;border-bottom:1px solid #e5e7eb;padding:16px 24px}
    .logo{color:#FF385C;font-size:20px;font-weight:700}
    .container{max-width:560px;margin:40px auto;padding:0 20px}
    .card{background:#fff;border-radius:16px;padding:32px;border:0.5px solid rgba(0,0,0,.08)}
    h1{font-size:22px;font-weight:600;margin-bottom:8px;color:#111}
    .sub{color:#6b7280;margin-bottom:24px;font-size:14px;line-height:1.6}
    .field{margin-bottom:16px}
    .field label{display:block;font-size:11px;font-weight:500;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px}
    .field input{width:100%;padding:11px 14px;border:0.5px solid rgba(0,0,0,.12);border-radius:8px;font-size:14px;color:#111;outline:none}
    .field input:focus{border-color:rgba(0,0,0,.3)}
    .btn{width:100%;padding:14px;border-radius:10px;border:none;font-size:14px;font-weight:600;cursor:pointer;background:#FF385C;color:#fff;margin-top:8px;transition:opacity .15s}
    .btn:hover{opacity:.88}
    .footer{text-align:center;font-size:11px;color:#d1d5db;margin-top:24px}
  </style>
</head>
<body>
  <div class="topbar"><span class="logo">MatchImóveis</span></div>
  <div class="container">
    <div class="card">
      <h1>Remarcar visita</h1>
      <p class="sub">Escolha uma nova data e horário para sua visita ao imóvel <strong><%= visita.imovelTitulo||visita.imovelBairro||'' %></strong>.</p>
      <form method="POST" action="/cliente/visita/<%= visita.id %>/remarcar">
        <div class="field">
          <label>Nova data</label>
          <input type="date" name="novaData" required min="<%= new Date().toISOString().split('T')[0] %>">
        </div>
        <div class="field">
          <label>Horário preferido</label>
          <input type="time" name="novaHora" value="10:00">
        </div>
        <button type="submit" class="btn">Solicitar nova data →</button>
      </form>
    </div>
    <p class="footer">MatchImóveis · Assistente imobiliário com memória</p>
  </div>
</body>
</html>
