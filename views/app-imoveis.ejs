<%- include('partials/app-shell',{active:'imoveis',title:'Meus imóveis',subtitle:'Relação completa dos imóveis da carteira.',perfil:'corretor'}) %>

<div id="barra-selecao" style="display:none;position:sticky;top:0;z-index:100;background:#1a1a2e;color:#fff;padding:14px 20px;border-radius:12px;margin-bottom:16px;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;box-shadow:0 4px 20px rgba(0,0,0,0.2)">
  <div style="display:flex;align-items:center;gap:12px">
    <span id="contador-sel" style="font-weight:700;font-size:15px">0 selecionados</span>
    <button onclick="deselectAll()" style="background:rgba(255,255,255,0.15);border:none;color:#fff;padding:5px 12px;border-radius:8px;cursor:pointer;font-size:12px">✕ Limpar</button>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <button onclick="gerarXML('vivareal')" style="background:#7c3aed;border:none;color:#fff;padding:8px 14px;border-radius:8px;cursor:pointer;font-weight:600;font-size:12px">📡 VivaReal</button>
    <button onclick="gerarXML('zap')" style="background:#ea580c;border:none;color:#fff;padding:8px 14px;border-radius:8px;cursor:pointer;font-weight:600;font-size:12px">📡 ZAP</button>
    <button onclick="gerarXML('olx')" style="background:#0284c7;border:none;color:#fff;padding:8px 14px;border-radius:8px;cursor:pointer;font-weight:600;font-size:12px">📡 OLX</button>
    <button onclick="gerarXML('chaves')" style="background:#059669;border:none;color:#fff;padding:8px 14px;border-radius:8px;cursor:pointer;font-weight:600;font-size:12px">📡 Chaves</button>
    <button onclick="gerarXML('imovelweb')" style="background:#d97706;border:none;color:#fff;padding:8px 14px;border-radius:8px;cursor:pointer;font-weight:600;font-size:12px">📡 ImovelWeb</button>
    <button onclick="gerarXML('123i')" style="background:#be185d;border:none;color:#fff;padding:8px 14px;border-radius:8px;cursor:pointer;font-weight:600;font-size:12px">📡 123i</button>
  </div>
</div>

<div style="display:flex;justify-content:space-between;align-items:center;margin:0 0 16px 0;flex-wrap:wrap;gap:8px">
  <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px;font-weight:600;background:#f3f4f6;padding:8px 14px;border-radius:8px;border:1px solid #e5e7eb">
    <input type="checkbox" id="check-todos" onchange="toggleTodos(this)" style="width:16px;height:16px;cursor:pointer">
    Selecionar todos
  </label>
  <!-- <a href="/app/imoveis/exportar-excel" class="btn btn-primary" style="text-decoration:none">📥 Baixar planilha</a> -->
</div>

<div class="card">
  <div style="display:flex;gap:10px;align-items:center;justify-content:space-between;flex-wrap:wrap">
    <span><strong><%= typeof imoveis !== 'undefined' ? imoveis.length : 0 %></strong> imóveis na carteira</span>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <input id="busca" placeholder="🔎 Buscar..." oninput="filtrar()" style="padding:8px 12px;border:1px solid #ddd;border-radius:8px;min-width:220px">
      <button class="btn light" type="button" onclick="toggleFiltros()">⚙️ Filtros avançados</button>
    </div>
  </div>
  <div id="box-filtros" style="display:none;margin-top:14px;padding-top:14px;border-top:1px solid #ebebeb">
    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end">
      <div style="flex:1;min-width:120px"><label>Tipo</label>
      <select id="f-tipo"><option value="">Todos</option><option value="apartamento">🏢 Apartamento</option><option value="casa">🏠 Casa</option><option value="cobertura">🏙️ Cobertura</option><option value="loft">🏗️ Loft</option><option value="studio">🛋️ Studio</option><option value="kitnet">🏡 Kitnet</option><option value="terreno">🟩 Terreno</option><option value="comercial">🏪 Comercial</option></select>
      </div>
      <div style="flex:1;min-width:120px"><label>Bairro</label><input id="f-bairro" placeholder="Vila Mariana"></div>
      <div style="flex:1;min-width:120px"><label>Cidade</label><input id="f-cidade" placeholder="São Paulo"></div>
      <div style="flex:1;min-width:100px"><label>Valor mín.</label><input id="f-valor-min" type="number"></div>
      <div style="flex:1;min-width:100px"><label>Valor máx.</label><input id="f-valor-max" type="number"></div>
      <div style="flex:0 0 80px"><label>Área m²</label><input id="f-area-min" type="number"></div>
      <div style="flex:0 0 70px"><label>Quartos</label><input id="f-quartos" type="number"></div>
      <div style="flex:0 0 70px"><label>Vagas</label><input id="f-vagas" type="number"></div>
      <div style="flex:1;min-width:120px"><label>Operação</label>
        <select id="f-operacao"><option value="">Todas</option><option value="venda">Venda</option><option value="aluguel">Aluguel</option></select>
      </div>
      <div style="flex:1;min-width:120px"><label>Status</label>
        <select id="f-status"><option value="">Todos</option><option value="ativo">Ativo</option><option value="inativo">Inativo</option></select>
      </div>
      <div style="flex:0 0 70px"><label>Suítes</label><input id="f-suites" type="number" min="0"></div>
      <div style="flex:0 0 70px"><label>Banheiros</label><input id="f-banheiros" type="number" min="0"></div>
      <div style="flex:1;min-width:120px"><label>Proprietário</label>
        <select id="f-proprietario"><option value="">Todos</option><option value="sim">Com proprietário</option><option value="nao">Sem proprietário</option></select>
      </div>
      <div style="flex:1;min-width:120px"><label>Fotos</label>
        <select id="f-fotos"><option value="">Todos</option><option value="sim">Com fotos</option><option value="nao">Sem fotos</option></select>
      </div>
      <div style="display:flex;gap:6px;align-items:flex-end">
        <button class="btn btn-primary" onclick="filtrar()">Aplicar</button>
        <button class="btn btn-outline" onclick="limpar()">Limpar</button>
      </div>
    </div>
  </div>
</div>

<br>

<div id="grid-imoveis" style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px">
<% (typeof imoveis !== 'undefined' ? imoveis : []).forEach((item, idx) => { %>
  <div class="card imovel-card"
    data-id="<%= item.idExterno || item.id || idx %>"
    data-tipo="<%= (item.tipo||'').toLowerCase() %>"
    data-bairro="<%= (item.bairro||'').toLowerCase() %>"
    data-cidade="<%= (item.cidade||'').toLowerCase() %>"
    data-valor="<%= item.valor_imovel || 0 %>"
    data-area="<%= item.area_m2 || 0 %>"
    data-quartos="<%= item.quartos || 0 %>"
    data-vagas="<%= item.vagas || 0 %>"
    data-status="<%= (item.status||'ativo').toLowerCase() %>"
    data-suites="<%= item.suites || 0 %>"
    data-banheiros="<%= item.banheiros || 0 %>"
    data-operacao="<%= (item.transacao||item.operacao||'').toLowerCase() %>"
    data-proprietario="<%= (item.proprietario && item.proprietario.nome) ? item.proprietario.nome.toLowerCase() : '' %>"
    data-fotos="<%= (item.fotos && item.fotos.length>0) ? item.fotos.length : '0' %>"
    data-texto="<%= ((item.tipo||'')+(item.bairro||'')+(item.cidade||'')+(item.titulo||'')).toLowerCase() %>"
    style="padding:0;overflow:hidden;border-radius:12px;border:2px solid #eee;display:flex;flex-direction:column;height:100%;transition:border-color .2s,box-shadow .2s;cursor:pointer"
    onclick="toggleCard(this)">
    <div style="position:relative">
      <% if(item.fotos && item.fotos.length > 0) { %>
        <img src="<%= item.fotos[0] %>" alt="foto" style="width:100%;height:140px;object-fit:cover;display:block">
      <% } else { %>
        <div style="width:100%;height:140px;background:#f5f5f5;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:32px">🏠</div>
      <% } %>
      <div class="check-overlay" style="position:absolute;top:8px;left:8px;width:22px;height:22px;border-radius:6px;border:2px solid #fff;background:rgba(0,0,0,0.3);display:flex;align-items:center;justify-content:center;transition:.2s">
        <span class="check-icon" style="color:#fff;font-size:13px;display:none">✓</span>
      </div>
      <% if((item.status||'ativo').toLowerCase() !== 'ativo') { %>
        <div style="position:absolute;top:8px;right:8px;background:#ef4444;color:#fff;font-size:10px;font-weight:700;padding:3px 8px;border-radius:20px">INATIVO</div>
      <% } %>
    </div>
    <div style="padding:12px;display:flex;flex-direction:column;flex:1" onclick="event.stopPropagation()">
      <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:8px">
        <span style="background:#fee2e2;color:#dc2626;font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px"><%= item.tipo || 'Imóvel' %></span>
        <span style="font-size:11px;color:#999">Ext: <%= item.idExterno || '-' %></span>
      </div>
      <div style="font-weight:700;font-size:16px;color:#111;margin-bottom:4px">R$ <%= item.valor_imovel ? Number(item.valor_imovel).toLocaleString('pt-BR') : '-' %></div>
      <div style="color:#666;font-size:11px;padding:6px;margin-bottom:8px"><%= item.bairro || '-' %>, <%= item.cidade || '-' %></div>
      <% if(item.proprietario && item.proprietario.nome) { %>
        <div style="font-size:11px;color:#374151;background:#f9fafb;border:1px solid #eee;border-radius:8px;padding:7px;margin-bottom:8px;line-height:1.45">
          👤 <strong><%= item.proprietario.nome %></strong><br>
          📞 <%= item.proprietario.telefone || item.proprietario.celular || "-" %>
        </div>
      <% } %>
      <div style="display:flex;gap:8px;font-size:11px;color:#444;margin-bottom:10px;flex-wrap:wrap">
        <% if(item.area_m2) { %><span>📐 <%= item.area_m2 %>m²</span><% } %>
        <% if(item.quartos) { %><span>🛏 <%= item.quartos %> qtos</span><% } %>
        <% if(item.suites) { %><span>🛁 <%= item.suites %> suítes</span><% } %>
        <% if(item.vagas) { %><span>🚗 <%= item.vagas %> vagas</span><% } %>
      </div>
      <div style="display:flex;gap:8px;margin-top:auto">
        <a href="/app/imovel/<%= item.idExterno %>" target="_blank" class="card-action-btn details" onclick="event.stopPropagation()">👁 Ver</a>
        <a href="/app/imovel/<%= item.idExterno %>/editar" class="card-action-btn edit" onclick="event.stopPropagation()">✏️ Editar</a>
      </div>
    </div>
  </div>
<% }) %>
</div>

<div id="sem-resultados" style="display:none;text-align:center;padding:60px;color:#999">
  <div style="font-size:48px">🔍</div><p>Nenhum imóvel encontrado.</p>
</div>

<div id="modal-xml" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:999;align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:16px;padding:32px;max-width:500px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.3)">
    <div style="font-size:48px;margin-bottom:12px">📡</div>
    <h2 style="margin:0 0 8px" id="modal-titulo">Gerando XML...</h2>
    <p style="color:#666;margin-bottom:20px" id="modal-desc"></p>
    <div id="modal-loading"><div style="width:40px;height:40px;border:3px solid #f3f4f6;border-top-color:#1a1a2e;border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto"></div></div>
    <div id="modal-link" style="display:none">
      <input id="modal-url" readonly style="width:100%;padding:10px;border:1px solid #ddd;border-radius:8px;font-size:12px;margin-bottom:12px">
      <div style="display:flex;gap:8px;justify-content:center">
        <button onclick="copiarURL()" style="background:#1a1a2e;color:#fff;border:none;padding:10px 20px;border-radius:8px;cursor:pointer;font-weight:600">📋 Copiar URL</button>
        <button onclick="document.getElementById('modal-xml').style.display='none'" style="background:#f3f4f6;border:none;padding:10px 20px;border-radius:8px;cursor:pointer">Fechar</button>
      </div>
    </div>
  </div>
</div>

<script>
const selecionados = new Set();
function toggleCard(card){
  const id=card.dataset.id;
  const overlay=card.querySelector('.check-overlay');
  const icon=card.querySelector('.check-icon');
  if(selecionados.has(id)){
    selecionados.delete(id);
    card.style.borderColor='#eee';card.style.boxShadow='';
    overlay.style.background='rgba(0,0,0,0.3)';overlay.style.borderColor='#fff';icon.style.display='none';
  } else {
    selecionados.add(id);
    card.style.borderColor='#7c3aed';card.style.boxShadow='0 0 0 2px #7c3aed33';
    overlay.style.background='#7c3aed';overlay.style.borderColor='#7c3aed';icon.style.display='block';
  }
  atualizarBarra();
}
function toggleTodos(chk){
  document.querySelectorAll('.imovel-card').forEach(card=>{
    if(card.style.display==='none')return;
    const tem=selecionados.has(card.dataset.id);
    if(chk.checked&&!tem)toggleCard(card);
    else if(!chk.checked&&tem)toggleCard(card);
  });
}
function deselectAll(){
  document.querySelectorAll('.imovel-card').forEach(card=>{if(selecionados.has(card.dataset.id))toggleCard(card);});
  document.getElementById('check-todos').checked=false;
}
function atualizarBarra(){
  const barra=document.getElementById('barra-selecao');
  document.getElementById('contador-sel').textContent=selecionados.size+' selecionado'+(selecionados.size!==1?'s':'');
  barra.style.display=selecionados.size>0?'flex':'none';
}
async function gerarXML(portal){
  const ids=[...selecionados];
  const modal=document.getElementById('modal-xml');
  document.getElementById('modal-titulo').textContent='Gerando XML '+portal.toUpperCase()+'...';
  document.getElementById('modal-desc').textContent=ids.length+' imóveis selecionados.';
  document.getElementById('modal-link').style.display='none';
  document.getElementById('modal-loading').style.display='block';
  modal.style.display='flex';
  try{
    const res=await fetch('/app/gerar-xml',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({portal,ids})});
    const data=await res.json();
    document.getElementById('modal-loading').style.display='none';
    document.getElementById('modal-link').style.display='block';
    document.getElementById('modal-titulo').textContent='✅ XML gerado!';
    document.getElementById('modal-desc').textContent=data.total+' imóveis incluídos.';
    document.getElementById('modal-url').value=window.location.origin+data.url;
  }catch(e){
    document.getElementById('modal-loading').style.display='none';
    document.getElementById('modal-titulo').textContent='❌ Erro ao gerar XML';
  }
}
function copiarURL(){const u=document.getElementById('modal-url');u.select();document.execCommand('copy');alert('URL copiada!');}
function toggleFiltros(){const b=document.getElementById('box-filtros');b.style.display=b.style.display==='none'?'block':'none';}
function norm(v){return(v||'').toString().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'')}
function filtrar(){
  const busca=norm(document.getElementById('busca').value);
  const tipo=norm(document.getElementById('f-tipo')?.value);
  const bairro=norm(document.getElementById('f-bairro')?.value);
  const cidade=norm(document.getElementById('f-cidade')?.value);
  const valorMin=Number(document.getElementById('f-valor-min')?.value)||0;
  const valorMax=Number(document.getElementById('f-valor-max')?.value)||0;
  const areaMin=Number(document.getElementById('f-area-min')?.value)||0;
  const quartos=Number(document.getElementById('f-quartos')?.value)||0;
  const vagas=Number(document.getElementById('f-vagas')?.value)||0;
  const suites=Number(document.getElementById('f-suites')?.value)||0;
  const banheiros=Number(document.getElementById('f-banheiros')?.value)||0;
  const operacao=norm(document.getElementById('f-operacao')?.value);
  const status=norm(document.getElementById('f-status')?.value);
  const proprietario=document.getElementById('f-proprietario')?.value;
  const fotos=document.getElementById('f-fotos')?.value;
  let vis=0;
  document.querySelectorAll('.imovel-card').forEach(card=>{
    let ok=true;
    if(busca&&!norm(card.outerText).includes(busca))ok=false;
    if(tipo&&!card.dataset.tipo.includes(tipo))ok=false;
    if(bairro&&!card.dataset.bairro.includes(bairro))ok=false;
    if(cidade&&!card.dataset.cidade.includes(cidade))ok=false;
    if(valorMin&&Number(card.dataset.valor)<valorMin)ok=false;
    if(valorMax&&Number(card.dataset.valor)>valorMax)ok=false;
    if(areaMin&&Number(card.dataset.area)<areaMin)ok=false;
    if(quartos&&Number(card.dataset.quartos)<quartos)ok=false;
    if(vagas&&Number(card.dataset.vagas)<vagas)ok=false;
    if(suites&&Number(card.dataset.suites)<suites)ok=false;
    if(banheiros&&Number(card.dataset.banheiros)<banheiros)ok=false;
    if(operacao&&!norm(card.dataset.operacao||'').includes(operacao))ok=false;
    if(status&&norm(card.dataset.status||'')!==status)ok=false;
    if(proprietario==='sim'&&!card.dataset.proprietario)ok=false;
    if(proprietario==='nao'&&card.dataset.proprietario)ok=false;
    if(fotos==='sim'&&card.dataset.fotos==='0')ok=false;
    if(fotos==='nao'&&card.dataset.fotos!=='0')ok=false;
    card.style.display=ok?'':'none';
    if(ok)vis++;
  });
  document.getElementById('sem-resultados').style.display=vis===0?'block':'none';
}
function limpar(){
  ['f-tipo','f-bairro','f-cidade','f-valor-min','f-valor-max','f-area-min','f-quartos','f-vagas','f-suites','f-banheiros','f-operacao','f-status','f-proprietario','f-fotos'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('busca').value='';filtrar();
}
</script>
<%- include('partials/app-end') %>
<style>
@keyframes spin{to{transform:rotate(360deg)}}
.card-action-btn{flex:1;text-align:center;font-size:11px;font-weight:700;padding:8px 10px;border-radius:10px;text-decoration:none;transition:.2s}
.card-action-btn.details{background:#f3f4f6;color:#111827;border:1px solid #e5e7eb}
.card-action-btn.edit{background:var(--brand);color:#fff;border:1px solid var(--brand)}
.imovel-card:hover{border-color:#c4b5fd !important}
@media(max-width:900px){#grid-imoveis{grid-template-columns:repeat(2,minmax(0,1fr)) !important}}
@media(max-width:650px){#grid-imoveis{grid-template-columns:repeat(1,minmax(0,1fr)) !important}}
</style>
