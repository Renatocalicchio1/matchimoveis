<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>MatchImóveis — Inteligência imobiliária com memória</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="A IA que lembra de cada lead, faz o match certo e agenda visitas sozinha. Você só aparece para fechar.">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{--rosa:#FF385C;--dark:#0f0f0f;--text:#1a1a1a;--muted:#6b7280;--light:#f5f5f4;--border:#e8e8e6}
    body{font-family:'Inter',sans-serif;background:#fff;color:var(--text);-webkit-font-smoothing:antialiased;line-height:1.6}
    a{text-decoration:none;color:inherit}

    nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.97);border-bottom:1px solid var(--border);padding:0 48px;display:flex;align-items:center;justify-content:space-between;height:58px}
    .logo{font-size:17px;font-weight:600;color:var(--dark);letter-spacing:-.3px}
    .logo span{color:var(--rosa)}
    .nav-links{display:flex;align-items:center;gap:32px}
    .nav-links a{font-size:13px;color:var(--muted);transition:color .15s}
    .nav-links a:hover{color:var(--dark)}
    .btn-entrar{background:var(--dark);color:#fff;padding:7px 18px;border-radius:7px;font-size:13px;font-weight:500;border:none;cursor:pointer;transition:opacity .15s}
    .btn-entrar:hover{opacity:.85}

    .hero{padding:100px 48px 80px;max-width:960px;margin:0 auto;text-align:center}
    .hero-tag{display:inline-flex;align-items:center;gap:6px;background:var(--light);color:var(--muted);padding:5px 14px;border-radius:999px;font-size:12px;font-weight:500;margin-bottom:28px}
    .hero-tag::before{content:'';width:6px;height:6px;background:var(--rosa);border-radius:50%}
    h1{font-size:52px;font-weight:700;line-height:1.1;letter-spacing:-2px;color:var(--dark);margin-bottom:20px}
    h1 em{font-style:normal;color:var(--rosa)}
    .hero-sub{font-size:18px;color:var(--muted);max-width:520px;margin:0 auto 36px;line-height:1.7;font-weight:400}
    .hero-ctas{display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:20px}
    .btn-main{background:var(--rosa);color:#fff;padding:12px 28px;border-radius:8px;font-size:14px;font-weight:600;border:none;cursor:pointer;transition:opacity .15s}
    .btn-main:hover{opacity:.88}
    .btn-sec{background:#fff;color:var(--dark);padding:11px 24px;border-radius:8px;font-size:14px;font-weight:500;border:1px solid var(--border);cursor:pointer;transition:background .15s}
    .btn-sec:hover{background:var(--light)}
    .hero-note{font-size:12px;color:var(--muted)}

    .numeros{background:var(--dark);padding:48px}
    .numeros-inner{max-width:800px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:0;text-align:center}
    .num-val{font-size:38px;font-weight:700;color:#fff;letter-spacing:-1px}
    .num-lbl{font-size:12px;color:rgba(255,255,255,.45);margin-top:4px;font-weight:400}
    .num-div{width:1px;background:rgba(255,255,255,.1);margin:auto}

    .problema{padding:80px 48px;max-width:800px;margin:0 auto;text-align:center}
    .sec-tag{font-size:11px;font-weight:600;color:var(--rosa);text-transform:uppercase;letter-spacing:.1em;margin-bottom:14px}
    .sec-title{font-size:36px;font-weight:700;color:var(--dark);letter-spacing:-.8px;margin-bottom:14px;line-height:1.2}
    .sec-sub{font-size:16px;color:var(--muted);line-height:1.7;max-width:540px;margin:0 auto 48px}
    .dores{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:12px;overflow:hidden}
    .dor{background:#fff;padding:28px 24px}
    .dor-num{font-size:11px;font-weight:600;color:var(--rosa);margin-bottom:12px}
    .dor-title{font-size:15px;font-weight:600;color:var(--dark);margin-bottom:8px}
    .dor-desc{font-size:13px;color:var(--muted);line-height:1.65}

    .como{padding:80px 48px;background:var(--light)}
    .como-inner{max-width:900px;margin:0 auto}
    .como-header{text-align:center;margin-bottom:52px}
    .fluxo{display:grid;grid-template-columns:repeat(6,1fr);gap:0;text-align:center;position:relative}
    .fluxo::after{content:'';position:absolute;top:24px;left:8%;right:8%;height:1px;background:var(--border);z-index:0}
    .fluxo-step{position:relative;z-index:1}
    .fluxo-icon{width:48px;height:48px;border-radius:12px;background:#fff;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:20px;margin:0 auto 12px}
    .fluxo-step.ativo .fluxo-icon{background:var(--rosa);border-color:var(--rosa)}
    .fluxo-label{font-size:12px;font-weight:500;color:var(--dark)}
    .fluxo-sub{font-size:11px;color:var(--muted);margin-top:3px;line-height:1.4}

    .features{padding:80px 48px;max-width:900px;margin:0 auto}
    .features-header{text-align:center;margin-bottom:52px}
    .feat-list{display:flex;flex-direction:column;gap:1px;background:var(--border);border:1px solid var(--border);border-radius:12px;overflow:hidden}
    .feat{background:#fff;padding:28px 32px;display:grid;grid-template-columns:200px 1fr;gap:40px;align-items:start}
    .feat-left{}
    .feat-num{font-size:11px;font-weight:600;color:var(--rosa);margin-bottom:8px}
    .feat-title{font-size:17px;font-weight:600;color:var(--dark);letter-spacing:-.3px;line-height:1.3}
    .feat-right{font-size:14px;color:var(--muted);line-height:1.8;padding-top:2px}
    .feat-items{display:flex;flex-direction:column;gap:6px;margin-top:12px}
    .feat-item{font-size:13px;color:var(--muted);display:flex;align-items:flex-start;gap:6px}
    .feat-item::before{content:'→';color:var(--rosa);flex-shrink:0;font-size:12px;margin-top:2px}

    .depos{padding:80px 48px;background:var(--light)}
    .depos-inner{max-width:900px;margin:0 auto}
    .depos-header{text-align:center;margin-bottom:48px}
    .depos-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:12px;overflow:hidden}
    .depo{background:#fff;padding:28px 24px}
    .depo-text{font-size:14px;color:var(--text);line-height:1.7;margin-bottom:20px}
    .depo-autor{display:flex;align-items:center;gap:10px;border-top:1px solid var(--border);padding-top:16px}
    .depo-av{width:32px;height:32px;border-radius:50%;background:var(--light);color:var(--muted);font-size:11px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .depo-nome{font-size:13px;font-weight:500;color:var(--dark)}
    .depo-cargo{font-size:11px;color:var(--muted)}
    .depo-resultado{font-size:11px;font-weight:600;color:var(--rosa);margin-bottom:12px}

    .cta-final{padding:80px 48px;background:var(--dark)}
    .cta-final-inner{max-width:600px;margin:0 auto;text-align:center}
    .cta-final h2{font-size:38px;font-weight:700;color:#fff;letter-spacing:-1px;margin-bottom:14px;line-height:1.2}
    .cta-final p{font-size:16px;color:rgba(255,255,255,.5);margin-bottom:32px;line-height:1.7}
    .btn-cta{background:var(--rosa);color:#fff;padding:13px 32px;border-radius:8px;font-size:15px;font-weight:600;border:none;cursor:pointer;transition:opacity .15s}
    .btn-cta:hover{opacity:.88}
    .cta-note{font-size:12px;color:rgba(255,255,255,.3);margin-top:14px}

    footer{background:#0a0a0a;padding:28px 48px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;border-top:1px solid rgba(255,255,255,.06)}
    .footer-logo{font-size:14px;font-weight:600;color:rgba(255,255,255,.6)}
    .footer-logo span{color:var(--rosa)}
    .footer-links{display:flex;gap:24px}
    .footer-links a{font-size:12px;color:rgba(255,255,255,.3);transition:color .15s}
    .footer-links a:hover{color:rgba(255,255,255,.6)}
    .footer-note{font-size:11px;color:rgba(255,255,255,.2)}

    .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:99999;align-items:center;justify-content:center}
    .modal-box{background:#fff;border-radius:14px;padding:28px;width:340px;max-width:92vw;position:relative}
    .modal-close{position:absolute;top:14px;right:16px;background:none;border:none;font-size:18px;cursor:pointer;color:var(--muted);line-height:1}
    .modal-title{font-size:16px;font-weight:600;color:var(--dark);margin-bottom:3px}
    .modal-sub{font-size:12px;color:var(--muted);margin-bottom:18px}
    .modal-tabs{display:flex;gap:4px;background:var(--light);border-radius:7px;padding:3px;margin-bottom:18px}
    .modal-tab{flex:1;padding:6px;border-radius:5px;font-size:12px;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--muted);text-align:center}
    .modal-tab.on{background:#fff;color:var(--dark);border:1px solid var(--border)}
    .m-field{margin-bottom:10px}
    .m-field label{display:block;font-size:11px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;margin-bottom:4px}
    .m-field input,.m-field select{width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:7px;font-size:13px;color:var(--dark);outline:none;box-sizing:border-box;background:#fff}
    .m-field input:focus,.m-field select:focus{border-color:var(--dark)}
    .m-btn{width:100%;background:var(--rosa);color:#fff;padding:10px;border:none;border-radius:7px;font-size:13px;font-weight:600;cursor:pointer;margin-top:4px}
    .m-note{font-size:11px;color:var(--muted);text-align:center;margin-top:10px}

    @media(max-width:768px){
      nav{padding:0 20px}
      .nav-links{display:none}
      .hero{padding:60px 24px 48px}
      h1{font-size:34px}
      .hero-sub{font-size:15px}
      .numeros-inner{grid-template-columns:1fr 1fr;gap:24px}
      .problema,.como,.features,.depos,.cta-final{padding:60px 24px}
      .dores,.depos-grid{grid-template-columns:1fr}
      .fluxo{grid-template-columns:1fr 1fr;gap:20px}
      .fluxo::after{display:none}
      .feat{grid-template-columns:1fr}
      footer{padding:24px 20px;flex-direction:column;text-align:center}
    }
  </style>
</head>
<body>

<nav>
  <span class="logo">Match<span>Imóveis</span></span>
  <div class="nav-links">
    <a href="#como-funciona">Como funciona</a>
    <a href="#depoimentos">Depoimentos</a>
    <a href="#preco">Preço</a>
  </div>
  <button class="btn-entrar" onclick="openModal()">Entrar</button>
</nav>

<section class="hero">
  <div class="hero-tag">Inteligência imobiliária com memória</div>
  <h1>A IA que trabalha<br>enquanto você <em>dorme.</em></h1>
  <p class="hero-sub">Lead chega, IA qualifica, match acontece, vitrine é enviada, visita confirmada. Você só aparece para fechar o negócio.</p>
  <div class="hero-ctas">
    <button class="btn-main" onclick="openModal('cadastro')">Começar agora — pague por uso</button>
    <a href="#como-funciona" class="btn-sec">Como funciona</a>
  </div>
  <p class="hero-note">Sem mensalidade fixa · Só pague o que usar · Cancele quando quiser</p>
</section>

<div class="numeros">
  <div class="numeros-inner">
    <div><div class="num-val">2.4k+</div><div class="num-lbl">Visitas agendadas</div></div>
    <div><div class="num-val">340+</div><div class="num-lbl">Corretores ativos</div></div>
    <div><div class="num-val">89%</div><div class="num-lbl">Taxa de resposta</div></div>
    <div><div class="num-val">4min</div><div class="num-lbl">Tempo até o match</div></div>
  </div>
</div>

<section class="problema" id="problema">
  <div class="sec-tag">O problema</div>
  <h2 class="sec-title">Você está perdendo leads<br>por falta de follow-up.</h2>
  <p class="sec-sub">Leads somem, proprietários não confirmam, clientes esquecem da visita. É operacional demais para uma pessoa só dar conta.</p>
  <div class="dores">
    <div class="dor">
      <div class="dor-num">01</div>
      <div class="dor-title">Lead some sem retorno</div>
      <div class="dor-desc">Você manda mensagem, silêncio. Manda de novo, mais silêncio. A lead esfria e a venda vai embora.</div>
    </div>
    <div class="dor">
      <div class="dor-num">02</div>
      <div class="dor-title">Impossível lembrar de tudo</div>
      <div class="dor-desc">50 leads, cada um com preferências diferentes. Tipo, bairro, valor, urgência. Nenhuma ferramenta lembrava. Até agora.</div>
    </div>
    <div class="dor">
      <div class="dor-num">03</div>
      <div class="dor-title">Tempo perdido no operacional</div>
      <div class="dor-desc">Confirmar visita, avisar proprietário, mandar lembrete. Tudo manual, tudo no seu tempo. Enquanto isso, oportunidades passando.</div>
    </div>
  </div>
</section>

<section class="como" id="como-funciona">
  <div class="como-inner">
    <div class="como-header">
      <div class="sec-tag">Como funciona</div>
      <h2 class="sec-title">Do lead ao fechamento.<br>Quase sem você.</h2>
    </div>
    <div class="fluxo">
      <div class="fluxo-step">
        <div class="fluxo-icon">💬</div>
        <div class="fluxo-label">Lead chega</div>
        <div class="fluxo-sub">WhatsApp, site ou manual</div>
      </div>
      <div class="fluxo-step">
        <div class="fluxo-icon">🧠</div>
        <div class="fluxo-label">IA qualifica</div>
        <div class="fluxo-sub">Extrai perfil e intenção</div>
      </div>
      <div class="fluxo-step ativo">
        <div class="fluxo-icon">🎯</div>
        <div class="fluxo-label">Match</div>
        <div class="fluxo-sub">Imóveis compatíveis</div>
      </div>
      <div class="fluxo-step">
        <div class="fluxo-icon">🏠</div>
        <div class="fluxo-label">Vitrine enviada</div>
        <div class="fluxo-sub">WA personalizado</div>
      </div>
      <div class="fluxo-step">
        <div class="fluxo-icon">📅</div>
        <div class="fluxo-label">Visita agendada</div>
        <div class="fluxo-sub">Todos confirmados</div>
      </div>
      <div class="fluxo-step">
        <div class="fluxo-icon">🤝</div>
        <div class="fluxo-label">Você fecha</div>
        <div class="fluxo-sub">Cliente aquecido</div>
      </div>
    </div>
  </div>
</section>

<section class="features" id="features">
  <div class="features-header">
    <div class="sec-tag">Funcionalidades</div>
    <h2 class="sec-title">Tudo que você precisa.<br>Nada que você não precisa.</h2>
  </div>
  <div class="feat-list">
    <div class="feat">
      <div class="feat-left">
        <div class="feat-num">01</div>
        <div class="feat-title">Memória inteligente</div>
      </div>
      <div class="feat-right">
        A IA lembra o que cada lead quer — tipo de imóvel, bairro, valor, urgência. Mesmo semanas depois. Quando o imóvel certo aparece, a vitrine é enviada automaticamente.
        <div class="feat-items">
          <div class="feat-item">Extrai perfil de qualquer conversa no WhatsApp</div>
          <div class="feat-item">Atualiza o perfil a cada nova mensagem</div>
          <div class="feat-item">Nunca perde uma oportunidade de match</div>
        </div>
      </div>
    </div>
    <div class="feat">
      <div class="feat-left">
        <div class="feat-num">02</div>
        <div class="feat-title">Visitas no piloto automático</div>
      </div>
      <div class="feat-right">
        Lead agenda pela vitrine. Sistema envia link ao proprietário, aguarda confirmação, avisa o cliente. Oito horas antes, lembra a todos. Você não faz nada.
        <div class="feat-items">
          <div class="feat-item">Funciona com proprietário, sem proprietário ou imóvel de parceiro</div>
          <div class="feat-item">Lembrete automático 8h antes para todos</div>
          <div class="feat-item">Follow-up pós-visita automático</div>
        </div>
      </div>
    </div>
    <div class="feat">
      <div class="feat-left">
        <div class="feat-num">03</div>
        <div class="feat-title">WhatsApp integrado</div>
      </div>
      <div class="feat-right">
        Conecte seu número em 2 minutos. A partir daí, toda mensagem que chegar é processada — qualificação, match, vitrine, confirmação. Pelo número que seus clientes já conhecem.
        <div class="feat-items">
          <div class="feat-item">QR Code — pronto em menos de 2 minutos</div>
          <div class="feat-item">Filtra spam automaticamente</div>
          <div class="feat-item">Você intervém quando quiser</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="depos" id="depoimentos">
  <div class="depos-inner">
    <div class="depos-header">
      <div class="sec-tag">Depoimentos</div>
      <h2 class="sec-title">Corretores que já vendem<br>no piloto automático.</h2>
    </div>
    <div class="depos-grid">
      <div class="depo">
        <div class="depo-resultado">4 visitas na primeira semana</div>
        <p class="depo-text">"O sistema agendou 4 visitas enquanto eu estava no plantão. Não precisei fazer nada. Só apareci para fechar."</p>
        <div class="depo-autor">
          <div class="depo-av">RC</div>
          <div><div class="depo-nome">Ricardo Correia</div><div class="depo-cargo">Corretor · Balneário Camboriú</div></div>
        </div>
      </div>
      <div class="depo">
        <div class="depo-resultado">Lead de 2 meses virou venda</div>
        <p class="depo-text">"Tinha uma lead parada há 2 meses. O Match lembrou, encontrou o imóvel certo e mandou a vitrine. Fechei em 3 dias."</p>
        <div class="depo-autor">
          <div class="depo-av">AF</div>
          <div><div class="depo-nome">Ana Figueiredo</div><div class="depo-cargo">Corretora · Itajaí</div></div>
        </div>
      </div>
      <div class="depo">
        <div class="depo-resultado">3 fechamentos em 30 dias</div>
        <p class="depo-text">"Em 30 dias fechei 3 negócios de leads que vieram pelo WhatsApp. A IA fez tudo. Eu só apareci na visita."</p>
        <div class="depo-autor">
          <div class="depo-av">GP</div>
          <div><div class="depo-nome">Gustavo Pereira</div><div class="depo-cargo">Corretor · Camboriú</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cta-final" id="preco">
  <div class="cta-final-inner">
    <h2>Pronto para colocar<br>a máquina para rodar?</h2>
    <p>Sem mensalidade fixa. Você compra créditos e usa conforme a necessidade. Quanto mais resultado, mais vale cada centavo.</p>
    <button class="btn-cta" onclick="openModal('cadastro')">Começar agora — pague por uso</button>
    <p class="cta-note">Acesso imediato · Sem cartão de crédito · Cancele quando quiser</p>
  </div>
</section>

<footer>
  <span class="footer-logo">Match<span>Imóveis</span></span>
  <div class="footer-links">
    <a href="#como-funciona">Como funciona</a>
    <a href="#depoimentos">Depoimentos</a>
    <a href="#preco">Preço</a>
  </div>
  <span class="footer-note">© 2025 MatchImóveis · LGPD · Dados protegidos</span>
</footer>

<div class="modal-overlay" id="modal-login" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal()">×</button>
    <div class="modal-title">Acessar plataforma</div>
    <div class="modal-sub">Entre ou solicite seu acesso</div>
    <div class="modal-tabs" style="display:none">
      <button class="modal-tab on" id="tab-e" onclick="setTab('entrar')">Entrar</button>
      
    </div>
    <div id="form-entrar">
      <form method="POST" action="/login">
        <div class="m-field"><label>Celular</label><input name="telefone" placeholder="47999999999" required autocomplete="username"></div>
        <div class="m-field"><label>Senha</label><input name="senha" type="password" placeholder="••••••" autocomplete="current-password"></div>
        <button type="submit" class="m-btn">Entrar →</button>
      </form>
    </div>
    <div id="form-cadastro" style="display:none">
      <form method="POST" action="/cadastro-secreto">
        <input type="hidden" name="token" value="match2025">
        <div class="m-field"><label>Tipo de conta</label><select name="tipo" required><option value="">Selecione...</option><option value="corretor">Corretor</option><option value="imobiliaria">Imobiliária</option></select></div>
        <div class="m-field"><label>Nome completo</label><input name="nome" placeholder="João Silva" required></div>
        <div class="m-field"><label>Celular (será seu login)</label><input name="telefone" placeholder="47999999999" required></div>
        <div class="m-field"><label>Senha</label><input name="senha" type="password" placeholder="Mínimo 6 caracteres" required minlength="6"></div>
        <div class="m-field"><label>CRECI (opcional)</label><input name="creci" placeholder="Opcional"></div>
        <button type="submit" class="m-btn">Criar minha conta →</button>
        <p class="m-note">Sem mensalidade · Só pague o que usar</p>
      </form>
    </div>
  </div>
</div>

<script>
function openModal(aba){
  document.getElementById('modal-login').style.display='flex';
  if(aba) setTab(aba);
}
function closeModal(){
  document.getElementById('modal-login').style.display='none';
}
function setTab(t){
  document.getElementById('form-entrar').style.display=t==='entrar'?'block':'none';
  document.getElementById('form-cadastro').style.display=t==='cadastro'?'block':'none';
  document.getElementById('tab-e').className='modal-tab'+(t==='entrar'?' on':'');
  document.getElementById('tab-c').className='modal-tab'+(t==='cadastro'?' on':'');
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    e.preventDefault();
    const el=document.querySelector(a.getAttribute('href'));
    if(el)el.scrollIntoView({behavior:'smooth'});
  });
});
</script>

</body>
</html>
