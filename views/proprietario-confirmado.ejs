<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>Resposta Registrada • MatchImóveis</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; color: #222; display:flex; align-items:center; justify-content:center; min-height:100vh; }
    .card { background:#fff; border-radius:20px; padding:48px 36px; box-shadow:0 8px 30px rgba(0,0,0,.10); max-width:400px; width:90%; text-align:center; }
    .icon { font-size:72px; margin-bottom:20px; }
    h1 { font-size:22px; font-weight:800; margin-bottom:10px; color:#222; }
    p { color:#666; font-size:15px; line-height:1.6; }
    .logo { color:#ff385c; font-size:16px; font-weight:800; margin-top:32px; display:block; }
  </style>
</head>
<body>
  <div class="card">
    <% if (resposta === 'confirmar') { %>
      <div class="icon">✅</div>
      <h1>Visita confirmada!</h1>
      <p>Obrigado pela sua resposta! O corretor será notificado e entrará em contato com o cliente.</p>
    <% } else if (resposta === 'indisponivel') { %>
      <div class="icon">❌</div>
      <h1>Imóvel indisponível</h1>
      <p>Obrigado pelo retorno! O corretor será informado sobre a indisponibilidade.</p>
    <% } else if (resposta === 'remarcar') { %>
      <div class="icon">📅</div>
      <h1>Remarcação solicitada</h1>
      <p>Obrigado! O corretor entrará em contato para combinar uma nova data.</p>
    <% } %>
    <span class="logo">MatchImóveis</span>
  </div>
</body>
</html>