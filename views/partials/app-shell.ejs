<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title><%= (typeof title !== 'undefined' && title) ? title : 'MatchImoveis' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    *{box-sizing:border-box}

    body{
      margin:0;
      font-family:-apple-system,BlinkMacSystemFont,"Inter","Segoe UI",Arial,sans-serif;
      background:#faf8ff;
      color:#1f1830;
      font-size:13px;
    }

    .app{
      min-height:100vh;
      display:flex;
      background:#faf8ff;
    }

    .sidebar{
      width:238px;
      min-height:100vh;
      padding:16px 12px;
      background:#fff;
      border-right:1px solid #eee6ff;
      position:fixed;
      left:0;
      top:0;
      bottom:0;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:8px;
      font-size:16px;
      font-weight:850;
      color:#FF385C;
      padding:6px 8px 16px;
      letter-spacing:-.3px;
    }

    .brand:before{
      content:"";
      width:24px;
      height:24px;
      border-radius:8px;
      background:linear-gradient(135deg,#FF385C,#a855f7);
      display:block;
    }

    .user-card{
      background:#f6f1ff;
      border:1px solid #FF385C;
      border-radius:14px;
      padding:10px;
      margin:0 4px 14px;
    }

    .user-card strong{
      display:block;
      font-size:13px;
      color:#2e1065;
      margin-bottom:2px;
    }

    .user-card span{
      font-size:11px;
      color:#7e5ab7;
    }

    .menu{
      display:flex;
      flex-direction:column;
      gap:4px;
      padding:0 4px;
    }

    .menu a{
      display:flex;
      align-items:center;
      min-height:36px;
      padding:9px 10px;
      border-radius:11px;
      color:#4b3b63;
      text-decoration:none;
      font-size:12.5px;
      font-weight:650;
      transition:.12s ease;
    }

    .menu a:hover{
      background:#f4edff;
      color:#FF385C;
    }

    .menu a.active{
      background:#FF385C;
      color:#fff;
    }

    .content{
      margin-left:238px;
      width:calc(100% - 238px);
      padding:22px;
    }

    .page-head{
      max-width:1120px;
      margin:0 auto 14px;
      padding:8px 2px 2px;
    }

    .page-head h1{
      margin:0;
      color:#2e1065;
      font-size:24px;
      line-height:1.15;
      letter-spacing:-.5px;
    }

    .page-head p{
      margin:5px 0 0;
      color:#7c6a94;
      font-size:12.5px;
    }

    .content > .card,
    .content > .grid,
    .content > .grid-3,
    .content > form,
    .content > table{
      max-width:1120px;
      margin-left:auto;
      margin-right:auto;
    }

    .card{
      background:#fff;
      border:1px solid #eee6ff;
      border-radius:16px;
      padding:16px;
      box-shadow:0 6px 18px rgba(46,16,101,.04);
      margin-bottom:12px;
    }

    .card h2,.card h3{
      margin:0 0 6px;
      color:#33115f;
      font-size:15px;
      letter-spacing:-.2px;
    }

    .card p{
      margin:5px 0 10px;
      line-height:1.4;
    }

    .small,.muted{
      color:#7c6a94;
      font-size:12px;
    }

    .grid,.grid-3{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:12px;
    }

    .btn,button,input[type="submit"]{
      background:#FF385C;
      color:#fff;
      border:0;
      border-radius:10px;
      padding:9px 12px;
      font-size:12.5px;
      font-weight:750;
      cursor:pointer;
      text-decoration:none;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:36px;
    }

    .btn:hover,button:hover,input[type="submit"]:hover{
      background:#FF385C;
    }

    label{
      font-size:12px;
      color:#FF385C;
      font-weight:750;
    }

    input,select,textarea{
      width:100%;
      border:1px solid #e0d4f7;
      border-radius:10px;
      padding:9px 10px;
      background:#fff;
      color:#21172f;
      outline:none;
      font-size:12.5px;
    }

    input:focus,select:focus,textarea:focus{
      border-color:#FF385C;
      box-shadow:0 0 0 3px rgba(139,92,246,.10);
    }

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      border:1px solid #eee6ff;
      border-radius:14px;
      overflow:hidden;
      box-shadow:0 6px 18px rgba(46,16,101,.04);
    }

    th,td{
      padding:9px 10px;
      border-bottom:1px solid #f2ebff;
      text-align:left;
      font-size:12px;
      vertical-align:top;
    }

    th{
      color:#FF385C;
      background:#f7f2ff;
      font-weight:800;
    }

    tr:last-child td{border-bottom:0}

    .num{
      font-size:26px;
      font-weight:850;
      color:#FF385C;
      letter-spacing:-.8px;
    }

    .formgrid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
    }

    @media(max-width:1100px){
      .grid,.grid-3{grid-template-columns:repeat(2,minmax(0,1fr))}
    }

    @media(max-width:800px){
      .app{display:block}
      .sidebar{
        position:relative;
        width:100%;
        min-height:auto;
        border-right:0;
        border-bottom:1px solid #eee6ff;
      }
      .content{
        margin-left:0;
        width:100%;
        padding:16px;
      }
      .grid,.grid-3,.formgrid{
        grid-template-columns:1fr;
      }
    }
  </style>
<link rel="stylesheet" href="/airbnb.css">
</head>

<body>
<div class="app">
  <aside class="sidebar">
    <div class="brand">MatchImoveis</div>

    <div class="user-card">
      <strong><%= (typeof user !== 'undefined' && user && user.nome) ? user.nome : 'Antonio' %></strong>
      <span><%= (typeof user !== 'undefined' && user && user.tipo) ? user.tipo : 'Corretor' %></span>
    </div>

    <nav class="menu">
      <a class="<%= active==='home'?'active':'' %>" href="/app-home">Dashboard</a>
      <a class="<%= active==='imoveis'?'active':'' %>" href="/app/imoveis">Meus imóveis</a>
      <a class="<%= active==='cadastro'?'active':'' %>" href="/app/cadastro">Cadastrar imóvel</a>
      <a class="<%= active==='leads'?'active':'' %>" href="/app/leads">Leads</a>
      <a class="<%= active==='portais'?'active':'' %>" href="/app/portais">Portais / XML</a>
      <a class="<%= active==='visitas'?'active':'' %>" href="/app/visitas">Visitas</a>
      <a class="<%= active==='perfil'?'active':'' %>" href="/app/perfil">Perfil</a>
      <a href="/login">Sair</a>
    </nav>
  </aside>

  <main class="content">
    <div class="page-head">
      <h1><%= (typeof title !== 'undefined' && title) ? title : '' %></h1>
      <p><%= (typeof subtitle !== 'undefined' && subtitle) ? subtitle : '' %></p>
    </div>
